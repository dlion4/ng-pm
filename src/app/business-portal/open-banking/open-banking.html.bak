</div>
</div>
</div>
</div>
<div class="modal-footer" id="connectFoot"><button (click)="closeModal('connectBankModal')" class="btn-pm" data-bs-dismiss="modal" type="button">Cancel</button><button (click)="nextFlow('connect', 4)" class="btn-pm btn-pm-p" id="connectNext" type="button">Continue <i class="bi bi-arrow-right"></i></button></div>
</div>
</div>
</div><div (click)="closeModal('transferModal')" [attr.aria-hidden]="isModalOpen('transferModal') ? null : 'true'" [attr.aria-modal]="isModalOpen('transferModal') ? 'true' : null" [class.show]="isModalOpen('transferModal')" [style.display]="isModalOpen('transferModal') ? 'block' : 'none'" class="modal fade R" id="transferModal" tabindex="-1">
