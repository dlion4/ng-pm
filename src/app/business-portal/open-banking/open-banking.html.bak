<div (click)="$event.stopPropagation()" class="modal-dialog modal-xl modal-dialog-centered">
<div class="modal-content">
<div class="modal-header">
<h5 class="modal-title"><i class="bi bi-list-check text-info me-2"></i>Reconciliation Engine</h5>
