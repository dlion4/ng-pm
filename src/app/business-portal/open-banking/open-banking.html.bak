</div>
</div>
</div>
</div><div (click)="closeModal('obSettingsModal')" [attr.aria-hidden]="isModalOpen('obSettingsModal') ? null : 'true'" [attr.aria-modal]="isModalOpen('obSettingsModal') ? 'true' : null" [class.show]="isModalOpen('obSettingsModal')" [style.display]="isModalOpen('obSettingsModal') ? 'block' : 'none'" class="modal fade R" id="obSettingsModal" tabindex="-1">
