                        production modals are fully functional.</p>
</div>
<div class="modal-footer"><button (click)="closeModal('testModal')" class="btn-pm" data-bs-dismiss="modal" type="button">Close</button></div>
</div>
</div>
</div></section></div>

  @if (hasOpenModal()) {
    <div class="modal-backdrop fade show" (click)="closeAllModals()"></div>
  }
</div>
}
}
}
}
}
}
}
}
}
}
