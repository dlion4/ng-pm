</section><section class="paymo-page-modals" id="openBankingModals"><div (click)="closeModal('connectBankModal')" [attr.aria-hidden]="isModalOpen('connectBankModal') ? null : 'true'" [attr.aria-modal]="isModalOpen('connectBankModal') ? 'true' : null" [class.show]="isModalOpen('connectBankModal')" [style.display]="isModalOpen('connectBankModal') ? 'block' : 'none'" class="modal fade R" id="connectBankModal" tabindex="-1">
<div (click)="$event.stopPropagation()" class="modal-dialog modal-lg modal-dialog-centered">
<div class="modal-content">
<div class="modal-header">
<h5 class="modal-title"><i class="bi bi-plus-circle text-primary me-2"></i>Connect New Bank Account
                    </h5><button (click)="closeModal('connectBankModal')" class="btn-close" data-bs-dismiss="modal" type="button"></button>
</div>
<div class="modal-body">
<div class="stepper" id="connectStepper">
@for (step of stepperItems('connect'); track step.index) {
  <div [class.active]="step.index === currentStep('connect')" [class.done]="step.index < currentStep('connect')" class="step">
<div class="step-n">@if (step.index < currentStep('connect')) { <i class="bi bi-check"></i> } @else { {{ step.index }} }</div>
<div class="step-l">{{ step.label }}</div>
</div>
}
  @if (!step.last) { <div class="step-line"></div> } {
}
</div>
<div [class.active]="isStep('connect', 1)" [style.display]="isStep('connect', 1) ? 'block' : 'none'" class="fstep active" id="connectS1">
