<div class="mb-3"><label class="FL">Account Number</label><input class="FC" placeholder="Enter account number"/></div>
<div class="mb-3"><label class="FL">Account Name</label><input class="FC" placeholder="Auto-filled from bank"/></div>
<div class="mb-3"><label class="FL">Account Type</label><select class="FC">
<option>Business Current</option>
<option>Business Savings</option>
<option>Escrow / Trust</option>
<option>Project Account</option>
</select></div>
