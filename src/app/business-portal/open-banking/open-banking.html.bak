<div class="paymo-angular-page">
  @if (toastMessage) {
    <div class="pm-toast" role="status">
      <i class="bi bi-check-circle-fill"></i>
      <span>{{ toastMessage }}</span>
      <button type="button" class="pm-toast-close" (click)="clearToast()">×</button>
    </div>

<div class="paymo-open-banking-body"><section class="paymo-page-source" id="openBankingPage">

<div class="pm-page-bar">
<div>
<div class="pm-breadcrumb"><a (click)="notify('Link action handled')" role="button" tabindex="0">Home</a> / <a (click)="notify('Link action handled')" role="button" tabindex="0">Business Portal</a> / <strong>Open
                            Banking</strong></div>
<h2 style="font-family:var(--pm-font-display);font-size:20px;font-weight:700;margin:8px 0 2px">PAGE
                        3.10 — Open Banking &amp; Account Aggregation</h2>
<p style="font-size:13px;color:var(--pm-ink-soft);margin:0">Connect bank accounts via PesaLink, view
                        consolidated cash positions, execute instant transfers, reconcile transactions, and analyse
                        multi-bank cash flow — all within a single secure dashboard.</p>
</div>
<div class="d-flex flex-wrap" style="gap:8px"><button (click)="openModal('healthCheckModal')" class="btn-pm" type="button"><i class="bi bi-heart-pulse"></i> Health
                        Check</button><button (click)="openModal('reconcileModal')" class="btn-pm" type="button"><i class="bi bi-list-check"></i> Reconcile</button><button (click)="openModal('transferModal')" class="btn-pm" type="button"><i class="bi bi-arrow-left-right"></i> Transfer</button><button (click)="openModal('connectBankModal')" class="btn-pm btn-pm-p" type="button"><i class="bi bi-plus-lg"></i>
                        Connect Bank</button></div>
</div>
<div class="pm-content">
<!-- HERO STATS -->
<div class="row g-3">
<div class="col-lg-4">
<div class="C C-accent" style="min-height:170px">
<p style="margin:0;font-size:12px;color:rgba(255,255,255,.78)">Open banking hub live <span style="color:#86efac">●</span></p>
<div class="SV" style="margin:8px 0;color:#fff">7 bank accounts connected</div>
<p style="margin:0;font-size:12px;color:rgba(255,255,255,.78)">Equity, KCB, Co-op, Stanbic,
                                Family, NCBA, I&amp;M — consolidated view across all business and personal accounts.</p>
<div class="d-flex flex-wrap mt-3" style="gap:8px"><button (click)="openModal('connectBankModal')" class="btn-pm btn-sm" style="background:rgba(255,255,255,.12);border-color:rgba(255,255,255,.22);color:#fff" type="button">Connect</button><button (click)="openModal('transferModal')" class="btn-pm btn-sm" style="background:rgba(255,255,255,.12);border-color:rgba(255,255,255,.22);color:#fff" type="button">Transfer</button><button (click)="openModal('reconcileModal')" class="btn-pm btn-sm" style="background:rgba(255,255,255,.12);border-color:rgba(255,255,255,.22);color:#fff" type="button">Reconcile</button></div>
</div>
</div>
<div class="col-lg-2 col-md-4 col-6">
<div class="C" style="min-height:170px">
<p class="SL" style="color:var(--pm-accent)">TOTAL CASH POSITION</p>
<div class="SV" style="margin:6px 0">KES 18.7M</div><span class="B B-s"><i class="bi bi-graph-up"></i> +12.4% MoM</span>
<div class="mt-2" style="font-size:12px;color:var(--pm-ink-soft)">Available: KES
                                14.2M<br/>Pending: KES 4.5M</div>
</div>
</div>
<div class="col-lg-3 col-md-4 col-6">
<div class="C" style="min-height:170px">
<p class="SL" style="color:var(--pm-info)">INSTANT TRANSFERS (MTD)</p>
<div class="SV" style="margin:6px 0">KES 41.2M</div><span class="B B-i"><i class="bi bi-lightning-charge"></i> 186 transfers</span>
<div class="mt-2" style="font-size:12px;color:var(--pm-ink-soft)">Avg settlement: 12
                                seconds<br/>Success rate: 99.7%</div>
</div>
</div>
<div class="col-lg-3 col-md-4">
<div class="C" style="min-height:170px;border-left:3px solid var(--pm-warning)">
<p class="SL" style="color:var(--pm-warning)">RECONCILIATION STATUS</p>
<div class="SV" style="margin:6px 0">94.8%</div><span class="B B-w"><i class="bi bi-exclamation-triangle"></i> 14 exceptions</span>
<div class="mt-2" style="font-size:12px;color:var(--pm-ink-soft)">Auto-matched:
                                412<br/>Manual review: 14</div>
</div>
</div>
</div>
<!-- ATTENTION / SUGGESTIONS / QUICK ACTIONS -->
<div class="row g-3">
<div class="col-lg-4">
<div class="C">
<div class="d-flex justify-content-between align-items-center mb-3">
<h3 class="st">Attention Required</h3><button (click)="openModal('attentionModal')" class="btn-pm btn-sm" type="button">View all</button>
</div>
<div class="sr">
<div class="d-flex align-items-center gap-3">
<div style="width:36px;height:36px;border-radius:50%;background:var(--pm-danger-soft);color:var(--pm-danger);display:flex;align-items:center;justify-content:center;font-size:14px;flex-shrink:0">
<i class="bi bi-bank"></i></div>
<div>
<div style="font-weight:600;font-size:13px">KCB account balance below minimum
                                        </div>
<div style="font-size:11px;color:var(--pm-muted)">KES 42,100 · minimum KES
                                            50,000</div>
</div>
</div><button (click)="openModal('transferModal')" class="btn-pm btn-sm" type="button">Top-up</button>
</div>
<div class="sr">
<div class="d-flex align-items-center gap-3">
<div style="width:36px;height:36px;border-radius:50%;background:var(--pm-warning-soft);color:var(--pm-warning);display:flex;align-items:center;justify-content:center;font-size:14px;flex-shrink:0">
<i class="bi bi-list-check"></i></div>
<div>
<div style="font-weight:600;font-size:13px">14 unreconciled transactions</div>
<div style="font-size:11px;color:var(--pm-muted)">Equity &amp; Stanbic accounts
                                        </div>
</div>
</div><button (click)="openModal('reconcileModal')" class="btn-pm btn-sm" type="button">Review</button>
</div>
<div class="sr">
<div class="d-flex align-items-center gap-3">
<div style="width:36px;height:36px;border-radius:50%;background:var(--pm-info-soft);color:var(--pm-info);display:flex;align-items:center;justify-content:center;font-size:14px;flex-shrink:0">
<i class="bi bi-clock"></i></div>
<div>
<div style="font-weight:600;font-size:13px">Co-op account link expires in 7 days
                                        </div>
<div style="font-size:11px;color:var(--pm-muted)">Re-authenticate consent</div>
</div>
</div><button (click)="openModal('reauthModal')" class="btn-pm btn-sm" type="button">Re-auth</button>
</div>
</div>
</div>
<div class="col-lg-4">
<div class="C">
<div class="d-flex justify-content-between align-items-center mb-3">
<h3 class="st">Smart Suggestions</h3><span class="B B-p"><i class="bi bi-stars"></i>
                                    AI</span>
</div>
<div class="sr">
<div class="d-flex align-items-center gap-3">
<div style="width:36px;height:36px;border-radius:50%;background:var(--pm-accent-soft);color:var(--pm-accent);display:flex;align-items:center;justify-content:center;font-size:14px;flex-shrink:0">
<i class="bi bi-graph-up"></i></div>
<div>
<div style="font-weight:600;font-size:13px">Consolidate 3 low-activity accounts
                                        </div>
<div style="font-size:11px;color:var(--pm-muted)">Potential fee savings: KES
                                            18,200/year</div>
</div>
</div><button (click)="openModal('optimizeModal')" class="btn-pm btn-sm" type="button">Analyse</button>
</div>
<div class="sr">
<div class="d-flex align-items-center gap-3">
<div style="width:36px;height:36px;border-radius:50%;background:var(--pm-warning-soft);color:var(--pm-warning);display:flex;align-items:center;justify-content:center;font-size:14px;flex-shrink:0">
<i class="bi bi-clock-history"></i></div>
<div>
<div style="font-weight:600;font-size:13px">Schedule recurring transfers to
                                            payroll account</div>
<div style="font-size:11px;color:var(--pm-muted)">Reduce manual effort by 92%
                                        </div>
</div>
</div><button (click)="openModal('scheduleTransferModal')" class="btn-pm btn-sm" type="button">Setup</button>
</div>
<div class="sr">
<div class="d-flex align-items-center gap-3">
<div style="width:36px;height:36px;border-radius:50%;background:var(--pm-purple-soft);color:var(--pm-purple);display:flex;align-items:center;justify-content:center;font-size:14px;flex-shrink:0">
<i class="bi bi-shield-check"></i></div>
<div>
<div style="font-weight:600;font-size:13px">Enable real-time fraud alerts on I&amp;M
                                        </div>
<div style="font-size:11px;color:var(--pm-muted)">High-value transfers detected
                                        </div>
</div>
</div><button (click)="openModal('fraudSettingsModal')" class="btn-pm btn-sm" type="button">Enable</button>
</div>
</div>
</div>
<div class="col-lg-4">
<div class="C">
<div class="mb-3">
<h3 class="st">Quick Actions</h3>
<p class="ss">Frequent open banking workflows</p>
</div>
<div class="quick-grid"><button (click)="openModal('transferModal')" class="quick-btn" type="button"><i class="bi bi-arrow-left-right text-primary me-1"></i> Instant
                                    Transfer</button><button (click)="openModal('connectBankModal')" class="quick-btn" type="button"><i class="bi bi-plus-circle text-success me-1"></i> Link Account</button><button (click)="openModal('reconcileModal')" class="quick-btn" type="button"><i class="bi bi-list-check text-info me-1"></i> Reconcile</button><button (click)="openModal('cashFlowModal')" class="quick-btn" type="button"><i class="bi bi-graph-up me-1" style="color:var(--pm-purple)"></i> Cash Flow</button><button (click)="openModal('exportStatementModal')" class="quick-btn" type="button"><i class="bi bi-download text-muted me-1"></i> Export</button><button (click)="openModal('scheduleTransferModal')" class="quick-btn" type="button"><i class="bi bi-calendar-event me-1" style="color:var(--pm-accent)"></i>
                                    Schedule</button><button (click)="openModal('fraudSettingsModal')" class="quick-btn" type="button"><i class="bi bi-shield-exclamation text-danger me-1"></i> Fraud
                                    Alerts</button><button (click)="openModal('manageLinksModal')" class="quick-btn" type="button"><i class="bi bi-link-45deg text-warning me-1"></i> Manage Links</button></div>
</div>
</div>
</div>
<!-- SECTION 3.10.1 -->
<div class="C">
<div class="d-flex justify-content-between align-items-center mb-3 flex-wrap" style="gap:8px">
<div>
<h3 class="st"><i class="bi bi-bank2" style="color:var(--pm-primary)"></i> 3.10.1 —
                                Connected Bank Accounts &amp; Consolidated Cash Position</h3>
<p class="ss">All linked bank accounts with real-time balances, consolidated view, and
                                instant PesaLink transfer capability.</p>
</div>
<div class="d-flex" style="gap:8px"><button (click)="openModal('connectBankModal')" class="btn-pm btn-sm" type="button"><i class="bi bi-plus-lg"></i> Link
                                Bank</button><button (click)="openModal('manageLinksModal')" class="btn-pm btn-sm" type="button"><i class="bi bi-gear"></i> Manage</button></div>
</div>
<div class="row g-3">
<div class="col-lg-8">
<div class="UB">
<h4 style="font-size:14px;font-weight:700;margin:0 0 16px">Linked Bank Accounts</h4>
<div class="table-responsive">
<table class="T">
<thead>
<tr>
<th>Bank</th>
<th>Account</th>
<th>Nickname</th>
<th>Balance</th>
<th>Last Sync</th>
<th>Status</th>
<th>Actions</th>
</tr>
</thead>
<tbody>
@for (account of mockData.bankAccounts; track account.id) {
<tr>
<td><strong>{{ account.bank }}</strong></td><td>{{ account.maskedAccount }}</td><td>{{ account.nickname }}</td><td><strong>{{ account.balance }}</strong></td><td>{{ account.lastSync }}</td>
<td><span [ngClass]="badgeClass(account.status)" class="B">{{ account.statusLabel }}</span></td>
<td><div class="d-flex" style="gap:4px"><button (click)="openModal('transferModal')" class="btn-pm btn-sm" type="button">Transfer</button><button (click)="openModal('accountDetailModal')" class="btn-pm btn-sm" type="button">View</button></div></td>
</tr>
} @empty { <tr><td class="text-center py-4" colspan="7">No linked bank accounts available.</td></tr> }
</tbody>
</table>
</div>
}
</div>
</div>
<div class="col-lg-4">
<div class="UB">
<h4 style="font-size:14px;font-weight:700;margin:0 0 16px">Consolidated Position</h4>
<div class="p-3 rounded mb-3" style="background:var(--pm-accent-soft)">
<div style="font-size:11px;color:#047857;font-weight:700">TOTAL AVAILABLE CASH</div>
<div style="font-size:28px;font-weight:700;color:var(--pm-accent)">KES 14.2M</div>
</div>
<div class="p-3 rounded mb-3" style="background:var(--pm-info-soft)">
<div style="font-size:11px;color:#1D4ED8;font-weight:700">PENDING SETTLEMENTS</div>
<div style="font-size:28px;font-weight:700;color:var(--pm-info)">KES 4.5M</div>
</div>
<div class="p-3 rounded" style="background:var(--pm-surface)">
<div style="font-size:11px;color:var(--pm-muted);font-weight:700">7-DAY FORECAST
                                    </div>
<div style="font-size:22px;font-weight:700;color:var(--pm-primary)">KES 22.1M</div>
<div style="font-size:12px;color:var(--pm-ink-soft)">Expected inflows: KES 8.3M
                                    </div>
</div>
</div>
</div>
</div>
</div>
<!-- SECTION 3.10.2 -->
<div class="C">
<div class="d-flex justify-content-between align-items-center mb-3 flex-wrap" style="gap:8px">
<div>
<h3 class="st"><i class="bi bi-arrow-left-right" style="color:var(--pm-accent)"></i> 3.10.2
                                — Instant Transfers, Standing Orders &amp; Scheduled Payments</h3>
<p class="ss">Execute real-time PesaLink transfers, create recurring payment schedules, and
                                manage standing orders across all linked banks.</p>
</div>
<div class="d-flex" style="gap:8px"><button (click)="openModal('transferModal')" class="btn-pm btn-sm" type="button"><i class="bi bi-send"></i> New Transfer</button><button (click)="openModal('scheduleTransferModal')" class="btn-pm btn-sm" type="button"><i class="bi bi-clock"></i> Schedule</button></div>
</div>
<div class="row g-3">
<div class="col-lg-5">
<div class="UB">
<h4 style="font-size:14px;font-weight:700;margin:0 0 16px">Recent Transfers</h4>
<div class="table-responsive">
<table class="T">
<thead>
<tr>
<th>Date</th>
<th>From → To</th>
<th>Amount</th>
<th>Status</th>
<th>Ref</th>
</tr>
</thead>
<tbody>
@for (transfer of mockData.transferHistory; track transfer.ref) {
<tr><td>{{ transfer.dateTime }}</td><td>{{ transfer.route }}</td><td><strong>{{ transfer.amount }}</strong></td><td><span [ngClass]="badgeClass(transfer.status)" class="B">{{ transfer.statusLabel }}</span></td><td><code>{{ transfer.ref }}</code></td></tr>
} @empty { <tr><td class="text-center py-4" colspan="5">No transfer history available.</td></tr> }
</tbody>
</table>
</div>
}
</div>
</div>
<div class="col-lg-4">
<div class="UB">
<h4 style="font-size:14px;font-weight:700;margin:0 0 16px">Standing Orders</h4>
<div class="sr">
<div><strong>Payroll to KCB</strong>
<div style="font-size:11px;color:var(--pm-muted)">KES 2.4M • Every 25th</div>
</div><button (click)="openModal('scheduleTransferModal')" class="btn-pm btn-sm" type="button">Edit</button>
</div>
<div class="sr">
<div><strong>Rent to NCBA</strong>
<div style="font-size:11px;color:var(--pm-muted)">KES 185K • Monthly 1st</div>
</div><button (click)="openModal('scheduleTransferModal')" class="btn-pm btn-sm" type="button">Edit</button>
</div>
<div class="sr">
<div><strong>Utilities to Equity</strong>
<div style="font-size:11px;color:var(--pm-muted)">KES 320K • Auto</div>
</div><button (click)="openModal('scheduleTransferModal')" class="btn-pm btn-sm" type="button">Edit</button>
</div>
<div class="sr">
<div><strong>Insurance to Stanbic</strong>
<div style="font-size:11px;color:var(--pm-muted)">KES 92K • Quarterly</div>
</div><button (click)="openModal('scheduleTransferModal')" class="btn-pm btn-sm" type="button">Edit</button>
</div>
</div>
</div>
<div class="col-lg-3">
<div class="UB">
<h4 style="font-size:14px;font-weight:700;margin:0 0 16px">Quick Transfer</h4>
<div class="mb-3"><label class="FL">From</label><select class="FC">
<option>Equity ****4521</option>
<option>Co-op ****3390</option>
<option>Stanbic ****9912</option>
</select></div>
<div class="mb-3"><label class="FL">To</label><select class="FC">
<option>KCB ****7782</option>
<option>NCBA ****1128</option>
<option>Family ****5543</option>
</select></div>
<div class="mb-3"><label class="FL">Amount (KES)</label><input class="FC" value="500000"/></div>
<button (click)="openModal('transferModal')" class="btn-pm btn-pm-p w-100" type="button">Send Now</button>
</div>
</div>
</div>
</div>
<!-- SECTION 3.10.3 -->
<div class="C">
<div class="d-flex justify-content-between align-items-center mb-3 flex-wrap" style="gap:8px">
<div>
<h3 class="st"><i class="bi bi-list-check" style="color:var(--pm-info)"></i> 3.10.3 —
                                Transaction History, Reconciliation &amp; Matching Engine</h3>
<p class="ss">Multi-bank transaction feed, auto-reconciliation engine, exception handling,
                                and audit-ready reports.</p>
</div>
<div class="d-flex" style="gap:8px"><button (click)="openModal('reconcileModal')" class="btn-pm btn-sm" type="button"><i class="bi bi-list-check"></i>
                                Reconcile</button><button (click)="openModal('exportStatementModal')" class="btn-pm btn-sm" type="button"><i class="bi bi-download"></i> Export</button>
</div>
</div>
<div class="row g-3">
<div class="col-lg-8">
<div class="UB">
<h4 style="font-size:14px;font-weight:700;margin:0 0 16px">Multi-Bank Transaction Feed
                                </h4>
<div class="table-responsive">
<table class="T">
<thead>
<tr>
<th>Date</th>
<th>Bank</th>
<th>Description</th>
<th>Amount</th>
<th>Match Status</th>
<th>Action</th>
</tr>
</thead>
<tbody>
@for (txn of mockData.transactions; track txn.id) {
<tr><td>{{ txn.date }}</td><td>{{ txn.bank }}</td><td>{{ txn.description }}</td><td><strong>{{ txn.amount }}</strong></td><td><span [ngClass]="badgeClass(txn.matchStatus)" class="B">{{ txn.matchLabel }}</span></td><td><button (click)="openModal(txn.actionModal)" class="btn-pm btn-sm" type="button">{{ txn.actionLabel }}</button></td></tr>
} @empty { <tr><td class="text-center py-4" colspan="6">No transactions available.</td></tr> }
</tbody>
</table>
</div>
}
</div>
</div>
<div class="col-lg-4">
<div class="UB">
<h4 style="font-size:14px;font-weight:700;margin:0 0 16px">Reconciliation Summary</h4>
<div class="p-3 rounded mb-3" style="background:var(--pm-accent-soft)">
<div style="font-size:11px;color:#047857;font-weight:700">AUTO-MATCHED</div>
<div style="font-size:24px;font-weight:700;color:var(--pm-accent)">412 txns</div>
<div style="font-size:12px;color:#065F46">KES 38.4M</div>
</div>
<div class="p-3 rounded mb-3" style="background:var(--pm-warning-soft)">
<div style="font-size:11px;color:#B45309;font-weight:700">UNMATCHED</div>
<div style="font-size:24px;font-weight:700;color:var(--pm-warning)">14 txns</div>
<div style="font-size:12px;color:#92400E">KES 235,000</div>
</div>
<div class="p-3 rounded" style="background:var(--pm-info-soft)">
<div style="font-size:11px;color:#1D4ED8;font-weight:700">EXCEPTIONS</div>
<div style="font-size:24px;font-weight:700;color:var(--pm-info)">3 txns</div>
<div style="font-size:12px;color:#1E40AF">KES 150,000</div>
</div>
</div>
</div>
</div>
</div>
<!-- SECTION 3.10.4 -->
<div class="C">
<div class="d-flex justify-content-between align-items-center mb-3 flex-wrap" style="gap:8px">
<div>
<h3 class="st"><i class="bi bi-graph-up-arrow" style="color:var(--pm-purple)"></i> 3.10.4 —
                                Cash Flow Analytics, Forecasting &amp; Bank Performance</h3>
<p class="ss">Multi-bank cash flow trends, 90-day forecasts, bank performance benchmarking,
                                and liquidity risk indicators.</p>
</div>
<div class="d-flex" style="gap:8px"><button (click)="openModal('cashFlowModal')" class="btn-pm btn-sm" type="button"><i class="bi bi-graph-up"></i> Forecast</button><button (click)="openModal('bankBenchmarkModal')" class="btn-pm btn-sm" type="button"><i class="bi bi-bar-chart"></i> Benchmark</button></div>
</div>
<div class="row g-3">
<div class="col-lg-5">
<div class="UB">
<h4 style="font-size:14px;font-weight:700;margin:0 0 16px">90-Day Cash Flow Forecast
                                </h4>
<div class="chart-bars">
<div class="chart-bar" style="height:55%;background:var(--pm-info)"><span class="bar-label">W1</span></div>
<div class="chart-bar" style="height:68%;background:var(--pm-info)"><span class="bar-label">W2</span></div>
<div class="chart-bar" style="height:82%;background:var(--pm-warning)"><span class="bar-label">W3</span></div>
<div class="chart-bar" style="height:74%;background:var(--pm-info)"><span class="bar-label">W4</span></div>
<div class="chart-bar" style="height:90%;background:var(--pm-primary)"><span class="bar-label">W5</span></div>
<div class="chart-bar" style="height:65%;background:var(--pm-accent)"><span class="bar-label">W6</span></div>
<div class="chart-bar" style="height:78%;background:var(--pm-primary)"><span class="bar-label">W7</span></div>
<div class="chart-bar" style="height:85%;background:var(--pm-info)"><span class="bar-label">W8</span></div>
<div class="chart-bar" style="height:72%;background:var(--pm-accent)"><span class="bar-label">W9</span></div>
<div class="chart-bar" style="height:95%;background:var(--pm-primary)"><span class="bar-label">W10</span></div>
<div class="chart-bar" style="height:60%;background:var(--pm-info)"><span class="bar-label">W11</span></div>
<div class="chart-bar" style="height:88%;background:var(--pm-accent)"><span class="bar-label">W12</span></div>
</div>
