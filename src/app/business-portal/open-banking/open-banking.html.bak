<div class="stepper" id="reconStepper">
@for (step of stepperItems('recon'); track step.index) {
  <div [class.active]="step.index === currentStep('recon')" [class.done]="step.index < currentStep('recon')" class="step">
<div class="step-n">@if (step.index < currentStep('recon')) { <i class="bi bi-check"></i> } @else { {{ step.index }} }</div>
<div class="step-l">{{ step.label }}</div>
</div>
}
  @if (!step.last) { <div class="step-line"></div> } {
}
</div>
<div [class.active]="isStep('recon', 1)" [style.display]="isStep('recon', 1) ? 'block' : 'none'" class="fstep active" id="reconS1">
<h6 style="font-weight:700">Step 1: Select Period &amp; Banks</h6>
<div class="row g-3">
<div class="col-md-4"><label class="FL">From Date</label><input class="FC" type="date" value="2025-06-01"/></div>
<div class="col-md-4"><label class="FL">To Date</label><input class="FC" type="date" value="2025-06-27"/></div>
<div class="col-md-4"><label class="FL">Banks</label><select class="FC" multiple="">
<option selected="">Equity Bank</option>
<option selected="">KCB Bank</option>
<option selected="">Co-op Bank</option>
<option>Stanbic Bank</option>
</select></div>
</div>
<div class="mt-3"><button (click)="setStep('recon', 2); setStep('recon', 2)" class="btn-pm btn-sm" type="button">Start
                                Auto-Reconciliation</button></div>
</div>
<div [class.active]="isStep('recon', 2)" [style.display]="isStep('recon', 2) ? 'block' : 'none'" class="fstep" id="reconS2">
<h6 style="font-weight:700">Step 2: Review Matches</h6>
<div class="table-responsive">
<table class="T">
<thead>
<tr>
<th>Date</th>
<th>Bank</th>
<th>Description</th>
<th>Amount</th>
<th>Match</th>
<th>Action</th>
</tr>
</thead>
<tbody>
@for (match of mockData.reconciliationMatches; track match.id) {
<tr><td>{{ match.date }}</td><td>{{ match.bank }}</td><td>{{ match.description }}</td><td>{{ match.amount }}</td><td><span [ngClass]="badgeClass(match.status)" class="B">{{ match.match }}</span></td><td><button (click)="openModal(match.actionModal)" class="btn-pm btn-sm" type="button">{{ match.action }}</button></td></tr>
} @empty { <tr><td class="text-center py-4" colspan="6">No reconciliation matches found.</td></tr> }
</tbody>
</table>
</div>
}
</div>
<div [class.active]="isStep('recon', 3)" [style.display]="isStep('recon', 3) ? 'block' : 'none'" class="fstep" id="reconS3">
<div class="receipt">
<div class="ri"><i class="bi bi-check-lg"></i></div>
<h5 style="font-weight:700;color:var(--pm-accent)">Reconciliation Complete</h5>
<p style="font-size:13px;color:var(--pm-ink-soft)">412 transactions auto-matched. 14
                                exceptions require manual review.</p>
<div class="d-flex justify-content-center mt-3" style="gap:8px"><button (click)="openModal('exportStatementModal')" class="btn-pm btn-sm" type="button">Download
                                    Report</button><button (click)="openModal('exceptionModal')" class="btn-pm btn-sm" type="button">Review Exceptions</button></div>
</div>
</div>
</div>
<div class="modal-footer" id="reconFoot"><button (click)="closeModal('reconcileModal')" class="btn-pm" data-bs-dismiss="modal" type="button">Close</button><button (click)="nextFlow('recon', 3)" class="btn-pm btn-pm-p" id="reconNext" type="button">Continue <i class="bi bi-arrow-right"></i></button></div>
</div>
</div>
</div><div (click)="closeModal('scheduleTransferModal')" [attr.aria-hidden]="isModalOpen('scheduleTransferModal') ? null : 'true'" [attr.aria-modal]="isModalOpen('scheduleTransferModal') ? 'true' : null" [class.show]="isModalOpen('scheduleTransferModal')" [style.display]="isModalOpen('scheduleTransferModal') ? 'block' : 'none'" class="modal fade R" id="scheduleTransferModal" tabindex="-1">
<div (click)="$event.stopPropagation()" class="modal-dialog modal-lg modal-dialog-centered">
<div class="modal-content">
<div class="modal-header">
<h5 class="modal-title"><i class="bi bi-clock text-primary me-2"></i>Schedule Recurring Transfer
                    </h5><button (click)="closeModal('scheduleTransferModal')" class="btn-close" data-bs-dismiss="modal" type="button"></button>
</div>
<div class="modal-body">
<div class="row g-3">
<div class="col-md-6"><label class="FL">From Account</label><select class="FC">
<option>Equity ****4521</option>
<option>Co-op ****3390</option>
</select></div>
<div class="col-md-6"><label class="FL">To Account</label><select class="FC">
<option>KCB ****7782</option>
<option>NCBA ****1128</option>
</select></div>
<div class="col-md-6"><label class="FL">Amount (KES)</label><input class="FC" value="2400000"/>
</div>
<div class="col-md-6"><label class="FL">Frequency</label><select class="FC">
<option>Monthly (25th)</option>
<option>Weekly (Every Monday)</option>
<option>Quarterly</option>
<option>Custom</option>
</select></div>
<div class="col-md-6"><label class="FL">Start Date</label><input class="FC" type="date" value="2025-07-25"/></div>
<div class="col-md-6"><label class="FL">End Date / Occurrences</label><input class="FC" type="date" value="2026-06-25"/></div>
<div class="col-12"><label class="FL">Reference</label><input class="FC" value="PAYROLL-TRANSFER"/></div>
</div>
</div>
<div class="modal-footer"><button (click)="closeModal('scheduleTransferModal')" class="btn-pm" data-bs-dismiss="modal" type="button">Cancel</button><button (click)="processAction('scheduleTransferModal', 'Standing order created successfully. First transfer scheduled for 25 Jul 2025.', 'SO-20250627-1128')" class="btn-pm btn-pm-p" type="button">Create
                        Standing Order</button></div>
</div>
</div>
</div><div (click)="closeModal('accountDetailModal')" [attr.aria-hidden]="isModalOpen('accountDetailModal') ? null : 'true'" [attr.aria-modal]="isModalOpen('accountDetailModal') ? 'true' : null" [class.show]="isModalOpen('accountDetailModal')" [style.display]="isModalOpen('accountDetailModal') ? 'block' : 'none'" class="modal fade R" id="accountDetailModal" tabindex="-1">
<div (click)="$event.stopPropagation()" class="modal-dialog modal-lg modal-dialog-centered">
<div class="modal-content">
<div class="modal-header">
<h5 class="modal-title"><i class="bi bi-bank me-2"></i>Account Detail</h5><button (click)="closeModal('accountDetailModal')" class="btn-close" data-bs-dismiss="modal" type="button"></button>
</div>
<div class="modal-body">
<div class="row g-3">
<div class="col-md-6">
<div class="p-3 rounded" style="background:var(--pm-surface-2)">
<div style="font-size:11px;color:var(--pm-muted)">Bank</div>
<div style="font-size:18px;font-weight:700">Equity Bank</div>
</div>
</div>
<div class="col-md-6">
<div class="p-3 rounded" style="background:var(--pm-surface-2)">
<div style="font-size:11px;color:var(--pm-muted)">Account Number</div>
<div style="font-size:18px;font-weight:700">****4521</div>
</div>
</div>
<div class="col-md-6">
<div class="p-3 rounded" style="background:var(--pm-surface-2)">
<div style="font-size:11px;color:var(--pm-muted)">Balance</div>
<div style="font-size:22px;font-weight:700;color:var(--pm-accent)">KES 6,842,100</div>
</div>
</div>
<div class="col-md-6">
<div class="p-3 rounded" style="background:var(--pm-surface-2)">
<div style="font-size:11px;color:var(--pm-muted)">Last Sync</div>
<div style="font-size:18px;font-weight:700">Just now</div>
</div>
</div>
</div>
<div class="mt-3"><label class="FL">Recent Transactions</label>
<div class="table-responsive">
<table class="T">
<thead>
<tr>
<th>Date</th>
<th>Description</th>
<th>Amount</th>
</tr>
</thead>
<tbody>
@for (entry of mockData.accountDetailTransactions; track entry.id) {
<tr><td>{{ entry.date }}</td><td>{{ entry.description }}</td><td><strong>{{ entry.amount }}</strong></td></tr>
} @empty { <tr><td class="text-center py-4" colspan="3">No account transactions available.</td></tr> }
</tbody>
</table>
</div>
}
</div>
</div>
<div class="modal-footer"><button (click)="closeModal('accountDetailModal')" class="btn-pm" data-bs-dismiss="modal" type="button">Close</button><button (click)="openModal('transferModal')" class="btn-pm btn-pm-p" type="button">Transfer from this account</button>
</div>
</div>
</div>
</div><div (click)="closeModal('exceptionModal')" [attr.aria-hidden]="isModalOpen('exceptionModal') ? null : 'true'" [attr.aria-modal]="isModalOpen('exceptionModal') ? 'true' : null" [class.show]="isModalOpen('exceptionModal')" [style.display]="isModalOpen('exceptionModal') ? 'block' : 'none'" class="modal fade R" id="exceptionModal" tabindex="-1">
<div (click)="$event.stopPropagation()" class="modal-dialog modal-dialog-centered">
<div class="modal-content">
<div class="modal-header">
<h5 class="modal-title"><i class="bi bi-exclamation-triangle text-warning me-2"></i>Resolve
                        Exception</h5><button (click)="closeModal('exceptionModal')" class="btn-close" data-bs-dismiss="modal" type="button"></button>
</div>
<div class="modal-body">
<div class="mb-3"><label class="FL">Transaction</label>
<div class="p-3 rounded" style="background:var(--pm-surface-2);font-size:13px">26 Jun • Stanbic
                            • Unknown credit • KES 85,000</div>
</div>
<div class="mb-3"><label class="FL">Match To</label><select class="FC">
<option>Invoice INV-4428 (KES 85,000)</option>
<option>Invoice INV-4431 (KES 85,000)</option>
<option>Create new invoice</option>
</select></div>
<div class="mb-3"><label class="FL">Notes</label><textarea class="FC" rows="3">Amount matches invoice exactly. Reference slightly different due to bank truncation.</textarea>
</div>
</div>
<div class="modal-footer"><button (click)="closeModal('exceptionModal')" class="btn-pm" data-bs-dismiss="modal" type="button">Cancel</button><button (click)="processAction('exceptionModal', 'Exception resolved and transaction matched successfully.', 'EXC-20250627-0044')" class="btn-pm btn-pm-p" type="button">Resolve
                        Exception</button></div>
</div>
</div>
</div><div (click)="closeModal('cashFlowModal')" [attr.aria-hidden]="isModalOpen('cashFlowModal') ? null : 'true'" [attr.aria-modal]="isModalOpen('cashFlowModal') ? 'true' : null" [class.show]="isModalOpen('cashFlowModal')" [style.display]="isModalOpen('cashFlowModal') ? 'block' : 'none'" class="modal fade R" id="cashFlowModal" tabindex="-1">
<div (click)="$event.stopPropagation()" class="modal-dialog modal-xl modal-dialog-centered">
<div class="modal-content">
<div class="modal-header">
<h5 class="modal-title"><i class="bi bi-graph-up-arrow text-purple me-2"></i>90-Day Cash Flow
                        Forecast</h5><button (click)="closeModal('cashFlowModal')" class="btn-close" data-bs-dismiss="modal" type="button"></button>
</div>
<div class="modal-body">
<div class="row g-3">
<div class="col-md-8">
<div class="chart-bars" style="height:140px">
<div class="chart-bar" style="height:55%;background:var(--pm-info)"><span class="bar-label">W1</span></div>
<div class="chart-bar" style="height:68%;background:var(--pm-info)"><span class="bar-label">W2</span></div>
<div class="chart-bar" style="height:82%;background:var(--pm-warning)"><span class="bar-label">W3</span></div>
<div class="chart-bar" style="height:74%;background:var(--pm-info)"><span class="bar-label">W4</span></div>
<div class="chart-bar" style="height:90%;background:var(--pm-primary)"><span class="bar-label">W5</span></div>
<div class="chart-bar" style="height:65%;background:var(--pm-accent)"><span class="bar-label">W6</span></div>
<div class="chart-bar" style="height:78%;background:var(--pm-primary)"><span class="bar-label">W7</span></div>
<div class="chart-bar" style="height:85%;background:var(--pm-info)"><span class="bar-label">W8</span></div>
<div class="chart-bar" style="height:72%;background:var(--pm-accent)"><span class="bar-label">W9</span></div>
<div class="chart-bar" style="height:95%;background:var(--pm-primary)"><span class="bar-label">W10</span></div>
<div class="chart-bar" style="height:60%;background:var(--pm-info)"><span class="bar-label">W11</span></div>
<div class="chart-bar" style="height:88%;background:var(--pm-accent)"><span class="bar-label">W12</span></div>
</div>
</div>
<div class="col-md-4">
<div class="p-3 rounded mb-2" style="background:var(--pm-accent-soft)">
<div style="font-size:11px;color:#047857;font-weight:700">PEAK CASH</div>
<div style="font-size:22px;font-weight:700;color:var(--pm-accent)">Week 10</div>
<div style="font-size:14px;color:#065F46">KES 22.1M</div>
</div>
<div class="p-3 rounded mb-2" style="background:var(--pm-warning-soft)">
<div style="font-size:11px;color:#B45309;font-weight:700">LOWEST POINT</div>
<div style="font-size:22px;font-weight:700;color:var(--pm-warning)">Week 8</div>
<div style="font-size:14px;color:#92400E">KES 11.4M</div>
</div>
<div class="p-3 rounded" style="background:var(--pm-info-soft)">
<div style="font-size:11px;color:#1D4ED8;font-weight:700">NET CHANGE</div>
<div style="font-size:22px;font-weight:700;color:var(--pm-info)">+KES 3.4M</div>
</div>
</div>
</div>
</div>
<div class="modal-footer"><button (click)="closeModal('cashFlowModal')" class="btn-pm" data-bs-dismiss="modal" type="button">Close</button><button (click)="openModal('scheduleTransferModal')" class="btn-pm btn-pm-p" type="button">Schedule Transfers</button>
</div>
</div>
</div>
</div><div (click)="closeModal('fraudSettingsModal')" [attr.aria-hidden]="isModalOpen('fraudSettingsModal') ? null : 'true'" [attr.aria-modal]="isModalOpen('fraudSettingsModal') ? 'true' : null" [class.show]="isModalOpen('fraudSettingsModal')" [style.display]="isModalOpen('fraudSettingsModal') ? 'block' : 'none'" class="modal fade R" id="fraudSettingsModal" tabindex="-1">
<div (click)="$event.stopPropagation()" class="modal-dialog modal-dialog-centered">
<div class="modal-content">
<div class="modal-header">
<h5 class="modal-title"><i class="bi bi-shield-exclamation text-danger me-2"></i>Fraud &amp; Security
                        Settings</h5><button (click)="closeModal('fraudSettingsModal')" class="btn-close" data-bs-dismiss="modal" type="button"></button>
</div>
<div class="modal-body">
<div class="form-check form-switch mb-3"><input checked="" class="form-check-input" type="checkbox"/><label class="form-check-label">Real-time fraud detection on all banks</label></div>
<div class="form-check form-switch mb-3"><input checked="" class="form-check-input" type="checkbox"/><label class="form-check-label">Large transfer verification (KES 1M+)</label></div>
<div class="form-check form-switch mb-3"><input class="form-check-input" type="checkbox"/><label class="form-check-label">New beneficiary approval workflow</label></div>
<div class="mb-3"><label class="FL">Daily transfer limit (KES)</label><input class="FC" value="5000000"/></div>
<div class="mb-3"><label class="FL">Single transfer limit (KES)</label><input class="FC" value="2000000"/></div>
<div class="p-3 rounded" style="background:var(--pm-info-soft);font-size:12px"><i class="bi bi-info-circle me-1"></i> All changes require 2FA confirmation and are logged in
                        the security audit trail.</div>
</div>
<div class="modal-footer"><button (click)="closeModal('fraudSettingsModal')" class="btn-pm" data-bs-dismiss="modal" type="button">Cancel</button><button (click)="processAction('fraudSettingsModal', 'Fraud settings updated and applied across all banks.', '')" class="btn-pm btn-pm-p" type="button">Save
                        Settings</button></div>
</div>
</div>
</div><div (click)="closeModal('consentModal')" [attr.aria-hidden]="isModalOpen('consentModal') ? null : 'true'" [attr.aria-modal]="isModalOpen('consentModal') ? 'true' : null" [class.show]="isModalOpen('consentModal')" [style.display]="isModalOpen('consentModal') ? 'block' : 'none'" class="modal fade R" id="consentModal" tabindex="-1">
<div (click)="$event.stopPropagation()" class="modal-dialog modal-lg modal-dialog-centered">
<div class="modal-content">
<div class="modal-header">
<h5 class="modal-title"><i class="bi bi-key text-primary me-2"></i>Consent Management</h5><button (click)="closeModal('consentModal')" class="btn-close" data-bs-dismiss="modal" type="button"></button>
</div>
<div class="modal-body">
<div class="table-responsive">
<table class="T">
<thead>
<tr>
<th>Bank</th>
<th>Consent</th>
<th>Expires</th>
<th>Status</th>
<th>Action</th>
</tr>
</thead>
<tbody>
@for (consent of mockData.consents; track consent.bank) {
<tr><td>{{ consent.bank }}</td><td>{{ consent.scope }}</td><td>{{ consent.expires }}</td><td><span [ngClass]="badgeClass(consent.status)" class="B">{{ consent.statusLabel }}</span></td><td><button (click)="handleConsentAction(consent)" class="btn-pm btn-sm" type="button">{{ consent.actionLabel }}</button></td></tr>
} @empty { <tr><td class="text-center py-4" colspan="5">No bank consents available.</td></tr> }
</tbody>
</table>
</div>
}
</div>
<div class="modal-footer"><button (click)="closeModal('consentModal')" class="btn-pm" data-bs-dismiss="modal" type="button">Close</button></div>
</div>
</div>
</div><div (click)="closeModal('reauthModal')" [attr.aria-hidden]="isModalOpen('reauthModal') ? null : 'true'" [attr.aria-modal]="isModalOpen('reauthModal') ? 'true' : null" [class.show]="isModalOpen('reauthModal')" [style.display]="isModalOpen('reauthModal') ? 'block' : 'none'" class="modal fade R" id="reauthModal" tabindex="-1">
<div (click)="$event.stopPropagation()" class="modal-dialog modal-dialog-centered">
<div class="modal-content">
<div class="modal-header">
<h5 class="modal-title"><i class="bi bi-arrow-repeat text-warning me-2"></i>Re-authenticate Bank
                        Consent</h5><button (click)="closeModal('reauthModal')" class="btn-close" data-bs-dismiss="modal" type="button"></button>
</div>
<div class="modal-body">
<div class="mb-3"><label class="FL">Bank</label><select class="FC">
<option>Family Bank</option>
<option>Co-op Bank</option>
</select></div>
<div class="p-3 rounded" style="background:var(--pm-warning-soft);font-size:13px"><i class="bi bi-info-circle me-1"></i> You will be redirected to the bank's secure portal to
                        renew consent. Your existing consent will remain active until the new one is granted.</div>
</div>
<div class="modal-footer"><button (click)="closeModal('reauthModal')" class="btn-pm" data-bs-dismiss="modal" type="button">Cancel</button><button (click)="processAction('reauthModal', 'Re-authorisation request sent. Please complete on the bank portal.', '')" class="btn-pm btn-pm-p" type="button">Start
                        Re-auth</button></div>
</div>
</div>
</div><div (click)="closeModal('healthCheckModal')" [attr.aria-hidden]="isModalOpen('healthCheckModal') ? null : 'true'" [attr.aria-modal]="isModalOpen('healthCheckModal') ? 'true' : null" [class.show]="isModalOpen('healthCheckModal')" [style.display]="isModalOpen('healthCheckModal') ? 'block' : 'none'" class="modal fade R" id="healthCheckModal" tabindex="-1">
<div (click)="$event.stopPropagation()" class="modal-dialog modal-lg modal-dialog-centered">
<div class="modal-content">
<div class="modal-header">
<h5 class="modal-title"><i class="bi bi-heart-pulse text-danger me-2"></i>Open Banking Health Check
                    </h5><button (click)="closeModal('healthCheckModal')" class="btn-close" data-bs-dismiss="modal" type="button"></button>
</div>
<div class="modal-body">
<div class="row g-3 mb-3">
<div class="col-md-3 col-6">
<div class="p-3 rounded text-center" style="background:var(--pm-accent-soft)">
<div style="font-size:28px;font-weight:800;color:var(--pm-accent);font-family:var(--pm-font-display)">
                                    96</div>
<div style="font-size:10px;font-weight:700;color:#047857">HEALTH SCORE</div>
</div>
</div>
<div class="col-md-3 col-6">
<div class="p-3 rounded text-center" style="background:var(--pm-info-soft)">
<div style="font-size:24px;font-weight:700;color:var(--pm-info)">7/7</div>
<div style="font-size:10px;font-weight:700;color:#1D4ED8">LINKED</div>
</div>
</div>
<div class="col-md-3 col-6">
<div class="p-3 rounded text-center" style="background:var(--pm-warning-soft)">
<div style="font-size:24px;font-weight:700;color:var(--pm-warning)">1</div>
<div style="font-size:10px;font-weight:700;color:#B45309">EXPIRING</div>
</div>
</div>
<div class="col-md-3 col-6">
<div class="p-3 rounded text-center" style="background:var(--pm-purple-soft)">
<div style="font-size:24px;font-weight:700;color:var(--pm-purple)">99.8%</div>
<div style="font-size:10px;font-weight:700;color:#6D28D9">UPTIME</div>
</div>
</div>
</div>
<div class="table-responsive">
<table class="T">
<thead>
<tr>
<th>Bank</th>
<th>Connection</th>
<th>Sync</th>
<th>Consent</th>
<th>Score</th>
</tr>
</thead>
<tbody>
@for (row of mockData.healthRows; track row.bank) {
<tr><td>{{ row.bank }}</td><td><span [ngClass]="badgeClass(row.connectionStatus)" class="B">{{ row.connection }}</span></td><td>{{ row.sync }}</td><td><span [ngClass]="badgeClass(row.consentStatus)" class="B">{{ row.consent }}</span></td><td><strong>{{ row.score }}</strong></td></tr>
} @empty { <tr><td class="text-center py-4" colspan="5">No health records available.</td></tr> }
</tbody>
</table>
</div>
}
</div>
<div class="modal-footer"><button (click)="closeModal('healthCheckModal')" class="btn-pm" data-bs-dismiss="modal" type="button">Close</button><button (click)="openModal('reauthModal')" class="btn-pm btn-pm-p" type="button">Fix Issues</button></div>
</div>
</div>
</div><div (click)="closeModal('bankBenchmarkModal')" [attr.aria-hidden]="isModalOpen('bankBenchmarkModal') ? null : 'true'" [attr.aria-modal]="isModalOpen('bankBenchmarkModal') ? 'true' : null" [class.show]="isModalOpen('bankBenchmarkModal')" [style.display]="isModalOpen('bankBenchmarkModal') ? 'block' : 'none'" class="modal fade R" id="bankBenchmarkModal" tabindex="-1">
<div (click)="$event.stopPropagation()" class="modal-dialog modal-lg modal-dialog-centered">
<div class="modal-content">
<div class="modal-header">
<h5 class="modal-title"><i class="bi bi-bar-chart text-purple me-2"></i>Bank Performance Benchmark
                    </h5><button (click)="closeModal('bankBenchmarkModal')" class="btn-close" data-bs-dismiss="modal" type="button"></button>
</div>
<div class="modal-body">
<div class="table-responsive">
<table class="T">
<thead>
<tr>
<th>Bank</th>
<th>Settlement</th>
<th>Fee</th>
<th>Uptime</th>
<th>Sync Speed</th>
<th>Score</th>
</tr>
</thead>
<tbody>
@for (bank of mockData.bankBenchmarks; track bank.bank) {
<tr><td>{{ bank.bank }}</td><td>{{ bank.settlement }}</td><td>{{ bank.fee }}</td><td>{{ bank.uptime }}</td><td>{{ bank.syncSpeed }}</td><td><strong>{{ bank.score }}</strong></td></tr>
} @empty { <tr><td class="text-center py-4" colspan="6">No benchmark data available.</td></tr> }
</tbody>
</table>
</div>
}
