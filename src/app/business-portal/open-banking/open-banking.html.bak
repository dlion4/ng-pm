</div>
<div class="col-md-4 col-6">
<div (click)="selectBox($event)" class="p-3 border rounded text-center" style="cursor:pointer"><i class="bi bi-bank d-block mb-1" style="font-size:22px;color:var(--pm-primary)"></i><strong style="font-size:12px">KCB Bank</strong></div>
</div>
<div class="col-md-4 col-6">
<div (click)="selectBox($event)" class="p-3 border rounded text-center" style="cursor:pointer"><i class="bi bi-bank d-block mb-1" style="font-size:22px;color:var(--pm-primary)"></i><strong style="font-size:12px">Co-op Bank</strong></div>
</div>
<div class="col-md-4 col-6">
<div (click)="selectBox($event)" class="p-3 border rounded text-center" style="cursor:pointer"><i class="bi bi-bank d-block mb-1" style="font-size:22px;color:var(--pm-primary)"></i><strong style="font-size:12px">Stanbic Bank</strong></div>
</div>
<div class="col-md-4 col-6">
<div (click)="selectBox($event)" class="p-3 border rounded text-center" style="cursor:pointer"><i class="bi bi-bank d-block mb-1" style="font-size:22px;color:var(--pm-primary)"></i><strong style="font-size:12px">Family Bank</strong></div>
</div>
<div class="col-md-4 col-6">
<div (click)="selectBox($event)" class="p-3 border rounded text-center" style="cursor:pointer"><i class="bi bi-bank d-block mb-1" style="font-size:22px;color:var(--pm-primary)"></i><strong style="font-size:12px">NCBA Bank</strong></div>
</div>
<div class="col-md-4 col-6">
<div (click)="selectBox($event)" class="p-3 border rounded text-center" style="cursor:pointer"><i class="bi bi-bank d-block mb-1" style="font-size:22px;color:var(--pm-primary)"></i><strong style="font-size:12px">I&amp;M Bank</strong></div>
</div>
<div class="col-md-4 col-6">
<div (click)="selectBox($event)" class="p-3 border rounded text-center" style="cursor:pointer"><i class="bi bi-bank d-block mb-1" style="font-size:22px;color:var(--pm-primary)"></i><strong style="font-size:12px">Absa Bank</strong></div>
</div>
</div>
</div>
<div [class.active]="isStep('connect', 2)" [style.display]="isStep('connect', 2) ? 'block' : 'none'" class="fstep" id="connectS2">
