</select></div>
<div class="form-check form-switch mb-2"><input checked="" class="form-check-input" type="checkbox"/><label class="form-check-label">Email daily reconciliation summary</label></div>
<div class="form-check form-switch mb-2"><input checked="" class="form-check-input" type="checkbox"/><label class="form-check-label">SMS for large unmatched amounts</label></div>
<div class="form-check form-switch"><input class="form-check-input" type="checkbox"/><label class="form-check-label">Auto-create exceptions for unmatched</label></div>
</div>
<div class="modal-footer"><button (click)="closeModal('obSettingsModal')" class="btn-pm" data-bs-dismiss="modal" type="button">Cancel</button><button (click)="processAction('obSettingsModal', 'Open banking preferences saved.', '')" class="btn-pm btn-pm-p" type="button">Save
                        Settings</button></div>
</div>
</div>
</div><div (click)="closeModal('obSupportModal')" [attr.aria-hidden]="isModalOpen('obSupportModal') ? null : 'true'" [attr.aria-modal]="isModalOpen('obSupportModal') ? 'true' : null" [class.show]="isModalOpen('obSupportModal')" [style.display]="isModalOpen('obSupportModal') ? 'block' : 'none'" class="modal fade R" id="obSupportModal" tabindex="-1">
<div (click)="$event.stopPropagation()" class="modal-dialog modal-dialog-centered">
