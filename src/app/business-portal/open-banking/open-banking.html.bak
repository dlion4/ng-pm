</div>
</div>
</div><div (click)="closeModal('optimizeModal')" [attr.aria-hidden]="isModalOpen('optimizeModal') ? null : 'true'" [attr.aria-modal]="isModalOpen('optimizeModal') ? 'true' : null" [class.show]="isModalOpen('optimizeModal')" [style.display]="isModalOpen('optimizeModal') ? 'block' : 'none'" class="modal fade R" id="optimizeModal" tabindex="-1">
<div (click)="$event.stopPropagation()" class="modal-dialog modal-lg modal-dialog-centered">
<div class="modal-content">
<div class="modal-header">
<h5 class="modal-title"><i class="bi bi-lightbulb text-warning me-2"></i>Account Optimisation
                        Analysis</h5><button (click)="closeModal('optimizeModal')" class="btn-close" data-bs-dismiss="modal" type="button"></button>
</div>
<div class="modal-body">
<div class="p-3 rounded mb-3" style="background:var(--pm-accent-soft)">
<div style="font-size:11px;color:#047857;font-weight:700">RECOMMENDED ACTIONS</div>
<div style="font-size:20px;font-weight:700;color:var(--pm-accent)">Close 3 low-activity accounts
                        </div>
<div style="font-size:14px;color:#065F46">Potential annual fee savings: KES 18,200</div>
</div>
<div class="table-responsive">
<table class="T">
<thead>
<tr>
<th>Account</th>
<th>Avg Monthly Txns</th>
<th>Annual Fees</th>
<th>Recommendation</th>
</tr>
</thead>
<tbody>
@for (item of mockData.optimizationAccounts; track item.account) {
<tr><td>{{ item.account }}</td><td>{{ item.averageMonthlyTransactions }}</td><td>{{ item.annualFees }}</td><td><span class="B B-w">{{ item.recommendation }}</span></td></tr>
} @empty { <tr><td class="text-center py-4" colspan="4">No optimization recommendations available.</td></tr> }
</tbody>
</table>
</div>
}
</div>
<div class="modal-footer"><button (click)="closeModal('optimizeModal')" class="btn-pm" data-bs-dismiss="modal" type="button">Close</button><button (click)="processAction('optimizeModal', 'Optimisation plan saved. Accounts scheduled for closure review.', '')" class="btn-pm btn-pm-p" type="button">Adopt
                        Plan</button></div>
</div>
</div>
</div><div (click)="closeModal('manageLinksModal')" [attr.aria-hidden]="isModalOpen('manageLinksModal') ? null : 'true'" [attr.aria-modal]="isModalOpen('manageLinksModal') ? 'true' : null" [class.show]="isModalOpen('manageLinksModal')" [style.display]="isModalOpen('manageLinksModal') ? 'block' : 'none'" class="modal fade R" id="manageLinksModal" tabindex="-1">
<div (click)="$event.stopPropagation()" class="modal-dialog modal-lg modal-dialog-centered">
<div class="modal-content">
<div class="modal-header">
<h5 class="modal-title"><i class="bi bi-link-45deg me-2"></i>Manage Bank Links</h5><button (click)="closeModal('manageLinksModal')" class="btn-close" data-bs-dismiss="modal" type="button"></button>
</div>
<div class="modal-body">
<div class="table-responsive">
<table class="T">
<thead>
<tr>
<th>Bank</th>
<th>Account</th>
<th>Consent</th>
<th>Sync</th>
<th>Actions</th>
</tr>
</thead>
<tbody>
@for (link of mockData.managedLinks; track link.bank + link.account) {
<tr><td>{{ link.bank }}</td><td>{{ link.account }}</td><td><span [ngClass]="badgeClass(link.consentStatus)" class="B">{{ link.consent }}</span></td><td><span [ngClass]="badgeClass(link.syncStatus)" class="B">{{ link.sync }}</span></td><td><button (click)="openModal('reauthModal')" class="btn-pm btn-sm" type="button">Re-auth</button><button (click)="processAction('manageLinksModal', link.secondaryActionMessage, '')" class="btn-pm btn-sm" type="button">{{ link.secondaryAction }}</button></td></tr>
} @empty { <tr><td class="text-center py-4" colspan="5">No bank links configured.</td></tr> }
</tbody>
</table>
</div>
}
</div>
<div class="modal-footer"><button (click)="closeModal('manageLinksModal')" class="btn-pm" data-bs-dismiss="modal" type="button">Close</button></div>
</div>
</div>
</div><div (click)="closeModal('profileModal')" [attr.aria-hidden]="isModalOpen('profileModal') ? null : 'true'" [attr.aria-modal]="isModalOpen('profileModal') ? 'true' : null" [class.show]="isModalOpen('profileModal')" [style.display]="isModalOpen('profileModal') ? 'block' : 'none'" class="modal fade R" id="profileModal" tabindex="-1">
<div (click)="$event.stopPropagation()" class="modal-dialog modal-dialog-centered">
<div class="modal-content">
