                                </div>
</div>
</div>
</div>
</div>
<div class="modal-footer"><button (click)="closeModal('matchDetailModal')" class="btn-pm" data-bs-dismiss="modal" type="button">Close</button></div>
</div>
</div>
</div><div (click)="closeModal('exportStatementModal')" [attr.aria-hidden]="isModalOpen('exportStatementModal') ? null : 'true'" [attr.aria-modal]="isModalOpen('exportStatementModal') ? 'true' : null" [class.show]="isModalOpen('exportStatementModal')" [style.display]="isModalOpen('exportStatementModal') ? 'block' : 'none'" class="modal fade R" id="exportStatementModal" tabindex="-1">
<div (click)="$event.stopPropagation()" class="modal-dialog modal-dialog-centered">
<div class="modal-content">
<div class="modal-header">
<h5 class="modal-title"><i class="bi bi-download me-2"></i>Export Multi-Bank Statement</h5><button (click)="closeModal('exportStatementModal')" class="btn-close" data-bs-dismiss="modal" type="button"></button>
</div>
