</div>
<div class="col-6">
<div class="p-2 rounded" style="background:var(--pm-surface-2)"><span class="text-muted">Open Exceptions</span><br/><strong>14</strong></div>
</div>
</div>
</div>
<div class="modal-footer"><button (click)="closeModal('profileModal')" class="btn-pm" data-bs-dismiss="modal" type="button">Close</button></div>
</div>
</div>
</div><div (click)="closeModal('notifModal')" [attr.aria-hidden]="isModalOpen('notifModal') ? null : 'true'" [attr.aria-modal]="isModalOpen('notifModal') ? 'true' : null" [class.show]="isModalOpen('notifModal')" [style.display]="isModalOpen('notifModal') ? 'block' : 'none'" class="modal fade R" id="notifModal" tabindex="-1">
<div (click)="$event.stopPropagation()" class="modal-dialog modal-dialog-centered">
<div class="modal-content">
<div class="modal-header">
<h5 class="modal-title"><i class="bi bi-bell me-2"></i>Notifications (9)</h5><button (click)="closeModal('notifModal')" class="btn-close" data-bs-dismiss="modal" type="button"></button>
</div>
<div class="modal-body" style="max-height:500px;overflow-y:auto">
<div class="p-3 rounded mb-2" style="background:var(--pm-danger-soft);font-size:13px"><strong>KCB
                            balance below minimum</strong>
<div style="font-size:11px;color:#7F1D1D">KES 42,100 (min KES 50,000)</div>
</div>
<div class="p-3 rounded mb-2" style="background:var(--pm-warning-soft);font-size:13px"><strong>Co-op
                            consent expires in 7 days</strong>
<div style="font-size:11px;color:#92400E">Re-authenticate before 04 Jul</div>
</div>
<div class="p-3 rounded mb-2" style="background:var(--pm-info-soft);font-size:13px"><strong>14
                            transactions unmatched</strong>
<div style="font-size:11px;color:#1E40AF">Requires reconciliation review</div>
</div>
<div class="p-3 rounded mb-2" style="background:var(--pm-accent-soft);font-size:13px">
<strong>Transfer PL-442189 completed</strong>
<div style="font-size:11px;color:#065F46">KES 850,000 to KCB ****7782</div>
</div>
<div class="p-3 rounded mb-2" style="background:#fff;border:1px solid var(--pm-border);font-size:13px"><strong>Family Bank
                            link expired</strong>
<div style="font-size:11px;color:var(--pm-muted)">Reconnect to resume sync</div>
</div>
</div>
<div class="modal-footer"><button (click)="openModal('obSettingsModal')" class="btn-pm" type="button"><i class="bi bi-gear"></i> Settings</button><button (click)="closeModal('notifModal')" class="btn-pm" data-bs-dismiss="modal" type="button">Close</button></div>
</div>
</div>
</div><div (click)="closeModal('optimizeModal2')" [attr.aria-hidden]="isModalOpen('optimizeModal2') ? null : 'true'" [attr.aria-modal]="isModalOpen('optimizeModal2') ? 'true' : null" [class.show]="isModalOpen('optimizeModal2')" [style.display]="isModalOpen('optimizeModal2') ? 'block' : 'none'" class="modal fade R" id="optimizeModal2" tabindex="-1">
<div (click)="$event.stopPropagation()" class="modal-dialog modal-lg modal-dialog-centered">
<div class="modal-content">
<div class="modal-header">
<h5 class="modal-title"><i class="bi bi-lightbulb text-warning me-2"></i>Account Optimisation</h5>
<button (click)="closeModal('optimizeModal2')" class="btn-close" data-bs-dismiss="modal" type="button"></button>
</div>
<div class="modal-body">
