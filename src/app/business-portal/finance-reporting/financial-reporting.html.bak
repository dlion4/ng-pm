      <div class="table-responsive"><table class="pm-table"><thead><tr><th>Category</th><th>Amount (YTD)</th><th>% of Opex</th><th>Trend (vs Last Year)</th></tr></thead><tbody><tr><td>Payroll &amp; Benefits</td><td>KES 18.2M</td><td>64%</td><td>+12% <i class="bi bi-arrow-up-right text-danger"></i></td></tr><tr><td>Inventory &amp; Raw Mat</td><td>KES 6.5M</td><td>23%</td><td>+4% <i class="bi bi-arrow-up-right text-warning"></i></td></tr><tr><td>Software &amp; IT</td><td>KES 1.8M</td><td>6%</td><td>+18% <i class="bi bi-arrow-up-right text-danger"></i></td></tr><tr><td>Utilities</td><td>KES 1.1M</td><td>4%</td><td>-2% <i class="bi bi-arrow-down-right text-success"></i></td></tr></tbody></table></div>
