  <div class="modal-header"><h5 class="modal-title"><i class="bi bi-eye text-primary me-2"></i>Activity Detail View</h5><button class="btn-close" (click)="closeModal()"></button></div>
  <div class="modal-body">
    <div class="p-3 rounded mb-3" style="background:var(--pm-surface-2);font-size:13px"><div class="d-flex justify-content-between mb-2"><span class="text-muted">User</span><strong>Titus G. (Admin)</strong></div><div class="d-flex justify-content-between mb-2"><span class="text-muted">Timestamp</span><strong>28 Jun 2025, 14:32:01 EAT</strong></div><div class="d-flex justify-content-between mb-2"><span class="text-muted">IP Address</span><strong>197.232.14.8 (Kenya)</strong></div><div class="d-flex justify-content-between mb-2"><span class="text-muted">Device</span><strong>Mac OS X, Chrome 114</strong></div><div class="d-flex justify-content-between"><span class="text-muted">Status</span><span class="pm-badge pm-badge-success">Success</span></div></div>
    <h6 style="font-weight:700">Action Payload</h6>
    <pre class="p-3 border rounded" style="background:#f8f9fa;font-size:11px;overflow-x:auto;margin:0">{
  "action": "APPROVE_DISBURSEMENT_BATCH",
  "batch_id": "9921",
  "total_amount": 3250000,
  "records": 42,
  "verification_method": "MFA_OTP",
  "hash": "a4b1c2d3e4f5..."
}</pre>
  </div>
  <div class="modal-footer"><button class="pm-btn" (click)="closeModal()">Close</button></div>
</div>
</div>

<!-- 18. Statutory Deductions -->
@if (activeModal === 'statutoryDeductionsModal') {
<div class="modal-dialog modal-lg modal-dialog-centered" style="position:relative">
<div class="modal-content">
  <div class="modal-header"><h5 class="modal-title"><i class="bi bi-shield-check text-warning me-2"></i>Statutory Deductions (June 2025)</h5><button class="btn-close" (click)="closeModal()"></button></div>
  <div class="modal-body">
    @if (!statutoryDeductionsSaved) {
    <div>
      <div class="row g-3 mb-3">
        <div class="col-md-4"><div class="p-3 rounded" style="background:var(--pm-warning-soft)"><div style="font-size:11px;color:#B45309;font-weight:700">PAYE (KRA)</div><strong style="font-size:20px;color:var(--pm-warning)">KES 450,200</strong></div></div>
        <div class="col-md-4"><div class="p-3 rounded" style="background:var(--pm-info-soft)"><div style="font-size:11px;color:#1D4ED8;font-weight:700">NSSF</div><strong style="font-size:20px;color:var(--pm-info)">KES 84,000</strong></div></div>
        <div class="col-md-4"><div class="p-3 rounded" style="background:var(--pm-accent-soft)"><div style="font-size:11px;color:#047857;font-weight:700">SHIF</div><strong style="font-size:20px;color:var(--pm-accent)">KES 72,500</strong></div></div>
      </div>
      <div class="table-responsive"><table class="pm-table"><thead><tr><th>Filing</th><th>Due Date</th><th>Employees</th><th>Total Due</th><th>Action</th></tr></thead><tbody><tr><td>PAYE (P10)</td><td>09 Jul 2025</td><td>42</td><td>KES 450,200</td><td><button class="pm-btn pm-btn-sm">CSV Extract</button></td></tr><tr><td>NSSF</td><td>09 Jul 2025</td><td>42</td><td>KES 84,000</td><td><button class="pm-btn pm-btn-sm">Excel Extract</button></td></tr><tr><td>SHIF</td><td>09 Jul 2025</td><td>42</td><td>KES 72,500</td><td><button class="pm-btn pm-btn-sm">Excel Extract</button></td></tr><tr><td>Housing Levy</td><td>09 Jul 2025</td><td>42</td><td>KES 48,000</td><td><button class="pm-btn pm-btn-sm">CSV Extract</button></td></tr></tbody></table><div (click)="processAction('statutoryDeductionsModal','CSV Downloaded.',''); processAction('statutoryDeductionsModal','Excel Downloaded.',''); processAction('statutoryDeductionsModal','Excel Downloaded.',''); processAction('statutoryDeductionsModal','CSV Downloaded.','')">
    </div>
    @if (statutoryDeductionsSaved) {
    <div class="pm-receipt"><div class="receipt-icon"><i class="bi bi-check-lg"></i></div><h5 style="font-weight:700;color:var(--pm-accent)">Success</h5><p style="font-size:13px;color:var(--pm-ink-soft)">Extract downloaded successfully.</p><div class="d-flex justify-content-center mt-3" style="gap:8px"><button class="pm-btn pm-btn-sm" (click)="resetAllModals()"><i class="bi bi-arrow-clockwise"></i> Refresh</button></div></div>
    }
  </div>
  <div class="modal-footer"><button class="pm-btn">Close</button><button class="pm-btn pm-btn-primary">Export All ZIP</button><div (click)="closeModal(); closeModal(); openModal('downloadStatementModal')">
</div>
</div>

<!-- 19. Export Trial Balance -->
@if (activeModal === 'exportTrialBalanceModal') {
<div class="modal-dialog modal-lg modal-dialog-centered" style="position:relative">
<div class="modal-content">
  <div class="modal-header"><h5 class="modal-title"><i class="bi bi-file-spreadsheet text-danger me-2"></i>Trial Balance Preview</h5><button class="btn-close" (click)="closeModal()"></button></div>
  <div class="modal-body">
    @if (!exportTrialBalanceSaved) {
    <div>
      <div class="d-flex justify-content-between mb-3"><span style="font-weight:700">As of: 28 Jun 2025</span><span class="pm-badge pm-badge-info">Consolidated</span></div>
      <div class="table-responsive" style="max-height:300px;overflow-y:auto"><table class="pm-table"><thead><tr><th>GL Code</th><th>Account Name</th><th>Debit (KES)</th><th>Credit (KES)</th></tr></thead><tbody><tr><td>1001</td><td>PayMo Wallet</td><td>12,450,800</td><td>-</td></tr><tr><td>1100</td><td>Accounts Receivable</td><td>4,200,000</td><td>-</td></tr><tr><td>2001</td><td>Accounts Payable</td><td>-</td><td>2,150,000</td></tr><tr><td>3001</td><td>Retained Earnings</td><td>-</td><td>8,500,800</td></tr><tr><td>4001</td><td>Sales Revenue</td><td>-</td><td>48,200,000</td></tr><tr><td>5001</td><td>Payroll Expenses</td><td>18,200,000</td><td>-</td></tr><tr><td>5010</td><td>COGS</td><td>21,000,000</td><td>-</td></tr><tr style="font-weight:700"><td></td><td>TOTAL</td><td>55,850,800</td><td>55,850,800</td></tr></tbody></table></div>
    </div>
    @if (exportTrialBalanceSaved) {
    <div class="pm-receipt"><div class="receipt-icon"><i class="bi bi-check-lg"></i></div><h5 style="font-weight:700;color:var(--pm-accent)">Success</h5><p style="font-size:13px;color:var(--pm-ink-soft)">Trial Balance downloaded successfully.</p><div class="d-flex justify-content-center mt-3" style="gap:8px"><button class="pm-btn pm-btn-sm" (click)="resetAllModals()"><i class="bi bi-arrow-clockwise"></i> Refresh</button></div></div>
    }
  </div>
  <div class="modal-footer"><button class="pm-btn">Close</button><button class="pm-btn pm-btn-primary"><i class="bi bi-download"></i> Download Excel</button><div (click)="closeModal(); processAction('exportTrialBalanceModal','Trial Balance downloaded successfully.','')">
</div>
</div>

<!-- 20. Report Delivery Settings -->
@if (activeModal === 'reportDeliverySettingsModal') {
<div class="modal-dialog modal-dialog-centered" style="position:relative">
<div class="modal-content">
  <div class="modal-header"><h5 class="modal-title"><i class="bi bi-sliders text-primary me-2"></i>Automated Delivery Settings</h5><button class="btn-close" (click)="closeModal()"></button></div>
  <div class="modal-body">
    @if (!reportDeliverySettingsSaved) {
    <div>
      <div class="mb-3"><label class="pm-form-label">Delivery Channel</label><select class="pm-form-control"><option>Email (Secure Attachment)</option><option>SFTP Server</option><option>Webhook (JSON Payload)</option></select></div>
      <div class="mb-3"><label class="pm-form-label">SFTP Host (If applicable)</label><input class="pm-form-control" placeholder="sftp.company.com"></div>
      <div class="mb-3"><label class="pm-form-label">SFTP Port</label><input class="pm-form-control" placeholder="22"></div>
      <div class="mb-3"><label class="pm-form-label">Security</label><div class="form-check"><input class="form-check-input" type="checkbox" checked><label class="form-check-label">Password protect PDFs (using KRA PIN)</label></div><div class="form-check"><input class="form-check-input" type="checkbox" checked><label class="form-check-label">PGP Encrypt CSV/Excel files</label></div></div>
    </div>
    @if (reportDeliverySettingsSaved) {
    <div class="pm-receipt"><div class="receipt-icon"><i class="bi bi-check-lg"></i></div><h5 style="font-weight:700;color:var(--pm-accent)">Success</h5><p style="font-size:13px;color:var(--pm-ink-soft)">Delivery configuration saved.</p><div class="d-flex justify-content-center mt-3" style="gap:8px"><button class="pm-btn pm-btn-sm" (click)="resetAllModals()"><i class="bi bi-arrow-clockwise"></i> Refresh</button></div></div>
    }
  </div>
  <div class="modal-footer"><button class="pm-btn">Cancel</button><button class="pm-btn pm-btn-primary">Save Settings</button><div (click)="closeModal(); processAction('reportDeliverySettingsModal','Delivery configuration saved.','')">
</div>
</div>

<!-- 21. Dispute Audit -->
@if (activeModal === 'disputeAuditModal') {
<div class="modal-dialog modal-dialog-centered" style="position:relative">
<div class="modal-content">
  <div class="modal-header"><h5 class="modal-title"><i class="bi bi-eye text-primary me-2"></i>Audit Log: Invoice Voided</h5><button class="btn-close" (click)="closeModal()"></button></div>
  <div class="modal-body">
    <div class="p-3 rounded mb-3" style="background:var(--pm-warning-soft);font-size:13px"><div class="d-flex justify-content-between mb-2"><span class="text-muted">User</span><strong>James K. (Sales)</strong></div><div class="d-flex justify-content-between mb-2"><span class="text-muted">Target</span><strong>Invoice #INV-2041</strong></div><div class="d-flex justify-content-between mb-2"><span class="text-muted">Action</span><strong>Status changed to VOID</strong></div><div class="d-flex justify-content-between"><span class="text-muted">Reason Provided</span><strong>"Duplicate generated by error"</strong></div></div>
    <div class="p-3 rounded" style="background:var(--pm-surface-2);font-size:12px">No financial impact recorded as payment had not been reconciled against this invoice. e-TIMS credit note auto-filed.</div>
  </div>
  <div class="modal-footer"><button class="pm-btn" (click)="closeModal()">Close</button></div>
</div>
</div>

<!-- 22. Financial Health Score -->
@if (activeModal === 'financialHealthScoreModal') {
<div class="modal-dialog modal-dialog-centered" style="position:relative">
<div class="modal-content">
  <div class="modal-header"><h5 class="modal-title"><i class="bi bi-heart-pulse text-accent me-2" style="color:var(--pm-accent)"></i>Business Financial Health</h5><button class="btn-close" (click)="closeModal()"></button></div>
  <div class="modal-body">
    <div class="text-center mb-4"><div style="font-size:48px;font-weight:800;color:var(--pm-accent);font-family:var(--pm-font-display);line-height:1">Excellent</div><div style="font-size:12px;font-weight:700;color:var(--pm-muted);text-transform:uppercase">OVERALL RATING</div></div>
    <div class="table-responsive"><table class="pm-table"><thead><tr><th>Indicator</th><th>Status</th><th>Score</th></tr></thead><tbody><tr><td>Liquidity Ratio (Current)</td><td>2.4x (Very Healthy)</td><td><span class="pm-badge pm-badge-success">Strong</span></td></tr><tr><td>Days Sales Outstanding</td><td>26 Days</td><td><span class="pm-badge pm-badge-success">Strong</span></td></tr><tr><td>Expense to Revenue Ratio</td><td>43% (Within target)</td><td><span class="pm-badge pm-badge-success">Strong</span></td></tr><tr><td>Revenue Concentration</td><td>Top client is 26%</td><td><span class="pm-badge pm-badge-warning">Fair</span></td></tr></tbody></table></div>
    <div class="p-3 rounded mt-3" style="background:var(--pm-surface-2);font-size:12px"><i class="bi bi-stars text-purple me-1" style="color:var(--pm-purple)"></i> AI Suggestion: Your liquidity is strong enough to place KES 5M in a 30-day Money Market Fund to generate yield without impacting operational cash flow.</div>
  </div>
  <div class="modal-footer"><button class="pm-btn" (click)="closeModal()">Close</button></div>
</div>
</div>

  </div>
}
}
}
}
}
}
}
}
}
}
}
}
}
}
}
}
}
}
}
}
}
}
}
}
}
}
}
}
}
}
}
}
}
}
}
}
}
}
}
