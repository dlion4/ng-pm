  <div class="modal-body">
    <div class="d-flex justify-content-between mb-3"><span style="font-weight:700;font-size:16px">June 2025</span><span class="pm-badge pm-badge-info">Consolidated View</span></div>
    <div class="p-3 border rounded mb-3"><div class="d-flex justify-content-between mb-2"><span class="text-muted">Total Gross Revenue</span><strong>KES 8,240,000</strong></div><div class="d-flex justify-content-between mb-2"><span class="text-muted">Cost of Goods Sold (COGS)</span><strong>- KES 2,100,000</strong></div><hr class="pm-divider"><div class="d-flex justify-content-between"><span style="font-weight:700">Gross Profit</span><strong style="color:var(--pm-accent)">KES 6,140,000 (74%)</strong></div></div>
    <div class="p-3 border rounded mb-3"><div class="d-flex justify-content-between mb-2"><span class="text-muted">Payroll &amp; Employee Benefits</span><strong>- KES 3,250,000</strong></div><div class="d-flex justify-content-between mb-2"><span class="text-muted">Marketing &amp; Sales</span><strong>- KES 450,000</strong></div><div class="d-flex justify-content-between mb-2"><span class="text-muted">Software &amp; Subscriptions</span><strong>- KES 280,000</strong></div><div class="d-flex justify-content-between mb-2"><span class="text-muted">Rent &amp; Utilities</span><strong>- KES 320,000</strong></div><hr class="pm-divider"><div class="d-flex justify-content-between"><span style="font-weight:700">Total Opex</span><strong>KES 4,300,000</strong></div></div>
    <div class="p-3 rounded" style="background:var(--pm-surface-2)"><div class="d-flex justify-content-between"><span style="font-weight:700;font-size:16px">Net Operating Profit</span><strong style="font-size:18px;color:var(--pm-primary)">KES 1,840,000 (22%)</strong></div></div>
  </div>
  <div class="modal-footer"><button class="pm-btn">Close</button><button class="pm-btn pm-btn-primary">Full P&amp;L Report</button><div (click)="closeModal(); closeModal(); openModal('downloadStatementModal')">
</div>
</div>

<!-- 9. Tax Readiness -->
@if (activeModal === 'taxReadinessModal') {
<div class="modal-dialog modal-dialog-centered" style="position:relative">
<div class="modal-content">
  <div class="modal-header"><h5 class="modal-title"><i class="bi bi-shield-check text-success me-2"></i>Tax &amp; Compliance Readiness</h5><button class="btn-close" (click)="closeModal()"></button></div>
  <div class="modal-body">
    <div class="text-center mb-4"><div style="font-size:48px;font-weight:800;color:var(--pm-accent);font-family:var(--pm-font-display);line-height:1">98%</div><div style="font-size:12px;font-weight:700;color:var(--pm-muted);text-transform:uppercase">OVERALL COMPLIANCE SCORE</div></div>
    <div class="status-row"><div><strong>KRA VAT (June)</strong><div style="font-size:11px;color:var(--pm-muted)">Extract generated, ready for iTax</div></div><span class="pm-badge pm-badge-success">Ready</span></div>
    <div class="status-row"><div><strong>e-TIMS Integration</strong><div style="font-size:11px;color:var(--pm-muted)">API connection healthy, 100% matched</div></div><span class="pm-badge pm-badge-success">Active</span></div>
    <div class="status-row"><div><strong>PAYE / NSSF / SHIF</strong><div style="font-size:11px;color:var(--pm-muted)">Pending June payroll execution</div></div><span class="pm-badge pm-badge-warning">Pending</span></div>
    <div class="status-row"><div><strong>CR12 Annual Return</strong><div style="font-size:11px;color:var(--pm-muted)">Due August 2025</div></div><span class="pm-badge pm-badge-info">On Track</span></div>
  </div>
  <div class="modal-footer"><button class="pm-btn" (click)="closeModal()">Close</button></div>
</div>
</div>

<!-- 10. eTims Reconciliation -->
@if (activeModal === 'eTimsReconciliationModal') {
<div class="modal-dialog modal-lg modal-dialog-centered" style="position:relative">
<div class="modal-content">
  <div class="modal-header"><h5 class="modal-title"><i class="bi bi-receipt text-secondary me-2"></i>e-TIMS Invoice Reconciliation</h5><button class="btn-close" (click)="closeModal()"></button></div>
  <div class="modal-body">
    @if (!eTimsReconciliationSaved) {
    <div>
      <div class="row g-3 mb-3">
        <div class="col-md-4"><div class="p-3 border rounded text-center"><div style="font-size:20px;font-weight:700">142</div><div style="font-size:11px;color:var(--pm-muted)">INVOICES (JUN)</div></div></div>
        <div class="col-md-4"><div class="p-3 border rounded text-center border-success bg-success bg-opacity-10"><div style="font-size:20px;font-weight:700;color:#047857">142</div><div style="font-size:11px;color:#065F46">SYNCED TO KRA</div></div></div>
        <div class="col-md-4"><div class="p-3 border rounded text-center"><div style="font-size:20px;font-weight:700">0</div><div style="font-size:11px;color:var(--pm-muted)">EXCEPTIONS</div></div></div>
      </div>
      <div class="table-responsive" style="max-height:250px;overflow-y:auto"><table class="pm-table"><thead><tr><th>Invoice #</th><th>Date</th><th>Amount</th><th>e-TIMS CU Number</th><th>Status</th></tr></thead><tbody><tr><td>INV-2045</td><td>28 Jun 2025</td><td>KES 45,000</td><td><code style="font-size:11px">KRA-CU-99812A</code></td><td><span class="pm-badge pm-badge-success">Synced</span></td></tr><tr><td>INV-2044</td><td>27 Jun 2025</td><td>KES 120,500</td><td><code style="font-size:11px">KRA-CU-99811B</code></td><td><span class="pm-badge pm-badge-success">Synced</span></td></tr><tr><td>INV-2043</td><td>26 Jun 2025</td><td>KES 15,000</td><td><code style="font-size:11px">KRA-CU-99810C</code></td><td><span class="pm-badge pm-badge-success">Synced</span></td></tr></tbody></table></div>
    </div>
    @if (eTimsReconciliationSaved) {
    <div class="pm-receipt"><div class="receipt-icon"><i class="bi bi-check-lg"></i></div><h5 style="font-weight:700;color:var(--pm-accent)">Success</h5><p style="font-size:13px;color:var(--pm-ink-soft)">Manual sync triggered. All invoices up to date.</p><div class="d-flex justify-content-center mt-3" style="gap:8px"><button class="pm-btn pm-btn-sm" (click)="resetAllModals()"><i class="bi bi-arrow-clockwise"></i> Refresh</button></div></div>
    }
  </div>
  <div class="modal-footer"><button class="pm-btn">Close</button><button class="pm-btn pm-btn-primary">Force Sync Now</button><div (click)="closeModal(); processAction('eTimsReconciliationModal', 'Manual sync triggered. All invoices up to date.', '')">
</div>
</div>

<!-- 11. Branch Performance -->
@if (activeModal === 'branchPerformanceModal') {
<div class="modal-dialog modal-lg modal-dialog-centered" style="position:relative">
<div class="modal-content">
