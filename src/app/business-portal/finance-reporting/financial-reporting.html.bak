      <div class="col-md-6"><div class="p-3 border rounded"><div style="font-size:11px;color:var(--pm-muted)">FASTEST PAYING</div><div style="font-size:18px;font-weight:700;color:var(--pm-accent)">TechFlow Solutions</div><div style="font-size:12px;color:var(--pm-muted)">Avg. 4 Days to Pay</div></div></div>
