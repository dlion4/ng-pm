<!-- 8. Schedule Disbursement Modal -->
@if (activeModal === 'scheduleDisbursementModal') {
  <div class="modal-backdrop show"></div>
  <div class="modal d-block" tabindex="-1" (click)="closeModal()">
    <div class="modal-dialog modal-dialog-centered" (click)="$event.stopPropagation()">
      <div class="modal-content">
        <div class="modal-header"><h5 class="modal-title"><i class="bi bi-calendar-check text-warning me-2"></i>Schedule Future Batch</h5><button class="btn-close" (click)="closeModal()"></button></div>
        <div class="modal-body">
          @if (!scheduleDisbursementSaved) {
            <div class="mb-3"><label class="pm-form-label">Select Draft/Template Batch</label><select class="pm-form-control"><option>Monthly Field Allowances (210)</option><option>June Contractor Payout (Draft)</option></select></div>
            <div class="mb-3"><label class="pm-form-label">Execution Strategy</label><select class="pm-form-control"><option>Single bulk run</option><option>Drip feed (Staggered over time)</option><option>Recurring (e.g., Weekly)</option></select></div>
            <div class="row g-3 mb-3"><div class="col-6"><label class="pm-form-label">Start Date</label><input type="date" class="pm-form-control" value="2025-07-01"></div><div class="col-6"><label class="pm-form-label">Time</label><input type="time" class="pm-form-control" value="08:00"></div></div>
            <div class="p-3 rounded" style="background:var(--pm-surface-2);font-size:12px"><i class="bi bi-info-circle me-1"></i> Float will be reserved at the time of checker approval. If float is insufficient on execution day, the batch will pause.</div>
          } @else {
            <div class="pm-receipt">
              <div class="receipt-icon"><i class="bi bi-check-lg"></i></div>
              <h5 style="font-weight:700;color:var(--pm-accent)">Batch scheduled successfully!</h5>
            </div>
