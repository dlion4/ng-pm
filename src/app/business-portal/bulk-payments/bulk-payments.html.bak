            <div class="mb-3"><label class="pm-form-label">Top-up Amount (KES)</label><input class="pm-form-control" placeholder="e.g. 5,000,000"></div>
            <div class="mb-3"><label class="pm-form-label">Funding Source</label>
              <div class="p-3 border rounded mb-2 d-flex align-items-center gap-3" style="border-color:var(--pm-primary)!important;background:rgba(79,70,229,.04)" (click)="selectRadioCard($event)"><input type="radio" checked name="fpay"> <i class="bi bi-bank" style="font-size:20px;color:var(--pm-info)"></i><div><strong>Business Bank Account</strong><div style="font-size:11px;color:var(--pm-muted)">Equity ***4521 · RTGS/EFT (T+1)</div></div></div>
              <div class="p-3 border rounded mb-2 d-flex align-items-center gap-3" (click)="selectRadioCard($event)"><input type="radio" name="fpay"> <i class="bi bi-phone" style="font-size:20px;color:var(--pm-accent)"></i><div><strong>C2B Collections Till</strong><div style="font-size:11px;color:var(--pm-muted)">Transfer from inbound collections (Instant)</div></div></div>
            </div>
