      <div class="modal-content">
        <div class="modal-header"><h5 class="modal-title"><i class="bi bi-arrow-clockwise me-2"></i>Retry Transfer</h5><button class="btn-close" (click)="closeModal()"></button></div>
        <div class="modal-body">
          @if (!retryTransferSaved) {
            <div class="mb-3"><label class="pm-form-label">Beneficiary Name</label><input class="pm-form-control" value="Alice Kemboi" disabled></div>
            <div class="mb-3"><label class="pm-form-label">Amount</label><input class="pm-form-control" value="4500" disabled></div>
            <div class="p-3 rounded mb-3" style="background:var(--pm-danger-soft);font-size:12px"><strong>Error:</strong> The destination phone number is not registered on M-Pesa.</div>
            <div class="mb-3"><label class="pm-form-label">Update Phone / Account Number</label><input class="pm-form-control" value="0799 000 111"></div>
            <div class="mb-3"><label class="pm-form-label">Action</label><select class="pm-form-control"><option>Update and retry immediately</option><option>Cancel transfer and return funds</option></select></div>
          } @else {
