        <div class="modal-footer">
          @if (!retryTransferSaved) {
            <button class="pm-btn" (click)="closeModal()">Cancel</button>
            <button class="pm-btn pm-btn-primary" (click)="processAction('retryTransferModal','Transfer queued for retry.','')">Execute Action</button>
          } @else {
            <button class="pm-btn pm-btn-primary" (click)="closeModal()">Close</button>
