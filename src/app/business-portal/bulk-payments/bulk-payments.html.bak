          } @else {
            <button class="pm-btn pm-btn-primary" (click)="closeModal()">Close</button>
          }
        </div>
      </div>
    </div>
  </div>

<!-- 9. Export Analytics Modal -->
@if (activeModal === 'exportAnalyticsModal') {
  <div class="modal-backdrop show"></div>
  <div class="modal d-block" tabindex="-1" (click)="closeModal()">
    <div class="modal-dialog modal-dialog-centered" (click)="$event.stopPropagation()">
      <div class="modal-content">
        <div class="modal-header"><h5 class="modal-title"><i class="bi bi-download me-2"></i>Export Disbursement Reports</h5><button class="btn-close" (click)="closeModal()"></button></div>
        <div class="modal-body">
          @if (!exportAnalyticsSaved) {
            <div class="mb-3"><label class="pm-form-label">Report Type</label><select class="pm-form-control"><option>Comprehensive Transaction Ledger</option><option>Failed & Reconciled Payments</option><option>Maker-Checker Audit Log</option><option>Beneficiary Payout Summary</option></select></div>
            <div class="row g-3 mb-3"><div class="col-6"><label class="pm-form-label">From Date</label><input type="date" class="pm-form-control" value="2025-06-01"></div><div class="col-6"><label class="pm-form-label">To Date</label><input type="date" class="pm-form-control" value="2025-06-27"></div></div>
            <div class="mb-3"><label class="pm-form-label">Export Format</label><select class="pm-form-control"><option>CSV Spreadsheet</option><option>Excel (.xlsx)</option><option>PDF Summary</option></select></div>
            <div class="form-check"><input class="form-check-input" type="checkbox"><label class="form-check-label" style="font-size:13px">Include full beneficiary KYC data</label></div>
          } @else {
            <div class="pm-receipt">
              <div class="receipt-icon"><i class="bi bi-check-lg"></i></div>
              <h5 style="font-weight:700;color:var(--pm-accent)">Report generated and downloading...</h5>
            </div>
        </div>
        <div class="modal-footer">
          @if (!exportAnalyticsSaved) {
            <button class="pm-btn" (click)="closeModal()">Cancel</button>
            <button class="pm-btn pm-btn-primary" (click)="processAction('exportAnalyticsModal','Report generated and downloading...','')">Generate Report</button>
          } @else {
            <button class="pm-btn pm-btn-primary" (click)="closeModal()">Close</button>
          }
        </div>
      </div>
    </div>
  </div>

<!-- 10. Batch Details Modal -->
@if (activeModal === 'batchDetailsModal') {
  <div class="modal-backdrop show"></div>
  <div class="modal d-block" tabindex="-1" (click)="closeModal()">
    <div class="modal-dialog modal-lg modal-dialog-centered" (click)="$event.stopPropagation()">
      <div class="modal-content">
        <div class="modal-header"><h5 class="modal-title"><i class="bi bi-file-earmark-text me-2"></i>Batch Execution Details</h5><button class="btn-close" (click)="closeModal()"></button></div>
        <div class="modal-body">
          <div class="row g-3 mb-3">
            <div class="col-md-4"><div class="p-3 rounded text-center" style="background:var(--pm-surface-2)"><div style="font-size:11px;color:var(--pm-muted);font-weight:700">BATCH ID</div><div style="font-size:16px;font-weight:700">BTH-9920</div></div></div>
            <div class="col-md-4"><div class="p-3 rounded text-center" style="background:var(--pm-surface-2)"><div style="font-size:11px;color:var(--pm-muted);font-weight:700">VALUE</div><div style="font-size:16px;font-weight:700;color:var(--pm-primary)">KES 4.5M</div></div></div>
            <div class="col-md-4"><div class="p-3 rounded text-center" style="background:var(--pm-accent-soft)"><div style="font-size:11px;color:#047857;font-weight:700">STATUS</div><div style="font-size:16px;font-weight:700;color:var(--pm-accent)">100% Executed</div></div></div>
          </div>
          <div class="d-flex justify-content-between text-muted" style="font-size:12px;margin-bottom:8px"><span>Successful: 118</span><span>Failed: 0</span></div>
          <div class="pm-progress mb-3"><div class="pm-progress-bar" style="width:100%;background:var(--pm-accent)"></div></div>
          <h6 style="font-weight:700">Audit Trail</h6>
          <div class="table-responsive"><table class="pm-table"><tbody>
            @for (at of auditTrail; track at.id) {
              <tr><td style="width:120px">{{ at.timestamp }}</td><td><span [class]="at.badgeClass">{{ at.badge }}</span></td><td>{{ at.description }}</td></tr>
            }
          </tbody></table></div>
        </div>
        <div class="modal-footer"><button class="pm-btn" (click)="closeModal(); openModal('bulkReceiptModal')">CloseClose</button><button class="pm-btn pm-btn-primary"><i class="bi bi-receipt"></i> Get Receipt</button></div>
      </div>
    </div>
  </div>

<!-- 11. NGO Program Modal -->
@if (activeModal === 'ngoProgramModal') {
  <div class="modal-backdrop show"></div>
  <div class="modal d-block" tabindex="-1" (click)="closeModal()">
    <div class="modal-dialog modal-lg modal-dialog-centered" (click)="$event.stopPropagation()">
      <div class="modal-content">
        <div class="modal-header"><h5 class="modal-title"><i class="bi bi-globe-africa text-info me-2"></i>Create Social Protection / Relief Program</h5><button class="btn-close" (click)="closeModal()"></button></div>
        <div class="modal-body">
          @if (!ngoProgramSaved) {
            <div class="row g-3">
              <div class="col-md-6"><label class="pm-form-label">Program Name</label><input class="pm-form-control" placeholder="e.g. Drought Relief Phase 1"></div>
              <div class="col-md-6"><label class="pm-form-label">Program Type</label><select class="pm-form-control"><option>Cash Transfer (G2P/NGO)</option><option>e-Voucher (Subsidies)</option><option>Emergency Relief</option></select></div>
              <div class="col-md-6"><label class="pm-form-label">Total Funding Allocated (KES)</label><input class="pm-form-control" placeholder="e.g. 50,000,000"></div>
              <div class="col-md-6"><label class="pm-form-label">Target Beneficiary Count</label><input class="pm-form-control" placeholder="e.g. 10,000"></div>
              <div class="col-12"><label class="pm-form-label">Compliance & Security Requirements</label>
                <div class="form-check mb-1"><input class="form-check-input" type="checkbox" checked><label class="form-check-label" style="font-size:13px">Strict KYC matching (Name must match National ID)</label></div>
                <div class="form-check mb-1"><input class="form-check-input" type="checkbox"><label class="form-check-label" style="font-size:13px">Biometric pre-verification required</label></div>
                <div class="form-check"><input class="form-check-input" type="checkbox" checked><label class="form-check-label" style="font-size:13px">Post-disbursement feedback collection via SMS/USSD</label></div>
              </div>
            </div>
          } @else {
            <div class="pm-receipt">
              <div class="receipt-icon"><i class="bi bi-check-lg"></i></div>
              <h5 style="font-weight:700;color:var(--pm-accent)">Program created. Funding vault initialized.</h5>
            </div>
        </div>
        <div class="modal-footer">
          @if (!ngoProgramSaved) {
            <button class="pm-btn" (click)="closeModal()">Cancel</button>
            <button class="pm-btn pm-btn-primary" (click)="processAction('ngoProgramModal','Program created. Funding vault initialized.','')">Create Program</button>
          } @else {
            <button class="pm-btn pm-btn-primary" (click)="closeModal()">Close</button>
          }
        </div>
      </div>
    </div>
  </div>

<!-- 12. Beneficiary Feedback Modal -->
@if (activeModal === 'beneficiaryFeedbackModal') {
  <div class="modal-backdrop show"></div>
  <div class="modal d-block" tabindex="-1" (click)="closeModal()">
    <div class="modal-dialog modal-dialog-centered" (click)="$event.stopPropagation()">
      <div class="modal-content">
        <div class="modal-header"><h5 class="modal-title"><i class="bi bi-chat-text me-2"></i>Post-Disbursement Feedback</h5><button class="btn-close" (click)="closeModal()"></button></div>
        <div class="modal-body">
          <p style="font-size:13px;color:var(--pm-ink-soft)">Monitor SMS/USSD survey responses from the "Flood Relief" campaign.</p>
          <div class="row g-3 mb-3">
            <div class="col-6"><div class="p-3 rounded text-center" style="background:var(--pm-surface-2)"><div style="font-size:11px;font-weight:700">SURVEY SENT</div><div style="font-size:20px;font-weight:700;color:var(--pm-primary)">1,200</div></div></div>
            <div class="col-6"><div class="p-3 rounded text-center" style="background:var(--pm-surface-2)"><div style="font-size:11px;font-weight:700">RESPONSES</div><div style="font-size:20px;font-weight:700;color:var(--pm-accent)">842 <span style="font-size:12px;color:var(--pm-muted);font-weight:400">(70%)</span></div></div></div>
          </div>
          <div class="mb-3">
            <div class="d-flex justify-content-between mb-1" style="font-size:12px"><span>"Did you receive the funds?" (YES)</span><span>98%</span></div>
            <div class="pm-progress"><div class="pm-progress-bar" style="width:98%;background:var(--pm-success)"></div></div>
          </div>
          <div class="mb-3">
            <div class="d-flex justify-content-between mb-1" style="font-size:12px"><span>"Did you pay a bribe/fee?" (NO)</span><span>99%</span></div>
            <div class="pm-progress"><div class="pm-progress-bar" style="width:99%;background:var(--pm-info)"></div></div>
          </div>
          <div class="p-3 rounded" style="background:var(--pm-danger-soft);font-size:12px"><i class="bi bi-exclamation-triangle text-danger me-1"></i> 3 beneficiaries reported issues. <a href="#">View exceptions report</a></div>
        </div>
        <div class="modal-footer"><button class="pm-btn" (click)="closeModal()">Close</button><button class="pm-btn pm-btn-primary" (click)="closeModal(); openModal('exportAnalyticsModal')">Export Data</button></div>
      </div>
    </div>
  </div>

<!-- 13. Approval Workflow Modal -->
@if (activeModal === 'approvalWorkflowModal') {
  <div class="modal-backdrop show"></div>
  <div class="modal d-block" tabindex="-1" (click)="closeModal()">
    <div class="modal-dialog modal-dialog-centered" (click)="$event.stopPropagation()">
      <div class="modal-content">
        <div class="modal-header"><h5 class="modal-title"><i class="bi bi-diagram-3 me-2"></i>Maker-Checker Settings</h5><button class="btn-close" (click)="closeModal()"></button></div>
        <div class="modal-body">
          @if (!approvalWorkflowSaved) {
            <div class="mb-3"><label class="pm-form-label">Tiers & Limits</label>
              @for (tier of workflowTiers; track tier.id) {
                <div class="p-2 border rounded mb-2 d-flex justify-content-between align-items-center" style="font-size:13px"><div><strong>{{ tier.name }}</strong><br><span class="text-muted">{{ tier.description }}</span></div><button class="pm-btn pm-btn-sm">Edit</button></div>
              }
            </div>
            <div class="form-check mb-2"><input class="form-check-input" type="checkbox" checked><label class="form-check-label" style="font-size:13px">Require OTP/MFA for all approvals</label></div>
            <div class="form-check"><input class="form-check-input" type="checkbox" checked><label class="form-check-label" style="font-size:13px">Auto-reject unapproved batches after 48 hours</label></div>
          } @else {
            <div class="pm-receipt">
              <div class="receipt-icon"><i class="bi bi-check-lg"></i></div>
              <h5 style="font-weight:700;color:var(--pm-accent)">Workflow rules updated successfully.</h5>
            </div>
        </div>
        <div class="modal-footer">
          @if (!approvalWorkflowSaved) {
            <button class="pm-btn" (click)="closeModal()">Cancel</button>
            <button class="pm-btn pm-btn-primary" (click)="processAction('approvalWorkflowModal','Workflow rules updated successfully.','')">Save Settings</button>
          } @else {
            <button class="pm-btn pm-btn-primary" (click)="closeModal()">Close</button>
          }
        </div>
      </div>
    </div>
  </div>

<!-- 14. Disbursement Settings Modal -->
@if (activeModal === 'disbursementSettingsModal') {
  <div class="modal-backdrop show"></div>
  <div class="modal d-block" tabindex="-1" (click)="closeModal()">
    <div class="modal-dialog modal-dialog-centered" (click)="$event.stopPropagation()">
      <div class="modal-content">
        <div class="modal-header"><h5 class="modal-title"><i class="bi bi-gear me-2"></i>Disbursement Engine Settings</h5><button class="btn-close" (click)="closeModal()"></button></div>
        <div class="modal-body">
          @if (!disbursementSettingsSaved) {
            <div class="mb-3"><label class="pm-form-label">Auto-Routing (Smart Path)</label><select class="pm-form-control"><option>Optimize for Cost (PesaLink where possible)</option><option>Optimize for Speed (B2C instant)</option><option>Strict mapping (Do not override file)</option></select></div>
            <div class="mb-3"><label class="pm-form-label">Daily B2C Limit Warning</label><input class="pm-form-control" type="number" value="45000000" placeholder="Alert when reaching X limit"></div>
            <div class="mb-3"><label class="pm-form-label">Duplicate Detection Window</label><select class="pm-form-control"><option>Check last 24 hours</option><option>Check last 7 days</option><option>Check current batch only</option></select></div>
            <div class="form-check"><input class="form-check-input" type="checkbox" checked><label class="form-check-label" style="font-size:13px">Automatically retry 'Network Timeout' failures</label></div>
          } @else {
            <div class="pm-receipt">
              <div class="receipt-icon"><i class="bi bi-check-lg"></i></div>
              <h5 style="font-weight:700;color:var(--pm-accent)">Engine settings updated!</h5>
            </div>
        </div>
        <div class="modal-footer">
          @if (!disbursementSettingsSaved) {
            <button class="pm-btn" (click)="closeModal()">Cancel</button>
            <button class="pm-btn pm-btn-primary" (click)="processAction('disbursementSettingsModal','Engine settings updated!','')">Save Settings</button>
          } @else {
            <button class="pm-btn pm-btn-primary" (click)="closeModal()">Close</button>
          }
        </div>
      </div>
    </div>
  </div>

<!-- 15. API Integration Modal -->
@if (activeModal === 'apiIntegrationModal') {
  <div class="modal-backdrop show"></div>
  <div class="modal d-block" tabindex="-1" (click)="closeModal()">
    <div class="modal-dialog modal-lg modal-dialog-centered" (click)="$event.stopPropagation()">
      <div class="modal-content">
        <div class="modal-header"><h5 class="modal-title"><i class="bi bi-code-slash text-danger me-2"></i>API Keys & Webhooks</h5><button class="btn-close" (click)="closeModal()"></button></div>
        <div class="modal-body">
          <div class="pm-tab-pills mb-3">
            <button class="pm-tab-pill" [class.active]="activeTabs['apiTab'] === 'keys'" (click)="switchTab('apiTab','keys',$event)">API Keys</button>
            <button class="pm-tab-pill" [class.active]="activeTabs['apiTab'] === 'webhooks'" (click)="switchTab('apiTab','webhooks',$event)">Webhooks</button>
            <button class="pm-tab-pill" [class.active]="activeTabs['apiTab'] === 'docs'" (click)="switchTab('apiTab','docs',$event)">Docs</button>
          </div>
          @if (activeTabs['apiTab'] === 'keys') {
            <div class="p-3 border rounded mb-3">
              <div class="d-flex justify-content-between mb-2"><strong style="font-size:13px">Live Production Key</strong><span class="pm-badge pm-badge-success">Active</span></div>
              <div class="d-flex gap-2"><input class="pm-form-control" value="pk_live_8f7d6a5...2b1c" type="password" disabled><button class="pm-btn pm-btn-sm"><i class="bi bi-clipboard"></i></button></div>
              <div style="font-size:11px;color:var(--pm-muted);margin-top:8px">Last used: 15 minutes ago</div>
            </div>
            <button class="pm-btn pm-btn-sm pm-btn-danger"><i class="bi bi-arrow-clockwise"></i> Roll Key</button>
          } @else if (activeTabs['apiTab'] === 'webhooks') {
            <div class="mb-3"><label class="pm-form-label">Disbursement Callback URL (B2C Result)</label><input class="pm-form-control" value="https://api.safiri.com/webhooks/paymo/b2c"></div>
            <div class="mb-3"><label class="pm-form-label">Secret Hash</label><input class="pm-form-control" value="whsec_991823719" disabled></div>
            <button class="pm-btn pm-btn-sm pm-btn-primary">Update URL</button>
          } @else if (activeTabs['apiTab'] === 'docs') {
            <p style="font-size:13px;color:var(--pm-ink-soft)">Integrate bulk disbursements directly from your ERP, HRMS, or custom software using the PayMo API.</p>
            <button class="pm-btn pm-btn-sm pm-btn-outline"><i class="bi bi-box-arrow-up-right"></i> Open Developer Portal</button>
          }
        </div>
        <div class="modal-footer"><button class="pm-btn" (click)="closeModal()">Close</button></div>
      </div>
    </div>
  </div>

<!-- 16. Audit Log Modal -->
@if (activeModal === 'auditLogModal') {
  <div class="modal-backdrop show"></div>
  <div class="modal d-block" tabindex="-1" (click)="closeModal()">
    <div class="modal-dialog modal-xl modal-dialog-centered" (click)="$event.stopPropagation()">
      <div class="modal-content">
        <div class="modal-header"><h5 class="modal-title"><i class="bi bi-journal-text me-2"></i>Security & Action Audit Log</h5><button class="btn-close" (click)="closeModal()"></button></div>
        <div class="modal-body">
          <div class="d-flex justify-content-between align-items-center mb-3">
            <input class="pm-form-control" style="max-width:300px" placeholder="Search logs...">
            <select class="pm-form-control" style="width:auto"><option>All Actions</option><option>Approvals</option><option>File Uploads</option><option>Settings Change</option></select>
          </div>
          <div class="table-responsive" style="max-height:400px;overflow-y:auto"><table class="pm-table">
            <thead><tr><th>Timestamp</th><th>User</th><th>IP Address</th><th>Action Event</th><th>Status</th></tr></thead>
            <tbody>
              @for (log of auditLogs; track log.id) {
                <tr>
                  <td>{{ log.timestamp }}</td>
                  <td>{{ log.user }}</td>
                  <td>{{ log.ip }}</td>
                  <td>{{ log.action }}</td>
                  <td><span [class]="log.statusBadgeClass">{{ log.statusBadge }}</span></td>
                </tr>
              }
            </tbody></table></div>
        </div>
        <div class="modal-footer"><button class="pm-btn" (click)="closeModal()">Close</button><button class="pm-btn pm-btn-primary" (click)="closeModal(); openModal('exportAnalyticsModal')">Export Logs</button></div>
      </div>
    </div>
  </div>

<!-- 17. Subsidy Voucher Modal -->
@if (activeModal === 'subsidyVoucherModal') {
  <div class="modal-backdrop show"></div>
  <div class="modal d-block" tabindex="-1" (click)="closeModal()">
    <div class="modal-dialog modal-lg modal-dialog-centered" (click)="$event.stopPropagation()">
      <div class="modal-content">
        <div class="modal-header"><h5 class="modal-title"><i class="bi bi-tree text-warning me-2"></i>Agricultural e-Voucher Management</h5><button class="btn-close" (click)="closeModal()"></button></div>
        <div class="modal-body">
          <div class="row g-3 mb-3">
            <div class="col-md-4"><div class="p-3 rounded text-center" style="background:var(--pm-surface-2)"><div style="font-size:11px;font-weight:700">TOTAL ISSUED</div><div style="font-size:20px;font-weight:700;color:var(--pm-primary)">1,500</div></div></div>
            <div class="col-md-4"><div class="p-3 rounded text-center" style="background:var(--pm-accent-soft)"><div style="font-size:11px;color:#047857;font-weight:700">REDEEMED</div><div style="font-size:20px;font-weight:700;color:var(--pm-accent)">840</div></div></div>
            <div class="col-md-4"><div class="p-3 rounded text-center" style="background:var(--pm-warning-soft)"><div style="font-size:11px;color:#B45309;font-weight:700">EXPIRED</div><div style="font-size:20px;font-weight:700;color:var(--pm-warning)">12</div></div></div>
          </div>
          <h6 style="font-weight:700">Agro-Vet Merchant Redemptions</h6>
          <div class="table-responsive"><table class="pm-table"><thead><tr><th>Merchant / Till</th><th>Location</th><th>Redeemed Today</th><th>Status</th></tr></thead><tbody>
            @for (vm of voucherMerchants; track vm.id) {
              <tr><td>{{ vm.merchant }}</td><td>{{ vm.location }}</td><td>{{ vm.redeemedToday }}</td><td><span [class]="vm.statusBadgeClass">{{ vm.statusBadge }}</span></td></tr>
            }
          </tbody></table></div>
        </div>
        <div class="modal-footer"><button class="pm-btn" (click)="closeModal()">Close</button><button class="pm-btn pm-btn-primary">Generate Batch Vouchers</button></div>
      </div>
    </div>
  </div>

<!-- 18. Biometric Verification Modal -->
@if (activeModal === 'biometricVerificationModal') {
  <div class="modal-backdrop show"></div>
  <div class="modal d-block" tabindex="-1" (click)="closeModal()">
    <div class="modal-dialog modal-dialog-centered" (click)="$event.stopPropagation()">
      <div class="modal-content">
        <div class="modal-header"><h5 class="modal-title"><i class="bi bi-fingerprint text-purple me-2" style="color:var(--pm-purple)"></i>Compliance & Verification Report</h5><button class="btn-close" (click)="closeModal()"></button></div>
        <div class="modal-body">
          <p style="font-size:13px;color:var(--pm-ink-soft)">For the <strong>Inua Jamii Q2 Stipend</strong>, biometric verification via IPRS and mobile agents is required.</p>
          <div class="mb-3">
            <div class="d-flex justify-content-between mb-1" style="font-size:12px"><span>Verified & Disbursed</span><span>4,000</span></div>
            <div class="pm-progress"><div class="pm-progress-bar" style="width:95%;background:var(--pm-success)"></div></div>
          </div>
          <div class="mb-3">
            <div class="d-flex justify-content-between mb-1" style="font-size:12px"><span>Pending Field Verification</span><span>150</span></div>
            <div class="pm-progress"><div class="pm-progress-bar" style="width:4%;background:var(--pm-warning)"></div></div>
          </div>
          <div class="mb-3">
            <div class="d-flex justify-content-between mb-1" style="font-size:12px"><span>Flagged (Deceased / Invalid ID)</span><span>50</span></div>
            <div class="pm-progress"><div class="pm-progress-bar" style="width:1%;background:var(--pm-danger)"></div></div>
          </div>
          <div class="p-3 rounded" style="background:var(--pm-surface-2);font-size:12px"><i class="bi bi-file-earmark-pdf me-1"></i> Funds for flagged beneficiaries have been ring-fenced and returned to the master program float.</div>
        </div>
        <div class="modal-footer"><button class="pm-btn" (click)="closeModal()">Close</button><button class="pm-btn pm-btn-primary" (click)="closeModal(); openModal('exportAnalyticsModal')">Download Full Roster</button></div>
      </div>
    </div>
  </div>

<!-- 19. Individual Transaction Receipt Modal -->
@if (activeModal === 'transactionReceiptModal') {
  <div class="modal-backdrop show"></div>
  <div class="modal d-block" tabindex="-1" (click)="closeModal()">
    <div class="modal-dialog modal-dialog-centered" (click)="$event.stopPropagation()">
      <div class="modal-content">
        <div class="modal-header"><h5 class="modal-title"><i class="bi bi-receipt me-2"></i>Disbursement Receipt</h5><button class="btn-close" (click)="closeModal()"></button></div>
        <div class="modal-body">
          <div class="pm-receipt">
            <div class="receipt-icon"><i class="bi bi-check-lg"></i></div>
            <h5 style="font-weight:700;color:var(--pm-accent)">Transfer Successful</h5>
            <div class="p-3 rounded text-start mt-3" style="background:#fff;font-size:13px">
              <div class="d-flex justify-content-between mb-2"><span class="text-muted">Beneficiary</span><strong>Jane Nduta</strong></div>
              <div class="d-flex justify-content-between mb-2"><span class="text-muted">Account</span><strong>0712***890</strong></div>
              <div class="d-flex justify-content-between mb-2"><span class="text-muted">Amount</span><strong>KES 15,000.00</strong></div>
              <div class="d-flex justify-content-between mb-2"><span class="text-muted">Batch Ref</span><strong>BTH-9920</strong></div>
              <div class="d-flex justify-content-between mb-2"><span class="text-muted">M-Pesa ID</span><strong style="font-family:monospace;color:var(--pm-primary)">TK982LMN12</strong></div>
              <div class="d-flex justify-content-between"><span class="text-muted">Date</span><strong>27 Jun 2025, 14:32 EAT</strong></div>
            </div>
            <div class="d-flex gap-2 justify-content-center mt-3"><button class="pm-btn pm-btn-sm"><i class="bi bi-download"></i> PDF</button><button class="pm-btn pm-btn-sm"><i class="bi bi-envelope"></i> Email</button></div>
          </div>
        </div>
        <div class="modal-footer"><button class="pm-btn" (click)="closeModal()">Close</button></div>
      </div>
    </div>
  </div>

<!-- 20. Bulk Receipt Modal -->
@if (activeModal === 'bulkReceiptModal') {
  <div class="modal-backdrop show"></div>
  <div class="modal d-block" tabindex="-1" (click)="closeModal()">
    <div class="modal-dialog modal-dialog-centered" (click)="$event.stopPropagation()">
      <div class="modal-content">
        <div class="modal-header"><h5 class="modal-title"><i class="bi bi-receipt-cutoff me-2"></i>Batch Consolidated Receipt</h5><button class="btn-close" (click)="closeModal()"></button></div>
        <div class="modal-body">
          <div class="pm-receipt">
            <div class="receipt-icon"><i class="bi bi-collection-play"></i></div>
            <h5 style="font-weight:700;color:var(--pm-accent)">Batch BTH-9920 Executed</h5>
            <div class="p-3 rounded text-start mt-3" style="background:#fff;font-size:13px">
              <div class="d-flex justify-content-between mb-2"><span class="text-muted">Batch Name</span><strong>Q2 Sales Commissions</strong></div>
              <div class="d-flex justify-content-between mb-2"><span class="text-muted">Count</span><strong>118 successful (0 failed)</strong></div>
              <div class="d-flex justify-content-between mb-2"><span class="text-muted">Total Paid</span><strong>KES 4,500,000</strong></div>
              <div class="d-flex justify-content-between mb-2"><span class="text-muted">Fees</span><strong>KES 2,596</strong></div>
              <div class="d-flex justify-content-between"><span class="text-muted">Time Completed</span><strong>27 Jun 2025, 14:34 EAT</strong></div>
            </div>
            <div class="d-flex gap-2 justify-content-center mt-3"><button class="pm-btn pm-btn-sm pm-btn-primary"><i class="bi bi-file-earmark-excel"></i> Download Settlement File</button></div>
          </div>
        </div>
        <div class="modal-footer"><button class="pm-btn" (click)="closeModal()">Close</button></div>
      </div>
    </div>
  </div>

<!-- 21. Dispute / Reversal Modal -->
@if (activeModal === 'disputeDisbursementModal') {
  <div class="modal-backdrop show"></div>
  <div class="modal d-block" tabindex="-1" (click)="closeModal()">
    <div class="modal-dialog modal-dialog-centered" (click)="$event.stopPropagation()">
      <div class="modal-content">
        <div class="modal-header"><h5 class="modal-title"><i class="bi bi-arrow-counterclockwise me-2"></i>Recall / Reversal Request</h5><button class="btn-close" (click)="closeModal()"></button></div>
        <div class="modal-body">
          @if (!disputeDisbursementSaved) {
            <div class="p-3 rounded mb-3" style="background:var(--pm-warning-soft);font-size:13px"><i class="bi bi-exclamation-triangle me-1"></i> Note: Reversals are subject to M-Pesa/Bank guidelines and availability of funds in the recipient's account.</div>
            <div class="mb-3"><label class="pm-form-label">Transaction ID (M-Pesa/Bank Ref)</label><input class="pm-form-control" placeholder="e.g. TK982LMN12"></div>
            <div class="mb-3"><label class="pm-form-label">Reason for Recall</label><select class="pm-form-control"><option>Sent to wrong number</option><option>Wrong amount sent</option><option>Duplicate payment</option><option>Fraud suspected</option></select></div>
            <div class="mb-3"><label class="pm-form-label">Additional Details</label><textarea class="pm-form-control" rows="3"></textarea></div>
            <div class="form-check"><input class="form-check-input" type="checkbox" required><label class="form-check-label" style="font-size:13px">I authorize PayMo to initiate a reversal request on my behalf.</label></div>
          } @else {
            <div class="pm-receipt">
              <div class="receipt-icon"><i class="bi bi-check-lg"></i></div>
              <h5 style="font-weight:700;color:var(--pm-accent)">Reversal request submitted to PSP. Track status in Audit Log.</h5>
              <p style="font-size:12px;color:var(--pm-muted)">Ref: REV-1192</p>
            </div>
        </div>
        <div class="modal-footer">
          @if (!disputeDisbursementSaved) {
            <button class="pm-btn" (click)="closeModal()">Cancel</button>
            <button class="pm-btn pm-btn-danger" (click)="processAction('disputeDisbursementModal','Reversal request submitted to PSP. Track status in Audit Log.','REV-1192')">Submit Recall Request</button>
          } @else {
            <button class="pm-btn pm-btn-primary" (click)="closeModal()">Close</button>
          }
        </div>
      </div>
    </div>
  </div>

<!-- 22. Attention Action Modal -->
@if (activeModal === 'attentionActionModal') {
  <div class="modal-backdrop show"></div>
  <div class="modal d-block" tabindex="-1" (click)="closeModal()">
    <div class="modal-dialog modal-lg modal-dialog-centered" (click)="$event.stopPropagation()">
      <div class="modal-content">
        <div class="modal-header"><h5 class="modal-title"><i class="bi bi-exclamation-circle text-warning me-2"></i>Action Center</h5><button class="btn-close" (click)="closeModal()"></button></div>
        <div class="modal-body" style="max-height:400px;overflow-y:auto">
          <div class="feed-item"><div class="pm-icon-circle" style="background:var(--pm-warning-soft);color:var(--pm-warning)">AP</div><div style="flex:1"><div style="font-weight:600">Approve: Contractor Payout Batch</div><div style="font-size:12px;color:var(--pm-muted)">KES 1.2M pending your sign-off</div></div><button class="pm-btn pm-btn-sm pm-btn-primary" (click)="openModal('approveBatchModal')">Review</button></div>
          <div class="feed-item"><div class="pm-icon-circle" style="background:var(--pm-danger-soft);color:var(--pm-danger)">FL</div><div style="flex:1"><div style="font-weight:600">14 Failed Transfers</div><div style="font-size:12px;color:var(--pm-muted)">Invalid numbers from last run</div></div><button class="pm-btn pm-btn-sm" (click)="openModal('failedTransfersModal')">Resolve</button></div>
          <div class="feed-item"><div class="pm-icon-circle" style="background:var(--pm-purple-soft);color:var(--pm-purple)">FL</div><div style="flex:1"><div style="font-weight:600">Low Float Warning</div><div style="font-size:12px;color:var(--pm-muted)">Scheduled batches exceed current KES 14.2M float</div></div><button class="pm-btn pm-btn-sm" (click)="openModal('fundWalletModal')">Top-up</button></div>
        </div>
        <div class="modal-footer"><button class="pm-btn" (click)="closeModal()">Close</button></div>
      </div>
    </div>
  </div>

<!-- 23. Business Profile / Multi-Business Modal -->
@if (activeModal === 'businessProfileModal') {
  <div class="modal-backdrop show"></div>
  <div class="modal d-block" tabindex="-1" (click)="closeModal()">
    <div class="modal-dialog modal-dialog-centered" (click)="$event.stopPropagation()">
      <div class="modal-content">
        <div class="modal-header"><h5 class="modal-title"><i class="bi bi-buildings me-2"></i>Business Accounts</h5><button class="btn-close" (click)="closeModal()"></button></div>
        <div class="modal-body">
          @if (!businessProfileSaved) {
            <div class="p-3 border rounded mb-2 d-flex align-items-center justify-content-between" style="border-color:var(--pm-primary)!important;background:rgba(79,70,229,.04)">
              <div class="d-flex align-items-center gap-3"><div class="pm-avatar" style="background:var(--pm-gradient-slate)">SO</div><div><strong>Safiri Operations Ltd</strong><div style="font-size:11px;color:var(--pm-muted)">PayBill: 400192</div></div></div>
              <i class="bi bi-check-circle-fill text-success"></i>
            </div>
            <div class="p-3 border rounded mb-3 d-flex align-items-center justify-content-between" style="cursor:pointer" (click)="processAction('businessProfileModal','Switched to Safiri Logistics','Switch')">
              <div class="d-flex align-items-center gap-3"><div class="pm-avatar" style="background:var(--pm-gradient-blue)">SL</div><div><strong>Safiri Logistics (Subsidiary)</strong><div style="font-size:11px;color:var(--pm-muted)">PayBill: 400193</div></div></div>
              <i class="bi bi-arrow-right text-muted"></i>
            </div>
            <hr class="pm-divider">
            <div class="d-flex gap-2"><button class="pm-btn pm-btn-sm"><i class="bi bi-plus"></i> Add New Business</button><button class="pm-btn pm-btn-sm pm-btn-outline"><i class="bi bi-person"></i> My Profile</button></div>
          } @else {
            <div class="pm-receipt">
              <div class="receipt-icon"><i class="bi bi-check-lg"></i></div>
              <h5 style="font-weight:700;color:var(--pm-accent)">Switched to Safiri Logistics</h5>
            </div>
        </div>
        <div class="modal-footer"><button class="pm-btn" (click)="closeModal()">Close</button></div>
      </div>
    </div>
  </div>

<!-- 24. Notifications Modal -->
@if (activeModal === 'notificationsModal') {
  <div class="modal-backdrop show"></div>
  <div class="modal d-block" tabindex="-1" (click)="closeModal()">
    <div class="modal-dialog modal-dialog-centered" (click)="$event.stopPropagation()">
      <div class="modal-content">
        <div class="modal-header"><h5 class="modal-title"><i class="bi bi-bell me-2"></i>Alerts & Notifications</h5><button class="btn-close" (click)="closeModal()"></button></div>
        <div class="modal-body" style="max-height:400px;overflow-y:auto">
          @for (ntf of notifications; track ntf.id) {
            <div class="p-3 rounded mb-2" [style]="ntf.bgStyle" style="font-size:13px"><strong>{{ ntf.title }}</strong><div style="font-size:11px;color:var(--pm-muted);margin-top:4px">{{ ntf.description }}</div></div>
          }
        </div>
        <div class="modal-footer"><button class="pm-btn pm-btn-sm">Mark All Read</button><button class="pm-btn" (click)="closeModal()">Close</button></div>
      </div>
    </div>
  </div>

<!-- 25. Health Check Modal -->
@if (activeModal === 'healthCheckModal') {
  <div class="modal-backdrop show"></div>
  <div class="modal d-block" tabindex="-1" (click)="closeModal()">
    <div class="modal-dialog modal-dialog-centered" (click)="$event.stopPropagation()">
      <div class="modal-content">
        <div class="modal-header"><h5 class="modal-title"><i class="bi bi-shield-check text-success me-2"></i>System Health & APIs</h5><button class="btn-close" (click)="closeModal()"></button></div>
        <div class="modal-body">
          @for (hc of healthChecks; track hc.id) {
            <div class="status-row"><div><strong>{{ hc.name }}</strong><div style="font-size:11px;color:var(--pm-muted)">{{ hc.response }}</div></div><span [class]="hc.statusBadgeClass">{{ hc.statusBadge }}</span></div>
          }
          <hr class="pm-divider">
          <div class="p-3 rounded" style="background:var(--pm-surface-2);font-size:12px">All bulk disbursements targeting Airtel Money will automatically retry up to 3 times or fallback to Bank if configured.</div>
        </div>
        <div class="modal-footer"><button class="pm-btn" (click)="closeModal()">Close</button></div>
      </div>
    </div>
  </div>
}}
}
}
}
}
}
}
}
}
}
}
}
}
}
}
}
}
}
}
}
}
}
}
}
}
}
}
}
}
}
}
}
}
}
}
}
}
}
}
}
}
}
