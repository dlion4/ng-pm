      <div class="pm-step-label">{{ label }}</div>
    </div>
  }
</div>
@if (loadingModal === 'investCashModal') {
  <div class="pm-loading-overlay"><div class="pm-spinner"></div><p style="margin-top:12px;font-size:13px;font-weight:600;color:var(--pm-primary)">Processing...</p></div>
}
@if (stepState['invest'] === 1) {
<div>
<div class="row g-2 mb-3">
<div class="col-md-4"><div class="acct-card text-center" (click)="selectBox($event)"><i class="bi bi-shield-check text-success" style="font-size:24px"></i><div style="font-size:13px;font-weight:700;margin-top:8px">PayMo MMF</div><div style="font-size:11px;color:var(--pm-muted)">Yield: 11.2% | Liquid</div></div></div>
<div class="col-md-4"><div class="acct-card text-center" (click)="selectBox($event)"><i class="bi bi-bank text-primary" style="font-size:24px"></i><div style="font-size:13px;font-weight:700;margin-top:8px">91-Day T-Bill</div><div style="font-size:11px;color:var(--pm-muted)">Yield: 15.4% | Locked</div></div></div>
<div class="col-md-4"><div class="acct-card text-center" (click)="selectBox($event)"><i class="bi bi-lock text-warning" style="font-size:24px"></i><div style="font-size:13px;font-weight:700;margin-top:8px">Fixed Deposit</div><div style="font-size:11px;color:var(--pm-muted)">Yield: 13.0% | 30 Days</div></div></div>
</div>
<div class="mb-3"><label class="pm-form-label">Funding Account</label><select class="pm-form-control"><option>Equity Bank Main (Available: KES 14.2M)</option><option>PayMo Wallet (Available: KES 4.2M)</option></select></div>
<div class="mb-3"><label class="pm-form-label">Investment Amount (KES)</label><input type="number" class="pm-form-control" value="2500000"></div>
</div>
} @else if (stepState['invest'] === 2) {
<div>
<h6 style="font-weight:700">Review Investment</h6>
<div class="p-3 rounded mb-3" style="background:var(--pm-info-soft);font-size:13px"><div class="d-flex justify-content-between mb-2"><span class="text-muted">Product</span><strong>PayMo Corporate MMF</strong></div><div class="d-flex justify-content-between mb-2"><span class="text-muted">Amount</span><strong>KES 2,500,000</strong></div><div class="d-flex justify-content-between mb-2"><span class="text-muted">Target Yield</span><strong>11.2% p.a.</strong></div><div class="d-flex justify-content-between"><span class="text-muted">Est. Monthly Interest</span><strong style="color:var(--pm-accent)">~ KES 23,333</strong></div></div>
<div class="form-check"><input class="form-check-input" type="checkbox" checked><label class="form-check-label" style="font-size:13px">Auto-reinvest monthly interest (Compound)</label></div>
</div>
} @else {
<div class="pm-receipt"><div class="receipt-icon"><i class="bi bi-check-lg"></i></div><h5 style="font-weight:700;color:var(--pm-accent)">Investment Placed!</h5><p style="font-size:13px;color:var(--pm-ink-soft)">KES 2,500,000 has been moved to the PayMo MMF. Interest accrues daily.</p><div style="font-size:12px;color:var(--pm-muted)">Ref: INV-20250628-331</div></div>
}
</div>
<div class="modal-footer">
  @if (stepState['invest'] < 3) {
    <button class="pm-btn" (click)="closeModal()">Cancel</button>
    <button class="pm-btn pm-btn-primary" (click)="nextFlow('invest', 3)">{{ getFlowButtonLabel('invest', 3) }} @if (stepState['invest'] < 2) { <i class="bi bi-arrow-right"></i> } @else { <i class="bi bi-lock"></i> }</button>
  } @else {
    <button class="pm-btn pm-btn-primary" (click)="closeModal()">Done</button>
  }
</div>
</div>
</div></div>

<!-- 10. Liquidate Investment -->
@if (activeModal === 'liquidateInvestModal') {
<div class="pm-modal-backdrop"><div class="pm-modal-dialog" (click)="closeModal(); $event.stopPropagation()">
<div class="modal-content">
<div class="modal-header"><h5 class="modal-title"><i class="bi bi-box-arrow-right text-danger me-2"></i>Withdraw / Liquidate Investment</h5><button class="btn-close" (click)="closeModal()"></button></div>
<div class="modal-body" style="position:relative">
  @if (savedModals['liquidateInvestModal']) {
    <div class="pm-receipt"><div class="receipt-icon"><i class="bi bi-check-lg"></i></div><h5 style="font-weight:700;color:var(--pm-accent)">{{ savedModals['liquidateInvestModal'].message }}</h5><p style="font-size:12px;color:var(--pm-muted)">Reference: {{ savedModals['liquidateInvestModal'].ref }}</p></div>
  } @else if (loadingModal === 'liquidateInvestModal') {
    <div class="pm-loading-overlay"><div class="pm-spinner"></div><p style="margin-top:12px;font-size:13px;font-weight:600;color:var(--pm-primary)">Processing...</p></div>
  } @else {
    <div class="p-3 rounded mb-3" style="background:var(--pm-surface-2)"><div class="d-flex justify-content-between mb-1"><span class="text-muted">Investment</span><strong>PayMo Corporate MMF</strong></div><div class="d-flex justify-content-between"><span class="text-muted">Available Balance</span><strong style="color:var(--pm-primary)">KES 8,500,000</strong></div></div>
    <div class="mb-3"><label class="pm-form-label">Withdrawal Amount (KES)</label><input type="number" class="pm-form-control" value="1000000"></div>
    <div class="mb-3"><label class="pm-form-label">Destination Account</label><select class="pm-form-control"><option>Equity Bank Main</option><option>PayMo Wallet</option></select></div>
    <div style="font-size:12px;color:var(--pm-muted)">Withdrawals from MMF reflect in your target account within 24 hours. Early withdrawal from locked deposits may incur penalty fees.</div>
  }
</div>
<div class="modal-footer">
  @if (savedModals['liquidateInvestModal']) {
    <button class="pm-btn pm-btn-primary" (click)="closeModal()">Done</button>
  } @else {
    <button class="pm-btn" (click)="closeModal()">Cancel</button>
    <button class="pm-btn pm-btn-danger" (click)="processAction('liquidateInvestModal','Withdrawal initiated. Funds will settle within 24 hours.','WTD-9921')">Withdraw Funds</button>
  }
</div>
</div>
</div></div>

<!-- 11. Investment Portfolio -->
@if (activeModal === 'investmentPortfolioModal') {
<div class="pm-modal-backdrop"><div class="pm-modal-dialog modal-lg" (click)="closeModal(); $event.stopPropagation()">
<div class="modal-content">
<div class="modal-header"><h5 class="modal-title"><i class="bi bi-briefcase me-2"></i>Investment Portfolio</h5><button class="btn-close" (click)="closeModal()"></button></div>
<div class="modal-body">
<div class="row g-3 mb-3">
<div class="col-md-4"><div class="p-3 rounded" style="background:var(--pm-purple-soft)"><div style="font-size:11px;font-weight:700;color:var(--pm-purple)">TOTAL AUM</div><div style="font-size:24px;font-weight:700;color:var(--pm-purple-dark)">KES 18.5M</div></div></div>
<div class="col-md-4"><div class="p-3 rounded" style="background:var(--pm-accent-soft)"><div style="font-size:11px;font-weight:700;color:var(--pm-accent)">YTD INTEREST</div><div style="font-size:24px;font-weight:700;color:var(--pm-accent-dark)">KES 842.5K</div></div></div>
<div class="col-md-4"><div class="p-3 rounded" style="background:var(--pm-info-soft)"><div style="font-size:11px;font-weight:700;color:var(--pm-info)">W.A. YIELD</div><div style="font-size:24px;font-weight:700;color:var(--pm-info-dark)">13.4%</div></div></div>
</div>
<div class="table-responsive"><table class="pm-table"><thead><tr><th>Asset Class</th><th>Principal</th><th>Yield (p.a.)</th><th>Maturity</th><th>Action</th></tr></thead><tbody>
<tr><td>PayMo MMF</td><td>KES 8,500,000</td><td>11.2%</td><td>Liquid</td><td><button class="pm-btn pm-btn-sm" (click)="openModal('liquidateInvestModal')">Withdraw</button></td></tr>
<tr><td>91-Day T-Bill</td><td>KES 5,000,000</td><td>15.4%</td><td>29 Jun 2025</td><td><button class="pm-btn pm-btn-sm">Rollover</button></td></tr>
<tr><td>182-Day T-Bill</td><td>KES 5,000,000</td><td>15.8%</td><td>12 Aug 2025</td><td><button class="pm-btn pm-btn-sm" disabled>Locked</button></td></tr>
</tbody></table></div>
</div>
<div class="modal-footer"><button class="pm-btn">Close</button><button class="pm-btn pm-btn-primary">New Investment</button><div (click)="closeModal(); openModal('investCashModal')">
</div>
</div></div>

<!-- 12. Cashflow Forecast Modal -->
@if (activeModal === 'cashflowForecastModal') {
<div class="pm-modal-backdrop"><div class="pm-modal-dialog modal-xl" (click)="closeModal(); $event.stopPropagation()">
<div class="modal-content">
<div class="modal-header"><h5 class="modal-title"><i class="bi bi-graph-up me-2"></i>Cash Flow Forecast Model</h5><button class="btn-close" (click)="closeModal()"></button></div>
<div class="modal-body">
<div class="d-flex justify-content-between mb-3">
<div class="pm-tab-pills"><button class="pm-tab-pill" [class.active]="activeTabs['forecastTab'] === '30d'">30 Days</button><button class="pm-tab-pill" [class.active]="activeTabs['forecastTab'] === '60d'">60 Days</button><button class="pm-tab-pill" [class.active]="activeTabs['forecastTab'] === '90d'">90 Days</button><div (click)="activeTabs['forecastTab'] = '30d'; activeTabs['forecastTab'] = '60d'; activeTabs['forecastTab'] = '90d'">
<button class="pm-btn pm-btn-sm" (click)="openModal('cashflowScenarioModal')"><i class="bi bi-sliders"></i> Scenarios</button>
</div>
<div class="chart-bars" style="height:150px">
<div class="chart-bar" style="height:30%;background:var(--pm-info)"><span class="bar-label">Jun 28</span></div>
<div class="chart-bar" style="height:45%;background:var(--pm-info)"><span class="bar-label">Jul 05</span></div>
<div class="chart-bar" style="height:70%;background:var(--pm-primary)"><span class="bar-label">Jul 12</span></div>
<div class="chart-bar" style="height:85%;background:var(--pm-accent)"><span class="bar-label">Jul 19</span></div>
<div class="chart-bar" style="height:25%;background:var(--pm-warning)"><span class="bar-label">Jul 26</span></div>
</div>
<div class="row g-3 mt-4">
<div class="col-md-6"><h6 style="font-weight:700">Expected Inflows (+18.2M)</h6><ul style="font-size:12px;color:var(--pm-ink-soft)"><li>Accounts Receivable (Due &lt; 30D): KES 12.5M</li><li>Recurring Subscription Revenue: KES 4.2M</li><li>Interest/Maturities: KES 1.5M</li></ul></div>
<div class="col-md-6"><h6 style="font-weight:700">Expected Outflows (-14.8M)</h6><ul style="font-size:12px;color:var(--pm-ink-soft)"><li>Payroll (Jul 25): KES 8.2M</li><li>Accounts Payable (Suppliers): KES 4.5M</li><li>Taxes (PAYE, VAT): KES 2.1M</li></ul></div>
</div>
</div>
<div class="modal-footer"><button class="pm-btn">Close</button><button class="pm-btn pm-btn-primary">Export Model</button><div (click)="closeModal(); openModal('exportTreasuryModal')">
</div>
</div></div>

<!-- 13. Scenario Builder Modal -->
@if (activeModal === 'cashflowScenarioModal') {
<div class="pm-modal-backdrop"><div class="pm-modal-dialog" (click)="closeModal(); $event.stopPropagation()">
<div class="modal-content">
<div class="modal-header"><h5 class="modal-title"><i class="bi bi-sliders text-primary me-2"></i>"What-If" Scenario Builder</h5><button class="btn-close" (click)="closeModal()"></button></div>
<div class="modal-body" style="position:relative">
  @if (savedModals['cashflowScenarioModal']) {
    <div class="pm-receipt"><div class="receipt-icon"><i class="bi bi-check-lg"></i></div><h5 style="font-weight:700;color:var(--pm-accent)">{{ savedModals['cashflowScenarioModal'].message }}</h5></div>
  } @else if (loadingModal === 'cashflowScenarioModal') {
    <div class="pm-loading-overlay"><div class="pm-spinner"></div><p style="margin-top:12px;font-size:13px;font-weight:600;color:var(--pm-primary)">Processing...</p></div>
  } @else {
    <div class="mb-3"><label class="pm-form-label">Scenario Name</label><input type="text" class="pm-form-control" value="Late Client Payments"></div>
    <div class="mb-3"><label class="pm-form-label">Receivables Delay</label><select class="pm-form-control"><option>Push all inflows by 7 days</option><option selected>Push 30% of inflows by 14 days</option><option>Push all inflows by 30 days</option></select></div>
    <div class="mb-3"><label class="pm-form-label">Payables Strategy</label><select class="pm-form-control"><option>Pay on time (Normal)</option><option>Delay supplier payments by 7 days</option></select></div>
    <div class="mb-3"><label class="pm-form-label">FX Shock</label><select class="pm-form-control"><option>None</option><option>KES depreciation by 5%</option></select></div>
    <div class="p-3 rounded mt-3" style="background:var(--pm-warning-soft);font-size:12px"><i class="bi bi-exclamation-triangle me-1"></i> Under this scenario, you will face a liquidity shortfall of <strong>KES 1.2M</strong> on Jul 25 (Payroll date). Recommended mitigation: Liquidate KES 1.5M from MMF on Jul 23.</div>
  }
</div>
<div class="modal-footer">
  @if (savedModals['cashflowScenarioModal']) {
    <button class="pm-btn pm-btn-primary" (click)="closeModal()">Done</button>
  } @else {
    <button class="pm-btn" (click)="closeModal()">Cancel</button>
    <button class="pm-btn pm-btn-primary" (click)="processAction('cashflowScenarioModal','Scenario saved and applied to forecast view.','')">Apply Scenario</button>
  }
</div>
</div>
</div></div>

<!-- 14. Export Treasury Reports -->
@if (activeModal === 'exportTreasuryModal') {
<div class="pm-modal-backdrop"><div class="pm-modal-dialog" (click)="closeModal(); $event.stopPropagation()">
<div class="modal-content">
<div class="modal-header"><h5 class="modal-title"><i class="bi bi-file-earmark-pdf text-danger me-2"></i>Export Treasury Reports</h5><button class="btn-close" (click)="closeModal()"></button></div>
<div class="modal-body" style="position:relative">
  @if (savedModals['exportTreasuryModal']) {
    <div class="pm-receipt"><div class="receipt-icon"><i class="bi bi-check-lg"></i></div><h5 style="font-weight:700;color:var(--pm-accent)">{{ savedModals['exportTreasuryModal'].message }}</h5></div>
  } @else if (loadingModal === 'exportTreasuryModal') {
    <div class="pm-loading-overlay"><div class="pm-spinner"></div><p style="margin-top:12px;font-size:13px;font-weight:600;color:var(--pm-primary)">Processing...</p></div>
  } @else {
    <div class="mb-3"><label class="pm-form-label">Report Type</label><select class="pm-form-control"><option>Consolidated Cash Position</option><option>FX Exposure &amp; Hedging</option><option>Investment Yield Summary</option><option>Sweep &amp; Auto-transfer Log</option><option>Cash Flow Forecast (30D)</option></select></div>
    <div class="row g-3 mb-3"><div class="col-6"><label class="pm-form-label">From</label><input type="date" class="pm-form-control" value="2025-06-01"></div><div class="col-6"><label class="pm-form-label">To</label><input type="date" class="pm-form-control" value="2025-06-28"></div></div>
    <div class="mb-3"><label class="pm-form-label">Format</label><select class="pm-form-control"><option>PDF</option><option>Excel (XLSX)</option><option>CSV</option></select></div>
  }
</div>
<div class="modal-footer">
  @if (savedModals['exportTreasuryModal']) {
    <button class="pm-btn pm-btn-primary" (click)="closeModal()">Done</button>
  } @else {
    <button class="pm-btn" (click)="closeModal()">Cancel</button>
    <button class="pm-btn pm-btn-primary" (click)="processAction('exportTreasuryModal','Report generated and downloading...','')"><i class="bi bi-download"></i> Generate Report</button>
  }
</div>
</div>
</div></div>

<!-- 15. FX Alert Modal -->
@if (activeModal === 'fxAlertModal') {
<div class="pm-modal-backdrop"><div class="pm-modal-dialog" (click)="closeModal(); $event.stopPropagation()">
<div class="modal-content">
<div class="modal-header"><h5 class="modal-title"><i class="bi bi-bell me-2" style="color:var(--pm-accent)"></i>Set FX Target Alert</h5><button class="btn-close" (click)="closeModal()"></button></div>
<div class="modal-body" style="position:relative">
  @if (savedModals['fxAlertModal']) {
