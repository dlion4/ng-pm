    <div class="p-3 rounded mb-3" style="background:var(--pm-surface-2);font-size:12px">Running auto-reconciliation will match PayMo ledger entries against raw bank statements pulled via Open Banking API.</div>
    <div class="d-flex justify-content-between mb-2" style="font-size:12px"><span>Unmatched Ledger Entries:</span><strong>14</strong></div>
    <div class="d-flex justify-content-between" style="font-size:12px"><span>Unmatched Bank Statement Lines:</span><strong>12</strong></div>
  }
</div>
<div class="modal-footer">
  @if (savedModals['reconciliationModal']) {
    <button class="pm-btn pm-btn-primary" (click)="closeModal()">Done</button>
  } @else {
    <button class="pm-btn" (click)="closeModal()">Cancel</button>
    <button class="pm-btn pm-btn-primary" (click)="processAction('reconciliationModal','Reconciliation complete. 12 items matched. 2 exceptions flagged.','')">Run Reconciliation</button>
  }
</div>
</div>
</div></div>

<!-- 19. Bank Statements Modal -->
@if (activeModal === 'bankStatementsModal') {
<div class="pm-modal-backdrop"><div class="pm-modal-dialog modal-lg" (click)="closeModal(); $event.stopPropagation()">
<div class="modal-content">
<div class="modal-header"><h5 class="modal-title"><i class="bi bi-journal-text me-2"></i>Bank Statements (API Pulled)</h5><button class="btn-close" (click)="closeModal()"></button></div>
<div class="modal-body">
<div class="d-flex justify-content-between mb-3"><select class="pm-form-control" style="width:250px"><option>Equity Bank Main</option><option>KCB Payroll</option></select><button class="pm-btn pm-btn-sm"><i class="bi bi-arrow-clockwise"></i> Sync Now</button></div>
<div class="table-responsive"><table class="pm-table"><thead><tr><th>Date</th><th>Description</th><th>Ref</th><th>In</th><th>Out</th><th>Balance</th></tr></thead><tbody>
@for (stmt of bankStatements; track stmt.ref) {
<tr><td>{{ stmt.date }}</td><td>{{ stmt.description }}</td><td>{{ stmt.ref }}</td><td>{{ stmt.inflow }}</td><td>{{ stmt.outflow }}</td><td>{{ stmt.balance }}</td></tr>
}
</tbody></table></div>
</div>
<div class="modal-footer"><button class="pm-btn">Close</button><button class="pm-btn pm-btn-primary">Export PDF/CSV</button><div (click)="closeModal(); openModal('exportTreasuryModal')">
</div>
</div></div>

<!-- 20. Yield Analytics Modal -->
@if (activeModal === 'yieldAnalyticsModal') {
<div class="pm-modal-backdrop"><div class="pm-modal-dialog modal-lg" (click)="closeModal(); $event.stopPropagation()">
<div class="modal-content">
<div class="modal-header"><h5 class="modal-title"><i class="bi bi-bar-chart-line me-2" style="color:var(--pm-purple)"></i>Yield Analytics</h5><button class="btn-close" (click)="closeModal()"></button></div>
<div class="modal-body">
<div class="chart-bars" style="height:150px">
<div class="chart-bar" style="height:30%;background:var(--pm-purple)"><span class="bar-label">Jan</span></div>
<div class="chart-bar" style="height:45%;background:var(--pm-purple)"><span class="bar-label">Feb</span></div>
<div class="chart-bar" style="height:60%;background:var(--pm-purple)"><span class="bar-label">Mar</span></div>
<div class="chart-bar" style="height:55%;background:var(--pm-purple)"><span class="bar-label">Apr</span></div>
<div class="chart-bar" style="height:75%;background:var(--pm-purple)"><span class="bar-label">May</span></div>
<div class="chart-bar" style="height:85%;background:var(--pm-purple)"><span class="bar-label">Jun</span></div>
</div>
<div class="table-responsive mt-4"><table class="pm-table"><thead><tr><th>Month</th><th>Avg Principal</th><th>Interest Earned</th><th>Effective Annual Yield</th></tr></thead><tbody>
@for (y of yieldData; track y.month) {
<tr><td>{{ y.month }}</td><td>{{ y.principal }}</td><td>{{ y.interest }}</td><td>{{ y.yield }}</td></tr>
}
</tbody></table></div>
</div>
<div class="modal-footer"><button class="pm-btn" (click)="closeModal()">Close</button></div>
</div>
</div></div>

<!-- 21. Attention Modal -->
@if (activeModal === 'attentionModal') {
<div class="pm-modal-backdrop"><div class="pm-modal-dialog modal-lg" (click)="closeModal(); $event.stopPropagation()">
<div class="modal-content">
<div class="modal-header"><h5 class="modal-title"><i class="bi bi-exclamation-circle text-warning me-2"></i>Treasury Action Items</h5><button class="btn-close" (click)="closeModal()"></button></div>
<div class="modal-body">
<div class="status-row"><div><strong>3 Sweeps require approval</strong><div style="font-size:11px;color:var(--pm-muted)">KES 4.2M target balancing transfers</div></div><button class="pm-btn pm-btn-sm pm-btn-primary" (click)="openModal('approvalQueueModal')">Review</button></div>
<div class="status-row"><div><strong>USD/KES dropped to 129.10</strong><div style="font-size:11px;color:var(--pm-muted)">Hit target alert for vendor payment</div></div><button class="pm-btn pm-btn-sm" (click)="openModal('bookFXModal')">Trade</button></div>
<div class="status-row"><div><strong>T-Bill maturity tomorrow</strong><div style="font-size:11px;color:var(--pm-muted)">KES 5.0M principal + interest</div></div><button class="pm-btn pm-btn-sm" (click)="openModal('investmentPortfolioModal')">Action</button></div>
<div class="status-row"><div><strong>Unreconciled bank statement</strong><div style="font-size:11px;color:var(--pm-muted)">Equity Bank main op account</div></div><button class="pm-btn pm-btn-sm" (click)="openModal('reconciliationModal')">Fix</button></div>
</div>
<div class="modal-footer"><button class="pm-btn" (click)="closeModal()">Close</button></div>
</div>
</div></div>

<!-- 22. Profile Modal -->
@if (activeModal === 'profileModal') {
<div class="pm-modal-backdrop"><div class="pm-modal-dialog" (click)="closeModal(); $event.stopPropagation()">
<div class="modal-content">
<div class="modal-header"><h5 class="modal-title"><i class="bi bi-person-circle me-2"></i>Profile Summary</h5><button class="btn-close" (click)="closeModal()"></button></div>
<div class="modal-body text-center">
<div class="pm-avatar mx-auto mb-3" style="width:64px;height:64px;font-size:24px;background:var(--pm-gradient-slate)">EA</div>
<h5 style="font-weight:700;margin-bottom:2px">Esther A.</h5>
<p style="font-size:13px;color:var(--pm-muted)">esther.a@corporate.com · CFO / Treasury</p>
<div class="row g-2 text-start mt-3" style="font-size:13px"><div class="col-6"><div class="p-2 rounded" style="background:var(--pm-surface-2)"><span class="text-muted">Auth Limit</span><br><strong>Unlimited</strong></div></div><div class="col-6"><div class="p-2 rounded" style="background:var(--pm-surface-2)"><span class="text-muted">Accounts</span><br><strong>6 managed</strong></div></div></div>
</div>
<div class="modal-footer"><button class="pm-btn" (click)="closeModal()">Close</button></div>
</div>
</div></div>

<!-- 23. Notifications Modal -->
@if (activeModal === 'notificationsModal') {
<div class="pm-modal-backdrop"><div class="pm-modal-dialog" (click)="closeModal(); $event.stopPropagation()">
<div class="modal-content">
<div class="modal-header"><h5 class="modal-title"><i class="bi bi-bell me-2"></i>Notifications</h5><button class="btn-close" (click)="closeModal()"></button></div>
<div class="modal-body" style="max-height:400px;overflow-y:auto">
<div class="p-3 rounded mb-2" style="background:var(--pm-danger-soft);font-size:13px"><strong>Approval Required</strong><div style="font-size:11px;color:var(--pm-muted)">Sweep of KES 1.4M pending your approval</div></div>
<div class="p-3 rounded mb-2" style="background:var(--pm-warning-soft);font-size:13px"><strong>FX Alert Hit</strong><div style="font-size:11px;color:var(--pm-muted)">USD/KES fell below 129.50</div></div>
<div class="p-3 rounded mb-2" style="background:var(--pm-accent-soft);border:1px solid var(--pm-accent);font-size:13px"><strong>Sweep Successful</strong><div style="font-size:11px;color:var(--pm-muted)">End of day sweep completed to Equity Bank</div></div>
</div>
<div class="modal-footer"><button class="pm-btn" (click)="closeModal()">Close</button></div>
</div>
</div></div>

<!-- 24. Treasury Settings Modal -->
@if (activeModal === 'treasurySettingsModal') {
<div class="pm-modal-backdrop"><div class="pm-modal-dialog" (click)="closeModal(); $event.stopPropagation()">
<div class="modal-content">
<div class="modal-header"><h5 class="modal-title"><i class="bi bi-gear me-2"></i>Treasury Settings</h5><button class="btn-close" (click)="closeModal()"></button></div>
<div class="modal-body" style="position:relative">
  @if (savedModals['treasurySettingsModal']) {
    <div class="pm-receipt"><div class="receipt-icon"><i class="bi bi-check-lg"></i></div><h5 style="font-weight:700;color:var(--pm-accent)">{{ savedModals['treasurySettingsModal'].message }}</h5></div>
  } @else if (loadingModal === 'treasurySettingsModal') {
    <div class="pm-loading-overlay"><div class="pm-spinner"></div><p style="margin-top:12px;font-size:13px;font-weight:600;color:var(--pm-primary)">Processing...</p></div>
  } @else {
    <div class="mb-3"><label class="pm-form-label">Global Daily Transfer Limit (KES)</label><input type="number" class="pm-form-control" value="50000000"></div>
    <div class="mb-3"><label class="pm-form-label">Approval Policy</label><select class="pm-form-control"><option>Maker-Checker required for all</option><option>Required only &gt; 1,000,000 KES</option><option>Single approver</option></select></div>
    <div class="form-check form-switch mb-2"><input class="form-check-input" type="checkbox" checked><label class="form-check-label">Auto-reconciliation daily at 6 AM</label></div>
    <div class="form-check form-switch"><input class="form-check-input" type="checkbox" checked><label class="form-check-label">Enable overnight MMF sweeps</label></div>
  }
</div>
<div class="modal-footer">
  @if (savedModals['treasurySettingsModal']) {
    <button class="pm-btn pm-btn-primary" (click)="closeModal()">Done</button>
  } @else {
    <button class="pm-btn" (click)="closeModal()">Cancel</button>
    <button class="pm-btn pm-btn-primary" (click)="processAction('treasurySettingsModal','Settings saved.','')">Save</button>
  }
</div>
</div>
</div></div>

</div>
</div>}
}
}
}
}
}
}
}
}
}
}
}
}
}
}
}
}
}
}
}
}
}
}
}
}
