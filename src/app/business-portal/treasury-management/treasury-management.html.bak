    <div class="mb-3"><label class="pm-form-label">Alert Me When Rate Is</label><select class="pm-form-control"><option>Less than or equal to (&lt;=)</option><option>Greater than or equal to (&gt;=)</option></select></div>
    <div class="mb-3"><label class="pm-form-label">Target Rate</label><input type="number" class="pm-form-control" value="128.50" step="0.01"></div>
    <div class="mb-3"><label class="pm-form-label">Notification Channel</label><div class="form-check"><input class="form-check-input" type="checkbox" checked><label class="form-check-label">SMS / Push</label></div><div class="form-check"><input class="form-check-input" type="checkbox" checked><label class="form-check-label">Email</label></div></div>
  }
</div>
<div class="modal-footer">
  @if (savedModals['fxAlertModal']) {
    <button class="pm-btn pm-btn-primary" (click)="closeModal()">Done</button>
  } @else {
    <button class="pm-btn" (click)="closeModal()">Cancel</button>
    <button class="pm-btn pm-btn-primary" (click)="processAction('fxAlertModal','Alert configured for USD/KES at 128.50.','')">Save Alert</button>
  }
</div>
</div>
</div></div>

<!-- 16. FX Risk & Exposure -->
@if (activeModal === 'fxRiskModal') {
