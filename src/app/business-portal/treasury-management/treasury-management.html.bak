</div>
</div></div>

<!-- 17. Approval Queue -->
@if (activeModal === 'approvalQueueModal') {
<div class="pm-modal-backdrop"><div class="pm-modal-dialog modal-lg" (click)="closeModal(); $event.stopPropagation()">
<div class="modal-content">
<div class="modal-header"><h5 class="modal-title"><i class="bi bi-check-circle text-primary me-2"></i>Treasury Approval Queue</h5><button class="btn-close" (click)="closeModal()"></button></div>
<div class="modal-body" style="position:relative">
  @if (savedModals['approvalQueueModal']) {
    <div class="pm-receipt"><div class="receipt-icon"><i class="bi bi-check-lg"></i></div><h5 style="font-weight:700;color:var(--pm-accent)">{{ savedModals['approvalQueueModal'].message }}</h5><p style="font-size:12px;color:var(--pm-muted)">Reference: {{ savedModals['approvalQueueModal'].ref }}</p></div>
  } @else if (loadingModal === 'approvalQueueModal') {
    <div class="pm-loading-overlay"><div class="pm-spinner"></div><p style="margin-top:12px;font-size:13px;font-weight:600;color:var(--pm-primary)">Processing...</p></div>
  } @else {
    <div class="table-responsive"><table class="pm-table"><thead><tr><th>Request</th><th>Amount</th><th>Initiator</th><th>Action</th></tr></thead><tbody>
    @for (item of approvalItems; track item.ref) {
      <tr><td>{{ item.request }}</td><td>{{ item.amount }}</td><td>{{ item.initiator }}</td><td><div class="d-flex" style="gap:4px"><button class="pm-btn pm-btn-sm pm-btn-primary" (click)="processAction('approvalQueueModal',item.approveMsg,item.ref)">Approve</button><button class="pm-btn pm-btn-sm pm-btn-danger">Reject</button></div></td></tr>
    }
    </tbody></table></div>
  }
</div>
<div class="modal-footer">
  @if (savedModals['approvalQueueModal']) {
    <button class="pm-btn pm-btn-primary" (click)="closeModal()">Done</button>
  } @else {
    <button class="pm-btn" (click)="closeModal()">Close</button>
  }
</div>
</div>
</div></div>

<!-- 18. Reconciliation Modal -->
@if (activeModal === 'reconciliationModal') {
<div class="pm-modal-backdrop"><div class="pm-modal-dialog" (click)="closeModal(); $event.stopPropagation()">
<div class="modal-content">
<div class="modal-header"><h5 class="modal-title"><i class="bi bi-file-earmark-diff text-info me-2"></i>Auto-Reconciliation</h5><button class="btn-close" (click)="closeModal()"></button></div>
