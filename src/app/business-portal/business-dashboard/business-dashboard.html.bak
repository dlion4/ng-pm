<td>Owner</td>
<td>8.10M</td>
<td><button (click)="openModal('p31_interCompanyTransferModal')" class="pm-btn pm-btn-sm" type="button">Transfer</button>
</td>
</tr>
<tr>
<td>TechSolutions Foundation</td>
<td>Admin</td>
<td>2.25M</td>
<td><button (click)="openModal('p31_switchBusinessModal')" class="pm-btn pm-btn-sm" type="button">Switch</button></td>
</tr>
</tbody>
</table>
</div>
</div>
</div>
</div>
<!-- SECTION 3.1.4: TEAM & USER MANAGEMENT -->
<div class="pm-card">
<div class="d-flex justify-content-between align-items-center mb-3">
<div>
<h3 class="pm-section-title text-success"><i class="bi bi-people"></i> 3.1.4 — Team &amp; User
                                Management</h3>
<p class="pm-section-sub">Manage roles, permissions, approval limits, and MFA requirements.
                            </p>
</div>
<div class="d-flex gap-2">
<button (click)="openModal('p31_rolePermissionsModal')" class="pm-btn pm-btn-sm" type="button"><i class="bi bi-shield-lock"></i> View Roles Matrix</button>
<button (click)="openModal('p31_inviteUserModal')" class="pm-btn pm-btn-sm pm-btn-primary" type="button"><i class="bi bi-person-plus"></i> Invite User</button>
</div>
</div>
<div class="table-responsive">
