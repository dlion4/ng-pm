<!-- ===== Angularized body content from source 3.4.html ===== -->
<div><section class="paymo-page-source" id="p34_page">
<!-- HEADER -->

<div class="pm-page-bar">
<div>
<div class="pm-breadcrumb"><a (click)="notify('Link action handled')" role="button" tabindex="0">Business Portal</a> / <a (click)="notify('Link action handled')" role="button" tabindex="0">HR &amp; Operations</a> /
                        <strong>Payroll Disbursement</strong></div>
<h2 style="font-family:var(--pm-font-display);font-size:20px;font-weight:700;margin:8px 0 2px">PAGE
                        3.4 — Payroll &amp; Compliance Command Center</h2>
<p style="font-size:13px;color:var(--pm-ink-soft);margin:0">Configure salary components, execute
                        bulk salary disbursements via M-Pesa B2C/PesaLink, generate payslips, and export statutory
                        P10/SHIF returns.</p>
</div>
<div class="d-flex flex-wrap" style="gap:8px">
<button (click)="openModal('p34_complianceAlertsModal')" class="pm-btn" type="button"><i class="bi bi-shield-check"></i> Compliance Hub</button>
<button (click)="openModal('p34_importEmployeesModal')" class="pm-btn" type="button"><i class="bi bi-file-earmark-excel"></i> Import Roster</button>
<button (click)="openModal('p34_addEmployeeModal')" class="pm-btn pm-btn-accent" type="button"><i class="bi bi-person-plus"></i> Add Employee</button>
<button (click)="openModal('p34_runPayrollModal')" class="pm-btn pm-btn-primary" type="button"><i class="bi bi-play-circle"></i> Run Payroll</button>
</div>
</div>
<div class="pm-content">
<!-- HERO STATS ROW -->
<div class="row g-3">
<div class="col-lg-4">
<div class="pm-card pm-card-accent" style="min-height:170px">
<p style="margin:0;font-size:12px;color:rgba(255,255,255,.78)">Next payroll cycle is
                                approaching <span style="color:#86efac">●</span></p>
<div class="pm-stat-value" style="margin:8px 0;color:#fff">28 Jun 2025</div>
<p style="margin:0;font-size:12px;color:rgba(255,255,255,.78)">June 2025 Regular Salary.
                                Requires CFO approval for execution over KES 1M.</p>
<div class="d-flex flex-wrap mt-3" style="gap:8px">
<button (click)="openModal('p34_runPayrollModal')" class="pm-btn pm-btn-sm" style="background:#fff;color:var(--pm-primary)" type="button">Preview &amp; Run</button>
<button (click)="openModal('p34_schedulePayrollModal')" class="pm-btn pm-btn-sm" style="background:rgba(255,255,255,.12);border-color:rgba(255,255,255,.22);color:#fff" type="button">Schedule</button>
</div>
</div>
</div>
<div class="col-lg-2 col-md-4 col-6">
<div class="pm-card" style="min-height:170px">
<p class="pm-stat-label" style="color:var(--pm-warning)">EST. TOTAL COST</p>
<div class="pm-stat-value" style="margin:6px 0">KES 4.2M</div>
<span class="pm-badge pm-badge-warning"><i class="bi bi-exclamation-triangle"></i> Review
                                budget</span>
<div class="mt-3" style="font-size:11px;color:var(--pm-muted)">
<div class="d-flex justify-content-between mb-1"><span>Gross Pay</span><span>3.1M</span>
</div>
<div class="d-flex justify-content-between mb-1"><span>Employer
                                        Tax</span><span>0.6M</span></div>
<div class="d-flex justify-content-between"><span>Allowances</span><span>0.5M</span>
</div>
</div>
</div>
</div>
<div class="col-lg-3 col-md-4 col-6">
<div class="pm-card" style="min-height:170px">
<p class="pm-stat-label" style="color:var(--pm-info)">ACTIVE EMPLOYEES</p>
<div class="pm-stat-value" style="margin:6px 0">142</div>
<span class="pm-badge pm-badge-success"><i class="bi bi-arrow-up-right"></i> +3 this
                                month</span>
<div class="mt-3">
<div class="avatar-group">
<div class="pm-avatar" style="background:#EF4444">JS</div>
<div class="pm-avatar" style="background:#3B82F6">MK</div>
<div class="pm-avatar" style="background:#10B981">AO</div>
<div class="pm-avatar" style="background:#8B5CF6">WN</div>
<div class="pm-avatar" style="background:var(--pm-surface-2);color:var(--pm-ink-soft);font-size:10px">
                                        +138</div>
</div>
</div>
</div>
</div>
<div class="col-lg-3 col-md-4">
<div class="pm-card" style="min-height:170px;border-left:3px solid var(--pm-accent)">
<p class="pm-stat-label" style="color:var(--pm-accent)">COMPLIANCE HEALTH</p>
<div class="pm-stat-value" style="margin:6px 0">98%</div>
<span class="pm-badge pm-badge-warning"><i class="bi bi-shield-exclamation"></i> 3 Missing
                                PINs</span>
<div class="mt-2" style="font-size:12px;color:var(--pm-ink-soft)">
<div>KRA P10: <strong style="color:var(--pm-accent)">Ready to file</strong></div>
<div>SHIF/NSSF: <strong style="color:var(--pm-warning)">Updating specs</strong></div>
</div>
</div>
</div>
</div>
<!-- ATTENTION / SUGGESTIONS / QUICK ACTIONS -->
<div class="row g-3">
<div class="col-lg-4">
<div class="pm-card">
<div class="d-flex justify-content-between align-items-center mb-3">
