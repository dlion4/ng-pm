<div class="col-md-5">
<div class="p-3 border rounded" style="background:var(--pm-surface-2)">
<h6 style="font-size:13px;font-weight:700">Dispute Details</h6>
<div class="d-flex justify-content-between mb-1" style="font-size:12px"><span class="text-muted">ID</span><strong>CB-20250627-01</strong></div>
<div class="d-flex justify-content-between mb-1" style="font-size:12px"><span class="text-muted">Amount</span><strong style="color:var(--pm-danger)">KES
                                        12,500</strong></div>
