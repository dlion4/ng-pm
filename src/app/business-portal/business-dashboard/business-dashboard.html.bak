                        Offboarding</button></div>
</div>
</div>
</div><div (click)="closeModal('p34_quickActionModal')" [attr.aria-hidden]="isModalOpen('p34_quickActionModal') ? null : 'true'" [attr.aria-modal]="isModalOpen('p34_quickActionModal') ? 'true' : null" [class.show]="isModalOpen('p34_quickActionModal')" [style.display]="isModalOpen('p34_quickActionModal') ? 'block' : 'none'" class="modal fade" id="p34_quickActionModal" tabindex="-1">
<div (click)="$event.stopPropagation()" class="modal-dialog modal-dialog-centered">
<div class="modal-content">
<div class="modal-header">
