                                    </div>
</div><button (click)="openModal('p34_editEmployeeModal')" class="pm-btn pm-btn-sm" type="button">Update</button>
</div>
</div>
</div>
<div class="col-lg-4">
<div class="pm-card">
<div class="d-flex justify-content-between align-items-center mb-3">
<h3 class="pm-section-title">Compliance &amp; Tax Alerts</h3><span class="pm-badge pm-badge-info"><i class="bi bi-bank"></i> KRA</span>
</div>
<div class="feed-item">
<div class="pm-icon-circle" style="background:var(--pm-accent-soft);color:var(--pm-accent);font-size:12px">P9
                                </div>
<div style="flex:1">
<div style="font-weight:600;font-size:13px">Generate P9A Certificates</div>
<div style="font-size:11px;color:var(--pm-muted)">Annual tax certificates ready for
                                        2024</div>
</div><button (click)="openModal('p34_annualP9Modal')" class="pm-btn pm-btn-sm" type="button">Generate</button>
</div>
<div class="feed-item">
<div class="pm-icon-circle" style="background:var(--pm-info-soft);color:var(--pm-info);font-size:12px">SH</div>
<div style="flex:1">
<div style="font-weight:600;font-size:13px">SHIF Deduction Active</div>
<div style="font-size:11px;color:var(--pm-muted)">2.75% applied per new regulations
                                    </div>
</div><button (click)="openModal('p34_taxConfigModal')" class="pm-btn pm-btn-sm" type="button">Verify</button>
</div>
<div class="feed-item">
