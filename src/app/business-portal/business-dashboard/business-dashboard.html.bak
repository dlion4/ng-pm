</div><div (click)="closeModal('p34_manageBenefitsModal')" [attr.aria-hidden]="isModalOpen('p34_manageBenefitsModal') ? null : 'true'" [attr.aria-modal]="isModalOpen('p34_manageBenefitsModal') ? 'true' : null" [class.show]="isModalOpen('p34_manageBenefitsModal')" [style.display]="isModalOpen('p34_manageBenefitsModal') ? 'block' : 'none'" class="modal fade" id="p34_manageBenefitsModal" tabindex="-1">
