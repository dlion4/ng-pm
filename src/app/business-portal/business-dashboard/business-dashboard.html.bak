                        Import</button></div>
</div>
</div>
</div><div (click)="closeModal('p34_taxConfigModal')" [attr.aria-hidden]="isModalOpen('p34_taxConfigModal') ? null : 'true'" [attr.aria-modal]="isModalOpen('p34_taxConfigModal') ? 'true' : null" [class.show]="isModalOpen('p34_taxConfigModal')" [style.display]="isModalOpen('p34_taxConfigModal') ? 'block' : 'none'" class="modal fade" id="p34_taxConfigModal" tabindex="-1">
