</div><!-- end content -->
</section><section class="paymo-page-modals" id="p31_modals"><div (click)="closeModal('p31_newInvoiceModal')" [attr.aria-hidden]="isModalOpen('p31_newInvoiceModal') ? null : 'true'" [attr.aria-modal]="isModalOpen('p31_newInvoiceModal') ? 'true' : null" [class.show]="isModalOpen('p31_newInvoiceModal')" [style.display]="isModalOpen('p31_newInvoiceModal') ? 'block' : 'none'" class="modal fade" id="p31_newInvoiceModal" tabindex="-1">
<div (click)="$event.stopPropagation()" class="modal-dialog modal-dialog-centered">
<div class="modal-content">
<div class="modal-header">
