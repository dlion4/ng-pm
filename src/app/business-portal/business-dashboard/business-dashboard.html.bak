<!-- SECTION 3.4.3 & 3.4.4 — Compliance, Reports & Employee Self-Service -->
<div class="row g-3">
<div class="col-lg-6">
<div class="pm-card" style="height:100%">
<div class="d-flex justify-content-between align-items-center mb-3">
<h3 class="pm-section-title"><i class="bi bi-file-earmark-check-fill" style="color:var(--pm-danger)"></i> 3.4.3 — Payslip &amp; Compliance</h3><button (click)="openModal('p34_generateReportsModal')" class="pm-btn pm-btn-sm" type="button">Export
                                    All</button>
</div>
<p class="pm-section-sub mb-3">Generate automated payslips, file KRA P10, issue P9A
                                certificates, and export SHIF/NSSF returns.</p>
<div class="row g-2">
<div class="col-6">
<div (click)="openModal('p34_generateReportsModal')" class="p-3 border rounded text-center" style="cursor:pointer"><i class="bi bi-bank text-danger d-block mb-1" style="font-size:24px"></i><strong style="font-size:13px">KRA P10 /
                                            P9A</strong>
<div style="font-size:11px;color:var(--pm-muted)">iTax Ready ZIP</div>
</div>
</div>
<div class="col-6">
<div (click)="openModal('p34_generateReportsModal')" class="p-3 border rounded text-center" style="cursor:pointer"><i class="bi bi-heart-pulse text-info d-block mb-1" style="font-size:24px"></i><strong style="font-size:13px">SHIF &amp;
                                            NSSF</strong>
<div style="font-size:11px;color:var(--pm-muted)">Portal CSV formats</div>
</div>
</div>
<div class="col-6">
<div (click)="openModal('p34_sendPayslipsModal')" class="p-3 border rounded text-center" style="cursor:pointer"><i class="bi bi-envelope text-purple d-block mb-1" style="font-size:24px;color:var(--pm-purple)"></i><strong style="font-size:13px">Send Payslips</strong>
<div style="font-size:11px;color:var(--pm-muted)">Email &amp; WhatsApp</div>
</div>
</div>
<div class="col-6">
<div (click)="openModal('p34_taxConfigModal')" class="p-3 border rounded text-center" style="cursor:pointer"><i class="bi bi-sliders text-warning d-block mb-1" style="font-size:24px"></i><strong style="font-size:13px">Tax
                                            Engine</strong>
<div style="font-size:11px;color:var(--pm-muted)">Update bands/rates</div>
</div>
</div>
</div>
</div>
</div>
<div class="col-lg-6">
<div class="pm-card" style="height:100%">
<div class="d-flex justify-content-between align-items-center mb-3">
<h3 class="pm-section-title"><i class="bi bi-phone-flip" style="color:var(--pm-accent)"></i> 3.4.4 — Employee Self-Service</h3><button (click)="openModal('p34_employeeSelfServiceModal')" class="pm-btn pm-btn-sm" type="button">Simulate
                                    ESS</button>
</div>
<p class="pm-section-sub mb-3">Review leave requests, expense claims, and profile updates
                                submitted by employees.</p>
<div class="business-block p-0" style="background:transparent">
<div class="status-row">
<div>
<div class="d-flex align-items-center gap-2"><span class="pm-badge pm-badge-warning">Leave</span> <strong>John
                                                Smith</strong></div>
<div style="font-size:11px;color:var(--pm-muted);margin-top:2px">Annual Leave: 5
                                            days (Jul 1 - Jul 5)</div>
</div><button (click)="openModal('p34_leaveApprovalModal')" class="pm-btn pm-btn-sm" type="button">Review</button>
</div>
<div class="status-row">
<div>
<div class="d-flex align-items-center gap-2"><span class="pm-badge pm-badge-info">Expense</span> <strong>Mary
                                                Kamau</strong></div>
<div style="font-size:11px;color:var(--pm-muted);margin-top:2px">Client Lunch:
                                            KES 4,500 (Receipt attached)</div>
</div><button (click)="openModal('p34_expenseApprovalModal')" class="pm-btn pm-btn-sm" type="button">Review</button>
</div>
<div class="status-row">
<div>
<div class="d-flex align-items-center gap-2"><span class="pm-badge pm-badge-purple">Profile</span> <strong>Ali
                                                Omondi</strong></div>
<div style="font-size:11px;color:var(--pm-muted);margin-top:2px">Updated M-Pesa
                                            number for salary</div>
</div><button (click)="openModal('p34_quickActionModal')" class="pm-btn pm-btn-sm" type="button">View</button>
</div>
</div>
</div>
</div>
</div>
</div>
</section><section class="paymo-page-modals" id="p34_modals"><div (click)="closeModal('p34_runPayrollModal')" [attr.aria-hidden]="isModalOpen('p34_runPayrollModal') ? null : 'true'" [attr.aria-modal]="isModalOpen('p34_runPayrollModal') ? 'true' : null" [class.show]="isModalOpen('p34_runPayrollModal')" [style.display]="isModalOpen('p34_runPayrollModal') ? 'block' : 'none'" class="modal fade" id="p34_runPayrollModal" tabindex="-1">
<div (click)="$event.stopPropagation()" class="modal-dialog modal-xl modal-dialog-centered">
<div class="modal-content">
<div class="modal-header">
<h5 class="modal-title"><i class="bi bi-play-circle text-primary me-2"></i>Execute Payroll Run</h5>
<button (click)="closeModal('p34_runPayrollModal')" class="btn-close" data-bs-dismiss="modal" type="button"></button>
</div>
<div class="modal-body">
<div class="pm-stepper" id="p34_runPayrollStepper">
  @for (step of stepperItems('p34_rp'); track step.index) {
    <div class="pm-step" [class.completed]="step.index < currentStep('p34_rp')" [class.active]="step.index === currentStep('p34_rp')">
      <div class="pm-step-num">@if (step.index < currentStep('p34_rp')) { <i class="bi bi-check"></i> } @else { {{ step.index }} }</div>
}
      @if (step.label) { <div class="pm-step-label">{{ step.label }}</div> } {
    </div>
}
    @if (!step.last) { <div class="pm-step-line"></div> } {
  }
</div>
<div [class.active]="isStep('p34_rp', 1)" [style.display]="isStep('p34_rp', 1) ? 'block' : 'none'" class="fade-step active" id="p34_rpStep1">
<h6 style="font-weight:700;margin-bottom:16px">Step 1: Define Period &amp; Scope</h6>
<div class="row g-3">
<div class="col-md-6"><label class="pm-form-label">Payroll Period</label><input class="pm-form-control" type="month" value="2025-06"/></div>
<div class="col-md-6"><label class="pm-form-label">Run Type</label><select class="pm-form-control">
<option>Regular Monthly Salary</option>
<option>Bonus/Commission</option>
<option>Arrears</option>
<option>Off-cycle Payment</option>
</select></div>
<div class="col-md-6"><label class="pm-form-label">Target Departments</label><select class="pm-form-control">
<option>All Departments</option>
<option>Sales Only</option>
<option>Engineering Only</option>
</select></div>
<div class="col-md-6"><label class="pm-form-label">Include Approved Expenses?</label><select class="pm-form-control">
<option>Yes, add to net pay</option>
<option>No, process separately</option>
</select></div>
</div>
<div class="p-3 rounded mt-3" style="background:var(--pm-warning-soft);font-size:12px"><i class="bi bi-info-circle me-1"></i> Ensure all leave and expense approvals are completed
                            before generating the preview.</div>
</div>
<div [class.active]="isStep('p34_rp', 2)" [style.display]="isStep('p34_rp', 2) ? 'block' : 'none'" class="fade-step" id="p34_rpStep2">
<h6 style="font-weight:700;margin-bottom:16px">Step 2: Preview Gross-to-Net Summary</h6>
<div class="row g-3 mb-3">
<div class="col-md-3">
<div class="p-3 border rounded text-center">
<div style="font-size:11px;color:var(--pm-muted)">Total Gross</div>
<h4 style="font-size:18px;font-weight:700;margin:4px 0 0">KES 6,105,000</h4>
</div>
</div>
<div class="col-md-3">
<div class="p-3 border rounded text-center">
<div style="font-size:11px;color:var(--pm-muted)">PAYE Tax</div>
<h4 style="font-size:18px;font-weight:700;margin:4px 0 0;color:var(--pm-danger)">KES
                                        1,280,000</h4>
</div>
</div>
<div class="col-md-3">
<div class="p-3 border rounded text-center">
<div style="font-size:11px;color:var(--pm-muted)">SHIF + NSSF + Levy</div>
<h4 style="font-size:18px;font-weight:700;margin:4px 0 0;color:var(--pm-danger)">KES
                                        625,000</h4>
</div>
</div>
<div class="col-md-3">
<div class="p-3 border rounded text-center" style="background:var(--pm-accent-soft);border-color:var(--pm-accent)!important">
<div style="font-size:11px;color:#047857">Total Net Payout</div>
<h4 style="font-size:18px;font-weight:700;margin:4px 0 0;color:var(--pm-accent)">KES
                                        4,200,000</h4>
</div>
</div>
</div>
<div class="table-responsive" style="max-height:250px;overflow-y:auto">
<table class="pm-table">
<thead>
<tr>
<th>Employee</th>
<th>Gross Pay</th>
<th>PAYE</th>
<th>Statutory</th>
<th>Net Pay</th>
</tr>
</thead>
<tbody>
<tr>
<td>John Smith</td>
<td>KES 135,000</td>
<td>KES 24,000</td>
<td>KES 10,250</td>
<td><strong>KES 100,750</strong></td>
</tr>
<tr>
<td>Mary Kamau</td>
<td>KES 90,000</td>
<td>KES 13,000</td>
<td>KES 8,800</td>
<td><strong>KES 68,200</strong></td>
</tr>
<tr>
<td>Ali Omondi</td>
<td>KES 180,000</td>
<td>KES 42,000</td>
<td>KES 14,100</td>
<td><strong>KES 123,900</strong></td>
</tr>
<tr>
<td>Wanjiku Ndungu</td>
<td>KES 47,000</td>
<td>KES 3,500</td>
<td>KES 2,800</td>
<td><strong>KES 40,700</strong></td>
</tr>
</tbody>
</table>
</div>
</div>
<div [class.active]="isStep('p34_rp', 3)" [style.display]="isStep('p34_rp', 3) ? 'block' : 'none'" class="fade-step" id="p34_rpStep3">
<h6 style="font-weight:700;margin-bottom:16px">Step 3: Execution Settings &amp; Submit</h6>
<div class="mb-3"><label class="pm-form-label">Funding Account</label><select class="pm-form-control">
<option>PayMo Business Wallet (Available: KES 12.5M)</option>
<option>Equity Bank Main (Link)</option>
</select></div>
<div class="mb-3"><label class="pm-form-label">Disbursement Methods</label>
<div class="form-check mb-1"><input checked="" class="form-check-input" disabled="" type="checkbox"/><label class="form-check-label">M-Pesa B2C (For employees with M-Pesa
                                    preference)</label></div>
<div class="form-check"><input checked="" class="form-check-input" disabled="" type="checkbox"/><label class="form-check-label">PesaLink/EFT (For employees with Bank
                                    preference)</label></div>
</div>
<div class="mb-3"><label class="pm-form-label">Execution Schedule</label><select class="pm-form-control">
<option>Immediately upon final approval</option>
<option>Schedule for 28 Jun 2025, 08:00 AM</option>
</select></div>
<div class="p-3 rounded" style="background:var(--pm-purple-soft);font-size:13px"><i class="bi bi-shield-lock me-1"></i> Because total net exceeds KES 1M, this run will
                            require Level 2 (Director/CFO) approval before funds are released.</div>
</div>
<div [class.active]="isStep('p34_rp', 4)" [style.display]="isStep('p34_rp', 4) ? 'block' : 'none'" class="fade-step" id="p34_rpStep4">
<div class="pm-receipt">
<div class="receipt-icon"><i class="bi bi-check2-circle"></i></div>
<h5 style="font-weight:700;color:var(--pm-accent)">Payroll Submitted for Approval</h5>
<p style="font-size:13px;color:var(--pm-ink-soft)">Batch PRL-2025-06-REG has been routed to
                                the CFO queue.</p>
<div class="p-3 rounded text-start mt-3 mx-auto" style="background:#fff;max-width:400px;font-size:13px">
<div class="d-flex justify-content-between mb-2"><span class="text-muted">Total
                                        Net</span><strong>KES 4,200,000</strong></div>
<div class="d-flex justify-content-between mb-2"><span class="text-muted">Employees</span><strong>142</strong></div>
<div class="d-flex justify-content-between"><span class="text-muted">Status</span><span class="pm-badge pm-badge-warning">Pending L2</span></div>
</div>
</div>
</div>
</div>
<div class="modal-footer" id="p34_rpFooter">
<button (click)="closeModal('p34_runPayrollModal')" class="pm-btn" data-bs-dismiss="modal" type="button">Cancel</button>
<button (click)="nextStepFlow('p34_rp', 4, 'p34_runPayrollModal', 'Payroll batch generated and submitted.', '')" class="pm-btn pm-btn-primary" id="p34_rpNextBtn" type="button">Continue <i class="bi bi-arrow-right"></i></button>
</div>
</div>
</div>
</div><div (click)="closeModal('p34_addEmployeeModal')" [attr.aria-hidden]="isModalOpen('p34_addEmployeeModal') ? null : 'true'" [attr.aria-modal]="isModalOpen('p34_addEmployeeModal') ? 'true' : null" [class.show]="isModalOpen('p34_addEmployeeModal')" [style.display]="isModalOpen('p34_addEmployeeModal') ? 'block' : 'none'" class="modal fade" id="p34_addEmployeeModal" tabindex="-1">
<div (click)="$event.stopPropagation()" class="modal-dialog modal-lg modal-dialog-centered">
<div class="modal-content">
<div class="modal-header">
<h5 class="modal-title"><i class="bi bi-person-plus text-accent me-2"></i>Onboard New Employee</h5>
<button (click)="closeModal('p34_addEmployeeModal')" class="btn-close" data-bs-dismiss="modal" type="button"></button>
</div>
<div class="modal-body">
<div class="pm-stepper" id="p34_empStepper">
  @for (step of stepperItems('p34_emp'); track step.index) {
    <div class="pm-step" [class.completed]="step.index < currentStep('p34_emp')" [class.active]="step.index === currentStep('p34_emp')">
      <div class="pm-step-num">@if (step.index < currentStep('p34_emp')) { <i class="bi bi-check"></i> } @else { {{ step.index }} }</div>
}
      @if (step.label) { <div class="pm-step-label">{{ step.label }}</div> } {
    </div>
}
    @if (!step.last) { <div class="pm-step-line"></div> } {
  }
</div>
<div [class.active]="isStep('p34_emp', 1)" [style.display]="isStep('p34_emp', 1) ? 'block' : 'none'" class="fade-step active" id="p34_empStep1">
