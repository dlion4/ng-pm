
<div class="paymo-angular-page">
  @if (toastMessage) {
    <div class="pm-toast" role="status">
      <i class="bi bi-check-circle-fill"></i>
      <span>{{ toastMessage }}</span>
      <button type="button" class="pm-toast-close" (click)="clearToast()">×</button>
    </div>

<!-- ===== Angularized body content from source 3.1.html ===== -->
<div><section class="paymo-page-source" id="p31_page">
<!-- HEADER -->

<div class="pm-page-bar">
<div>
<div class="pm-breadcrumb"><a (click)="notify('Link action handled')" role="button" tabindex="0">Business Portal</a> / <strong>Command Center</strong></div>
<h2 style="font-family:var(--pm-font-display);font-size:22px;font-weight:700;margin:0">PAGE 3.1 —
                        Business Command Center</h2>
<p class="pm-section-sub">Consolidated overview of collections, payroll, invoices, and business
                        health.</p>
</div>
<div class="d-flex gap-2 flex-wrap">
<button (click)="openModal('p31_consolidatedReportModal')" class="pm-btn" type="button"><i class="bi bi-file-earmark-bar-graph"></i> Reports</button>
<button (click)="openModal('p31_inviteUserModal')" class="pm-btn" type="button"><i class="bi bi-person-plus"></i> Add
                        User</button>
<button (click)="openModal('p31_newInvoiceModal')" class="pm-btn pm-btn-dark" type="button"><i class="bi bi-plus-lg"></i> New Invoice</button>
</div>
</div>
<div class="pm-content">
<!-- HERO ROW: 3.1.1 Key Metrics -->
<div class="row g-3">
<div class="col-lg-3 col-md-6">
<div (click)="openModal('p31_cashFlowDetailsModal')" class="pm-card pm-card-biz" style="cursor:pointer">
<div class="pm-stat-label" style="color:var(--pm-muted)">AVAILABLE CASH POSITION</div>
<div class="pm-stat-value">KES 2.45M</div>
<div class="d-flex align-items-center gap-2 mt-2" style="font-size:12px;color:rgba(255,255,255,0.7)">
<span class="pm-badge pm-badge-dark"><i class="bi bi-bank"></i> + KES 850K in
                                    transit</span>
</div>
</div>
</div>
<div class="col-lg-3 col-md-6">
<div (click)="openModal('p31_revenueDetailsModal')" class="pm-card" style="cursor:pointer">
<div class="pm-stat-label">MONTHLY REVENUE</div>
<div class="pm-stat-value" style="color:var(--pm-ink)">KES 1.82M</div>
<div class="d-flex align-items-center justify-content-between mt-2">
<span class="pm-badge pm-badge-success"><i class="bi bi-graph-up-arrow"></i> +12% vs
                                    last month</span>
<span style="font-size:11px;color:var(--pm-muted)">Target: 2.0M</span>
</div>
</div>
</div>
<div class="col-lg-3 col-md-6">
<div (click)="openModal('p31_expenseDetailsModal')" class="pm-card" style="cursor:pointer">
<div class="pm-stat-label">MONTHLY EXPENSES</div>
<div class="pm-stat-value" style="color:var(--pm-danger)">KES 940K</div>
<div class="mt-2">
<div class="d-flex justify-content-between mb-1" style="font-size:11px;color:var(--pm-muted)"><span>Payroll:
                                        450K</span><span>Supplier: 320K</span></div>
<div class="pm-progress">
<div class="pm-progress-bar" style="width:65%;background:var(--pm-danger)"></div>
</div>
</div>
</div>
</div>
<div class="col-lg-3 col-md-6">
<div class="pm-card" style="border-left:3px solid var(--pm-warning)">
<div class="pm-stat-label" style="color:var(--pm-warning)">PENDING APPROVALS</div>
<div class="pm-stat-value">5 Actionable</div>
<div class="d-flex gap-2 mt-2">
<button (click)="openModal('p31_pendingApprovalsModal')" class="pm-btn pm-btn-sm" style="flex:1" type="button">Review Queue</button>
</div>
</div>
</div>
</div>
<!-- ATTENTION & QUICK ACTIONS -->
<div class="row g-3">
<div class="col-lg-8">
<div class="pm-card h-100">
<div class="d-flex justify-content-between align-items-center mb-3">
<h3 class="pm-section-title">Attention &amp; Operations</h3>
<button (click)="openModal('p31_notificationsModal')" class="pm-btn pm-btn-sm" type="button">View
                                    all</button>
</div>
<div class="feed-item">
<div class="pm-icon-circle" style="background:var(--pm-warning-soft);color:var(--pm-warning)"><i class="bi bi-people"></i></div>
<div style="flex:1">
<div style="font-weight:600;font-size:14px">Payroll Run: October 2025 Requires
                                        Approval</div>
<div style="font-size:12px;color:var(--pm-muted)">24 Employees · Total KES 450,500 ·
                                        Maker: HR Dept</div>
</div>
<button (click)="openModal('p31_runPayrollModal')" class="pm-btn pm-btn-sm pm-btn-primary" type="button">Review &amp; Approve</button>
</div>
<div class="feed-item">
<div class="pm-icon-circle" style="background:var(--pm-danger-soft);color:var(--pm-danger)"><i class="bi bi-shield-exclamation"></i></div>
<div style="flex:1">
<div style="font-weight:600;font-size:14px">KYB Update Required: Annual Returns
                                    </div>
<div style="font-size:12px;color:var(--pm-muted)">Upload 2024 CR12 to maintain Tier
                                        3 limit (Overdue in 5 days)</div>
</div>
<button (click)="openModal('p31_kybUploadModal')" class="pm-btn pm-btn-sm pm-btn-danger" type="button">Upload Doc</button>
</div>
<div class="feed-item">
<div class="pm-icon-circle" style="background:var(--pm-info-soft);color:var(--pm-info)">
<i class="bi bi-receipt"></i></div>
<div style="flex:1">
<div style="font-weight:600;font-size:14px">3 Invoices Aging > 60 Days</div>
<div style="font-size:12px;color:var(--pm-muted)">Total outstanding: KES 145,000 ·
                                        Action recommended</div>
</div>
<button (click)="openModal('p31_agingInvoicesModal')" class="pm-btn pm-btn-sm" type="button">Send
                                    Reminders</button>
</div>
</div>
</div>
<div class="col-lg-4">
<div class="pm-card h-100">
<h3 class="pm-section-title mb-3">Quick Actions</h3>
<div class="quick-action-grid">
<div (click)="openModal('p31_newInvoiceModal')" class="quick-action-btn"><i class="bi bi-receipt text-primary"></i> Invoice</div>
<div (click)="openModal('p31_runPayrollModal')" class="quick-action-btn"><i class="bi bi-people text-success"></i> Payroll</div>
<div (click)="openModal('p31_disburseFundsModal')" class="quick-action-btn"><i class="bi bi-send text-info"></i> Disburse</div>
<div (click)="openModal('p31_interCompanyTransferModal')" class="quick-action-btn"><i class="bi bi-arrow-left-right text-purple" style="color:var(--pm-purple)"></i>
                                    Transfer</div>
<div (click)="openModal('p31_inviteUserModal')" class="quick-action-btn"><i class="bi bi-person-plus text-warning"></i> Add Team</div>
<div (click)="openModal('p31_kybUploadModal')" class="quick-action-btn"><i class="bi bi-shield-check text-secondary"></i> KYB</div>
</div>
<div class="p-3 mt-3 rounded" style="background:var(--pm-accent-soft);border:1px solid rgba(16,185,129,0.2)">
<div style="font-size:12px;font-weight:700;color:#047857;margin-bottom:4px"><i class="bi bi-stars"></i> Smart Suggestion</div>
<div style="font-size:12px;color:#065F46">You have KES 1.2M idle cash. Consider moving
                                    500K to the Money Market Fund to earn ~11% p.a.</div>
<button (click)="openModal('p31_interCompanyTransferModal')" class="pm-btn pm-btn-sm mt-2 w-100" style="background:#fff;color:#047857;border-color:rgba(16,185,129,0.3)" type="button">View Investment Options</button>
</div>
</div>
</div>
</div>
<!-- SECTION 3.1.1: OVERVIEW DASHBOARD -->
<div class="pm-card">
<div class="d-flex justify-content-between align-items-center mb-4">
<div>
<h3 class="pm-section-title text-primary"><i class="bi bi-graph-up"></i> 3.1.1 — Business
                                Overview Dashboard</h3>
<p class="pm-section-sub">Collections vs Targets, Aging Invoices, and Disbursement Rates.
                            </p>
</div>
<button (click)="openModal('p31_collectionTargetModal')" class="pm-btn pm-btn-sm" type="button"><i class="bi bi-sliders"></i> Edit Targets</button>
</div>
<div class="row g-4">
<div class="col-lg-6">
<div class="status-block">
<h4 style="font-size:14px;font-weight:700;margin:0 0 8px">Collections vs Target (Last 6
                                    Months)</h4>
<div class="chart-container">
<div (click)="openModal('p31_revenueDetailsModal')" class="chart-bar-wrapper">
<div style="position:relative;width:40px;height:100%;margin:0 auto">
<div class="chart-bar target" style="height:60%"></div>
<div class="chart-bar actual" style="height:55%;background:var(--pm-muted)">
</div>
</div>
<div class="chart-label">May</div>
</div>
<div (click)="openModal('p31_revenueDetailsModal')" class="chart-bar-wrapper">
<div style="position:relative;width:40px;height:100%;margin:0 auto">
<div class="chart-bar target" style="height:65%"></div>
<div class="chart-bar actual" style="height:60%;background:var(--pm-muted)">
</div>
</div>
<div class="chart-label">Jun</div>
</div>
<div (click)="openModal('p31_revenueDetailsModal')" class="chart-bar-wrapper">
<div style="position:relative;width:40px;height:100%;margin:0 auto">
<div class="chart-bar target" style="height:70%"></div>
<div class="chart-bar actual" style="height:75%;background:var(--pm-accent)"></div>
</div>
<div class="chart-label">Jul</div>
</div>
<div (click)="openModal('p31_revenueDetailsModal')" class="chart-bar-wrapper">
<div style="position:relative;width:40px;height:100%;margin:0 auto">
<div class="chart-bar target" style="height:75%"></div>
<div class="chart-bar actual" style="height:68%;background:var(--pm-warning)"></div>
</div>
<div class="chart-label">Aug</div>
</div>
<div (click)="openModal('p31_revenueDetailsModal')" class="chart-bar-wrapper">
<div style="position:relative;width:40px;height:100%;margin:0 auto">
<div class="chart-bar target" style="height:80%"></div>
<div class="chart-bar actual" style="height:85%;background:var(--pm-accent)"></div>
</div>
<div class="chart-label">Sep</div>
</div>
<div (click)="openModal('p31_revenueDetailsModal')" class="chart-bar-wrapper">
<div style="position:relative;width:40px;height:100%;margin:0 auto">
<div class="chart-bar target" style="height:85%"></div>
<div class="chart-bar actual" style="height:95%;background:var(--pm-primary)"></div>
</div>
<div class="chart-label">Oct</div>
</div>
</div>
<div class="d-flex justify-content-center gap-3 mt-3" style="font-size:11px">
<span class="d-flex align-items-center gap-1">
<div style="width:10px;height:10px;background:var(--pm-border-2);border-radius:2px">
</div> Target
                                    </span>
<span class="d-flex align-items-center gap-1">
<div style="width:10px;height:10px;background:var(--pm-primary);border-radius:2px">
</div> Actual
                                    </span>
</div>
</div>
</div>
<div class="col-lg-6">
<div class="status-block">
<h4 style="font-size:14px;font-weight:700;margin:0 0 16px">Outstanding Invoices Aging
                                </h4>
<div class="d-flex gap-2 h-100">
<div (click)="openModal('p31_agingInvoicesModal')" class="p-3 rounded flex-1 text-center d-flex flex-column justify-content-center" style="background:var(--pm-success-soft, #D1FAE5);cursor:pointer">
<div style="font-size:12px;color:#047857;font-weight:600">0-30 Days</div>
<div style="font-size:18px;font-weight:700;color:#065F46">KES 420K</div>
</div>
<div (click)="openModal('p31_agingInvoicesModal')" class="p-3 rounded flex-1 text-center d-flex flex-column justify-content-center" style="background:var(--pm-warning-soft);cursor:pointer">
<div style="font-size:12px;color:#B45309;font-weight:600">31-60 Days</div>
<div style="font-size:18px;font-weight:700;color:#92400E">KES 185K</div>
</div>
<div (click)="openModal('p31_agingInvoicesModal')" class="p-3 rounded flex-1 text-center d-flex flex-column justify-content-center" style="background:var(--pm-danger-soft);cursor:pointer">
<div style="font-size:12px;color:#DC2626;font-weight:600">61-90+ Days</div>
<div style="font-size:18px;font-weight:700;color:#991B1B">KES 145K</div>
</div>
</div>
<div class="mt-3">
<button (click)="openModal('p31_agingInvoicesModal')" class="pm-btn pm-btn-sm w-100" type="button"><i class="bi bi-envelope"></i> Send Auto-Reminders to All Overdue</button>
</div>
</div>
</div>
</div>
</div>
<!-- ROW: PROFILE & MULTI-BIZ -->
<div class="row g-3">
<!-- SECTION 3.1.2: BUSINESS PROFILE -->
<div class="col-lg-6">
<div class="pm-card h-100">
<div class="d-flex justify-content-between align-items-center mb-3">
<div>
<h3 class="pm-section-title text-info"><i class="bi bi-building-check"></i> 3.1.2 —
                                        Business Profile &amp; Settings</h3>
<p class="pm-section-sub">KYC/KYB status and corporate details.</p>
</div>
<button (click)="openModal('p31_businessSettingsModal')" class="pm-btn pm-btn-sm" type="button"><i class="bi bi-pencil"></i></button>
</div>
<div class="row g-2 mb-3">
<div class="col-sm-6">
<div class="p-2 border rounded">
<div style="font-size:11px;color:var(--pm-muted)">Company Name</div>
<div style="font-size:13px;font-weight:600">TechSolutions Ltd</div>
</div>
</div>
<div class="col-sm-6">
<div class="p-2 border rounded">
<div style="font-size:11px;color:var(--pm-muted)">KRA PIN</div>
<div style="font-size:13px;font-weight:600;font-family:monospace">P051234567M
                                        </div>
</div>
</div>
<div class="col-sm-6">
<div class="p-2 border rounded">
<div style="font-size:11px;color:var(--pm-muted)">Registration Number</div>
<div style="font-size:13px;font-weight:600">PVT-2022/10492</div>
</div>
</div>
<div class="col-sm-6">
<div class="p-2 border rounded">
<div style="font-size:11px;color:var(--pm-muted)">Business Type / Sector</div>
<div style="font-size:13px;font-weight:600">LLC · IT Services</div>
</div>
</div>
</div>
<h4 style="font-size:13px;font-weight:700;margin:0 0 8px">Verification &amp; KYB Status</h4>
<div class="d-flex justify-content-between align-items-center p-2 border-bottom" style="font-size:13px">
<span>Certificate of Incorporation</span>
<span class="pm-badge pm-badge-success"><i class="bi bi-check-circle"></i>
                                    Verified</span>
</div>
<div class="d-flex justify-content-between align-items-center p-2 border-bottom" style="font-size:13px">
<span>KRA PIN Certificate</span>
<span class="pm-badge pm-badge-success"><i class="bi bi-check-circle"></i>
                                    Verified</span>
</div>
<div class="d-flex justify-content-between align-items-center p-2 border-bottom" style="font-size:13px">
<span>Tax Compliance Certificate</span>
<span class="pm-badge pm-badge-success"><i class="bi bi-check-circle"></i> Valid till
                                    Dec 2025</span>
</div>
<div class="d-flex justify-content-between align-items-center p-2" style="font-size:13px">
<span>Annual Returns (CR12)</span>
<span class="pm-badge pm-badge-danger"><i class="bi bi-exclamation-circle"></i> Missing
                                    2024</span>
</div>
<button (click)="openModal('p31_kybUploadModal')" class="pm-btn pm-btn-sm mt-2" type="button">Manage
                                Documents</button>
</div>
</div>
<!-- SECTION 3.1.3: MULTI-BIZ -->
<div class="col-lg-6">
<div class="pm-card h-100">
<div class="d-flex justify-content-between align-items-center mb-3">
<div>
<h3 class="pm-section-title" style="color:var(--pm-purple)"><i class="bi bi-diagram-3"></i> 3.1.3 — Multi-Business Management</h3>
<p class="pm-section-sub">Switch accounts, view consolidated data, inter-company
                                        transfers.</p>
</div>
<button (click)="openModal('p31_switchBusinessModal')" class="pm-btn pm-btn-sm" type="button">Switch</button>
</div>
<div class="p-3 rounded mb-3" style="background:var(--pm-purple-soft)">
<div style="font-size:11px;color:#6D28D9;font-weight:700">CONSOLIDATED GROUP CASH (3
                                    ENTITIES)</div>
<div style="font-size:24px;font-weight:700;color:var(--pm-purple)">KES 12.8M</div>
<div class="mt-2 d-flex gap-2">
<button (click)="openModal('p31_consolidatedReportModal')" class="pm-btn pm-btn-sm" style="border-color:var(--pm-purple);color:var(--pm-purple)" type="button">View Group Report</button>
</div>
</div>
<div class="table-responsive">
<table class="pm-table">
<thead>
<tr>
<th>Entity Name</th>
<th>Role</th>
<th>Cash Bal</th>
<th>Action</th>
</tr>
</thead>
<tbody>
