</div><div (click)="closeModal('p34_annualP9Modal')" [attr.aria-hidden]="isModalOpen('p34_annualP9Modal') ? null : 'true'" [attr.aria-modal]="isModalOpen('p34_annualP9Modal') ? 'true' : null" [class.show]="isModalOpen('p34_annualP9Modal')" [style.display]="isModalOpen('p34_annualP9Modal') ? 'block' : 'none'" class="modal fade" id="p34_annualP9Modal" tabindex="-1">
