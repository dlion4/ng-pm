<div class="d-flex justify-content-between" style="font-size:12px"><span class="text-muted">Deadline</span><strong style="color:var(--pm-danger)">2
                                        days</strong></div>
</div>
</div>
<div class="col-md-7">
<h6 style="font-size:13px;font-weight:700">Action: Defend Chargeback</h6>
<div class="mb-3"><label class="pm-form-label">Defense Evidence</label><select class="pm-form-control">
<option>Proof of delivery / receipt</option>
<option>Customer communication logs</option>
<option>Digital service access logs</option>
</select></div>
<div class="mb-3"><label class="pm-form-label">Upload Documents</label><input class="pm-form-control" multiple="" type="file"/></div>
<div class="mb-3"><label class="pm-form-label">Notes</label><textarea class="pm-form-control" rows="3">Customer signed for the delivery on 25 Jun. Attached is the signed waybill and GPS logs.</textarea>
</div>
</div>
</div>
</div>
<div class="modal-footer"><button (click)="processAction('p32_disputeModal', 'Chargeback accepted. KES 12,500 reversed.', '')" class="pm-btn pm-btn-danger" type="button">Accept
                        Chargeback (Refund)</button><button (click)="processAction('p32_disputeModal', 'Evidence submitted to acquiring bank. Status changed to Reviewing.', '')" class="pm-btn pm-btn-primary" type="button">Submit
                        Evidence</button></div>
</div>
</div>
</div><div (click)="closeModal('p32_txnDetailModal')" [attr.aria-hidden]="isModalOpen('p32_txnDetailModal') ? null : 'true'" [attr.aria-modal]="isModalOpen('p32_txnDetailModal') ? 'true' : null" [class.show]="isModalOpen('p32_txnDetailModal')" [style.display]="isModalOpen('p32_txnDetailModal') ? 'block' : 'none'" class="modal fade resettable" id="p32_txnDetailModal" tabindex="-1">
