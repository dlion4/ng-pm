</div><div (click)="closeModal('p32_settlementModal')" [attr.aria-hidden]="isModalOpen('p32_settlementModal') ? null : 'true'" [attr.aria-modal]="isModalOpen('p32_settlementModal') ? 'true' : null" [class.show]="isModalOpen('p32_settlementModal')" [style.display]="isModalOpen('p32_settlementModal') ? 'block' : 'none'" class="modal fade resettable" id="p32_settlementModal" tabindex="-1">
