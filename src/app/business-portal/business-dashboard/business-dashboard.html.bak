</div><div (click)="closeModal('p34_importEmployeesModal')" [attr.aria-hidden]="isModalOpen('p34_importEmployeesModal') ? null : 'true'" [attr.aria-modal]="isModalOpen('p34_importEmployeesModal') ? 'true' : null" [class.show]="isModalOpen('p34_importEmployeesModal')" [style.display]="isModalOpen('p34_importEmployeesModal') ? 'block' : 'none'" class="modal fade" id="p34_importEmployeesModal" tabindex="-1">
