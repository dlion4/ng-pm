</div>
</div>
</div>
</div><div (click)="closeModal('p34_notificationsModal')" [attr.aria-hidden]="isModalOpen('p34_notificationsModal') ? null : 'true'" [attr.aria-modal]="isModalOpen('p34_notificationsModal') ? 'true' : null" [class.show]="isModalOpen('p34_notificationsModal')" [style.display]="isModalOpen('p34_notificationsModal') ? 'block' : 'none'" class="modal fade" id="p34_notificationsModal" tabindex="-1">
<div (click)="$event.stopPropagation()" class="modal-dialog modal-dialog-centered">
<div class="modal-content">
<div class="modal-header">
<h5 class="modal-title"><i class="bi bi-bell me-2"></i>Payroll Notifications</h5><button (click)="closeModal('p34_notificationsModal')" class="btn-close" data-bs-dismiss="modal" type="button"></button>
</div>
<div class="modal-body" style="max-height:400px;overflow-y:auto">
<div class="p-3 rounded mb-2" style="background:var(--pm-warning-soft);font-size:13px">
<strong>Approve Payroll Run</strong><br/><span style="font-size:11px;color:var(--pm-muted)">PRL-2025-06-REG requires CFO approval before
                            28th.</span></div>
<div class="p-3 rounded mb-2" style="background:var(--pm-danger-soft);font-size:13px">
<strong>Compliance Alert</strong><br/><span style="font-size:11px;color:var(--pm-muted)">3 new
                            hires lack KRA PINs. Fix before running payroll.</span></div>
<div class="p-3 rounded mb-2" style="background:var(--pm-info-soft);font-size:13px"><strong>Expense
                            Claim</strong><br/><span style="font-size:11px;color:var(--pm-muted)">Mary Kamau submitted
                            KES 4,500 expense.</span></div>
<div class="p-3 rounded mb-2" style="background:var(--pm-surface-2);font-size:13px"><strong>Bank
                            Validation</strong><br/><span style="font-size:11px;color:var(--pm-muted)">Wanjiku's account
                            length is invalid.</span></div>
</div>
<div class="modal-footer"><button class="pm-btn pm-btn-sm" type="button">Mark All Read</button><button (click)="closeModal('p34_notificationsModal')" class="pm-btn" data-bs-dismiss="modal" type="button">Close</button></div>
</div>
</div>
</div></section></div>
<div class="modal fade" id="p34_employeeRequestsModal" tabindex="-1" [class.show]="isModalOpen('p34_employeeRequestsModal')" [style.display]="isModalOpen('p34_employeeRequestsModal') ? 'block' : 'none'" [attr.aria-hidden]="isModalOpen('p34_employeeRequestsModal') ? null : 'true'" [attr.aria-modal]="isModalOpen('p34_employeeRequestsModal') ? 'true' : null" (click)="closeModal('p34_employeeRequestsModal')">
  <div class="modal-dialog modal-lg modal-dialog-centered" (click)="$event.stopPropagation()">
    <div class="modal-content">
      <div class="modal-header"><h5 class="modal-title"><i class="bi bi-inbox text-primary me-2"></i>Employee Requests</h5><button type="button" class="btn-close" (click)="closeModal('p34_employeeRequestsModal')"></button></div>
      <div class="modal-body">
        <div class="pm-list-item"><div><strong>Leave Requests</strong><div style="font-size:12px;color:var(--pm-muted)">4 pending approval</div></div><button type="button" class="pm-btn pm-btn-sm" (click)="openModal('p34_leaveApprovalModal');closeModal('p34_employeeRequestsModal')">Review</button></div>
        <div class="pm-list-item"><div><strong>Expense Claims</strong><div style="font-size:12px;color:var(--pm-muted)">8 awaiting finance action</div></div><button type="button" class="pm-btn pm-btn-sm" (click)="openModal('p34_expenseApprovalModal');closeModal('p34_employeeRequestsModal')">Review</button></div>
      </div>
      <div class="modal-footer"><button type="button" class="pm-btn" (click)="closeModal('p34_employeeRequestsModal')">Close</button></div>
    </div>
  </div>
</div>


  @if (hasOpenModal()) {
    <div class="modal-backdrop fade show" (click)="closeAllModals()"></div>
  }
</div>
}
}
}
}
}
}
