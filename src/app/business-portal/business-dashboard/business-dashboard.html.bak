<option>Fixed Amount</option>
<option>Customer decides (Donation/Open)</option>
</select></div>
<div class="mb-3"><label class="pm-form-label">Amount (KES)</label><input class="pm-form-control" type="number" value="10000"/></div>
<div class="form-check mb-2"><input checked="" class="form-check-input" type="checkbox"/><label class="form-check-label">Collect customer shipping address</label></div>
<div class="form-check mb-2"><input class="form-check-input" type="checkbox"/><label class="form-check-label">Limit number of uses</label></div>
</div>
<div class="modal-footer"><button (click)="closeModal('p33_newPaymentLinkModal')" class="pm-btn" data-bs-dismiss="modal" type="button">Cancel</button><button (click)="processAction('p33_newPaymentLinkModal', 'Payment Link Created!', 'pay.apex.co.ke/l/dep-10k', 'p33_paymentLinkShareModal')" class="pm-btn pm-btn-primary" type="button">Generate
                        Link</button></div>
</div>
</div>
</div><div (click)="closeModal('p33_newSubscriptionModal')" [attr.aria-hidden]="isModalOpen('p33_newSubscriptionModal') ? null : 'true'" [attr.aria-modal]="isModalOpen('p33_newSubscriptionModal') ? 'true' : null" [class.show]="isModalOpen('p33_newSubscriptionModal')" [style.display]="isModalOpen('p33_newSubscriptionModal') ? 'block' : 'none'" class="modal fade resettable" id="p33_newSubscriptionModal" tabindex="-1">
