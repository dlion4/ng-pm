<div class="col-md-6"><label class="pm-form-label">First Name</label><input class="pm-form-control" placeholder="Jane"/></div>
<div class="col-md-6"><label class="pm-form-label">Last Name</label><input class="pm-form-control" placeholder="Doe"/></div>
<div class="col-md-6"><label class="pm-form-label">National ID / Passport</label><input class="pm-form-control" placeholder="e.g. 29384711"/></div>
<div class="col-md-6"><label class="pm-form-label">Email Address</label><input class="pm-form-control" placeholder="jane.doe@acmecorp.co.ke"/></div>
<div class="col-md-6"><label class="pm-form-label">KRA PIN</label><input class="pm-form-control" placeholder="A000000000X"/></div>
<div class="col-md-6"><label class="pm-form-label">Phone Number</label><input class="pm-form-control" placeholder="0712 345 678"/></div>
</div>
</div>
<div [class.active]="isStep('p34_emp', 2)" [style.display]="isStep('p34_emp', 2) ? 'block' : 'none'" class="fade-step" id="p34_empStep2">
