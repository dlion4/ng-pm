<div class="modal-footer"><button (click)="closeModal('p34_schedulePayrollModal')" class="pm-btn" data-bs-dismiss="modal" type="button">Cancel</button><button (click)="processAction('p34_schedulePayrollModal', 'Auto-payroll schedule saved')" class="pm-btn pm-btn-primary" type="button">Save Schedule</button>
</div>
</div>
</div>
</div><div (click)="closeModal('p34_offboardEmployeeModal')" [attr.aria-hidden]="isModalOpen('p34_offboardEmployeeModal') ? null : 'true'" [attr.aria-modal]="isModalOpen('p34_offboardEmployeeModal') ? 'true' : null" [class.show]="isModalOpen('p34_offboardEmployeeModal')" [style.display]="isModalOpen('p34_offboardEmployeeModal') ? 'block' : 'none'" class="modal fade" id="p34_offboardEmployeeModal" tabindex="-1">
<div (click)="$event.stopPropagation()" class="modal-dialog modal-dialog-centered">
