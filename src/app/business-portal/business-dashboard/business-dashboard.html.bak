<div class="col-md-6"><label class="pm-form-label">Department</label><select class="pm-form-control">
<option>Marketing</option>
<option>Sales</option>
<option>Engineering</option>
<option>HR</option>
</select></div>
<div class="col-md-6"><label class="pm-form-label">Employment Type</label><select class="pm-form-control">
<option>Full-Time Permanent</option>
<option>Contract</option>
<option>Probation</option>
</select></div>
<div class="col-md-6"><label class="pm-form-label">Join Date</label><input class="pm-form-control" type="date"/></div>
<div class="col-md-6"><label class="pm-form-label">Basic Salary (Gross KES)</label><input class="pm-form-control" placeholder="80000" type="number"/></div>
<div class="col-md-6"><label class="pm-form-label">NSSF / SHIF Registration</label><select class="pm-form-control">
<option>Registered (Deduct standard)</option>
<option>Not Registered (Alert HR)</option>
</select></div>
</div>
</div>
<div [class.active]="isStep('p34_emp', 3)" [style.display]="isStep('p34_emp', 3) ? 'block' : 'none'" class="fade-step" id="p34_empStep3">
<h6 style="font-weight:700;margin-bottom:16px">Disbursement Preference</h6>
<div class="mb-3">
<div (click)="selectRadio($event)" class="p-3 border rounded mb-2 d-flex align-items-center gap-3" style="cursor:pointer">
<input checked="" name="payPref" type="radio"/> <i class="bi bi-phone text-success" style="font-size:24px"></i>
<div><strong>M-Pesa B2C (Mobile Money)</strong>
<div style="font-size:11px;color:var(--pm-muted)">Instant delivery to employee phone
                                    </div>
</div>
</div>
<div (click)="selectRadio($event)" class="p-3 border rounded d-flex align-items-center gap-3" style="cursor:pointer">
<input name="payPref" type="radio"/> <i class="bi bi-bank text-info" style="font-size:24px"></i>
<div><strong>Bank Transfer (EFT/PesaLink)</strong>
<div style="font-size:11px;color:var(--pm-muted)">Standard bank settlement</div>
</div>
</div>
</div>
<div class="row g-3" id="p34_bankDetails" style="display:none">
