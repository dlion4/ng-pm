</div>
</div>
</div>
</div><div (click)="closeModal('p32_refundModal')" [attr.aria-hidden]="isModalOpen('p32_refundModal') ? null : 'true'" [attr.aria-modal]="isModalOpen('p32_refundModal') ? 'true' : null" [class.show]="isModalOpen('p32_refundModal')" [style.display]="isModalOpen('p32_refundModal') ? 'block' : 'none'" class="modal fade resettable" id="p32_refundModal" tabindex="-1">
<div (click)="$event.stopPropagation()" class="modal-dialog modal-dialog-centered">
<div class="modal-content">
<div class="modal-header">
<h5 class="modal-title"><i class="bi bi-arrow-return-left text-warning me-2"></i>Process Refund</h5>
<button (click)="closeModal('p32_refundModal')" class="btn-close" data-bs-dismiss="modal" type="button"></button>
</div>
<div class="modal-body">
<div class="pm-stepper" id="p32_refStepper">
  @for (step of stepperItems('p32_ref'); track step.index) {
    <div class="pm-step" [class.completed]="step.index < currentStep('p32_ref')" [class.active]="step.index === currentStep('p32_ref')">
      <div class="pm-step-num">@if (step.index < currentStep('p32_ref')) { <i class="bi bi-check"></i> } @else { {{ step.index }} }</div>
}
      @if (step.label) { <div class="pm-step-label">{{ step.label }}</div> } {
    </div>
    @if (!step.last) { <div class="pm-step-line"></div> } {
  }
</div>
<div [class.active]="isStep('p32_ref', 1)" [style.display]="isStep('p32_ref', 1) ? 'block' : 'none'" class="fade-step active" id="p32_refStep1">
<h6 style="font-weight:700;margin-bottom:16px">Step 1: Select Transaction</h6><input class="pm-form-control mb-3" placeholder="Enter Transaction ID or Phone number"/>
<div class="p-3 border rounded mb-2" style="cursor:pointer;border-color:var(--pm-primary)!important;background:rgba(79,70,229,.04)">
<div class="d-flex justify-content-between"><strong>John Mark</strong><strong>KES
                                    3,400</strong></div>
<div style="font-size:11px;color:var(--pm-muted)">TXN-99120 • M-Pesa • Today 11:42 AM</div>
</div>
<div class="p-3 border rounded mb-2" style="cursor:pointer">
<div class="d-flex justify-content-between"><strong>Sarah W.</strong><strong>KES
                                    1,500</strong></div>
<div style="font-size:11px;color:var(--pm-muted)">TXN-88192 • Visa • Yesterday</div>
</div>
</div>
<div [class.active]="isStep('p32_ref', 2)" [style.display]="isStep('p32_ref', 2) ? 'block' : 'none'" class="fade-step" id="p32_refStep2">
<h6 style="font-weight:700;margin-bottom:16px">Step 2: Refund Details</h6>
<div class="p-3 rounded mb-3" style="background:var(--pm-surface-2);font-size:12px">Original
                            Transaction: KES 3,400 (John Mark)</div>
<div class="mb-3"><label class="pm-form-label">Refund Type</label><select class="pm-form-control">
<option>Full Refund (KES 3,400)</option>
<option>Partial Refund</option>
</select></div>
<div class="mb-3"><label class="pm-form-label">Reason</label><select class="pm-form-control">
<option>Customer requested cancellation</option>
<option>Out of stock / Unavailable</option>
<option>Fraudulent transaction</option>
<option>Duplicate charge</option>
</select></div>
<div class="mb-3"><label class="pm-form-label">PIN to authorize</label>
<div class="pm-pin-input"><input (input)="moveFocus($event)" maxlength="1" type="password"/><input (input)="moveFocus($event)" maxlength="1" type="password"/><input (input)="moveFocus($event)" maxlength="1" type="password"/><input (input)="moveFocus($event)" maxlength="1" type="password"/></div>
</div>
</div>
<div [class.active]="isStep('p32_ref', 3)" [style.display]="isStep('p32_ref', 3) ? 'block' : 'none'" class="fade-step" id="p32_refStep3">
<div class="pm-receipt">
<div class="receipt-icon"><i class="bi bi-check-lg"></i></div>
<h5 style="font-weight:700;color:var(--pm-accent)">Refund Initiated</h5>
<p style="font-size:13px;color:var(--pm-ink-soft)">KES 3,400 will be reversed to John Mark's
                                M-Pesa account.</p>
<p style="font-size:11px;color:var(--pm-muted)">Ref: REF-PM-20250627-011</p>
</div>
</div>
</div>
<div class="modal-footer" id="p32_refFooter"><button (click)="closeModal('p32_refundModal')" class="pm-btn" data-bs-dismiss="modal" type="button">Cancel</button><button (click)="nextStepFlow('p32_ref', 3, 'p32_refundModal', 'Refund authorization completed.', '')" class="pm-btn pm-btn-warning" id="p32_refNextBtn" style="color:#fff" type="button">Continue <i class="bi bi-arrow-right"></i></button>
</div>
</div>
</div>
</div><div (click)="closeModal('p32_disputeModal')" [attr.aria-hidden]="isModalOpen('p32_disputeModal') ? null : 'true'" [attr.aria-modal]="isModalOpen('p32_disputeModal') ? 'true' : null" [class.show]="isModalOpen('p32_disputeModal')" [style.display]="isModalOpen('p32_disputeModal') ? 'block' : 'none'" class="modal fade resettable" id="p32_disputeModal" tabindex="-1">
<div (click)="$event.stopPropagation()" class="modal-dialog modal-lg modal-dialog-centered">
<div class="modal-content">
<div class="modal-header">
<h5 class="modal-title"><i class="bi bi-shield-exclamation text-danger me-2"></i>Dispute /
                        Chargeback Management</h5><button (click)="closeModal('p32_disputeModal')" class="btn-close" data-bs-dismiss="modal" type="button"></button>
</div>
