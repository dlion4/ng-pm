                        Benefits</button></div>
</div>
</div>
</div><div (click)="closeModal('p34_schedulePayrollModal')" [attr.aria-hidden]="isModalOpen('p34_schedulePayrollModal') ? null : 'true'" [attr.aria-modal]="isModalOpen('p34_schedulePayrollModal') ? 'true' : null" [class.show]="isModalOpen('p34_schedulePayrollModal')" [style.display]="isModalOpen('p34_schedulePayrollModal') ? 'block' : 'none'" class="modal fade" id="p34_schedulePayrollModal" tabindex="-1">
<div (click)="$event.stopPropagation()" class="modal-dialog modal-dialog-centered">
<div class="modal-content">
<div class="modal-header">
<h5 class="modal-title"><i class="bi bi-calendar-event me-2"></i>Schedule Auto-Payroll</h5><button (click)="closeModal('p34_schedulePayrollModal')" class="btn-close" data-bs-dismiss="modal" type="button"></button>
</div>
