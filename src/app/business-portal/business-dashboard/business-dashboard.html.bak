<!-- 3.3.3 — COLLECTIONS TRACKING & AGING -->
<!-- ============================================================ -->
<div class="pm-card">
<div class="d-flex justify-content-between align-items-center mb-3 flex-wrap" style="gap:8px">
<div>
<h3 class="pm-section-title"><i class="bi bi-graph-down text-danger me-2"></i> 3.3.3 —
                                Collections Tracking &amp; Aging</h3>
<p class="pm-section-sub">Monitor accounts receivable, Days Sales Outstanding (DSO), and
                                automate your reminder sequences.</p>
</div>
<div class="d-flex gap-2">
<button (click)="openModal('p33_reminderSettingsModal')" class="pm-btn pm-btn-sm" type="button"><i class="bi bi-bell"></i> Reminder Rules</button>
<button (click)="openModal('p33_bulkRemindersModal')" class="pm-btn pm-btn-sm pm-btn-danger" type="button">Send Batch Reminders</button>
</div>
</div>
<div class="row g-3">
<div class="col-lg-6">
<div class="utility-block">
<h4 style="font-size:14px;font-weight:600;margin:0 0 12px">Receivables Aging Breakdown
                                </h4>
<div class="d-flex align-items-end mb-2" style="height:120px;gap:12px;padding-bottom:10px;border-bottom:1px solid var(--pm-border)">
<!-- 0-30 -->
<div style="flex:1;text-align:center;position:relative">
<div style="height:40%;background:var(--pm-accent);border-radius:4px 4px 0 0;width:40px;margin:0 auto">
</div>
<div style="position:absolute;bottom:-20px;left:0;right:0;font-size:10px;color:var(--pm-muted)">
                                            0-30 Days</div>
<div style="font-size:11px;font-weight:600;margin-bottom:4px">KES 220k</div>
</div>
<!-- 31-60 -->
<div style="flex:1;text-align:center;position:relative">
<div style="height:60%;background:var(--pm-warning);border-radius:4px 4px 0 0;width:40px;margin:0 auto">
</div>
<div style="position:absolute;bottom:-20px;left:0;right:0;font-size:10px;color:var(--pm-muted)">
                                            31-60 Days</div>
<div style="font-size:11px;font-weight:600;margin-bottom:4px">KES 145k</div>
</div>
<!-- 61-90 -->
<div style="flex:1;text-align:center;position:relative">
<div style="height:35%;background:#F97316;border-radius:4px 4px 0 0;width:40px;margin:0 auto">
</div>
<div style="position:absolute;bottom:-20px;left:0;right:0;font-size:10px;color:var(--pm-muted)">
                                            61-90 Days</div>
<div style="font-size:11px;font-weight:600;margin-bottom:4px">KES 85k</div>
</div>
<!-- 90+ -->
<div style="flex:1;text-align:center;position:relative">
<div style="height:15%;background:var(--pm-danger);border-radius:4px 4px 0 0;width:40px;margin:0 auto">
</div>
<div style="position:absolute;bottom:-20px;left:0;right:0;font-size:10px;color:var(--pm-muted)">
                                            90+ Days</div>
<div style="font-size:11px;font-weight:600;margin-bottom:4px">KES 32k</div>
</div>
</div>
<div class="mt-4 text-center">
<button (click)="openModal('p33_agingReportModal')" class="pm-btn pm-btn-sm" type="button">View Full
                                        Aging Report</button>
</div>
</div>
</div>
<div class="col-lg-6">
<div class="utility-block">
<h4 style="font-size:14px;font-weight:600;margin:0 0 12px">Active Escalations &amp; Promises
                                    to Pay</h4>
<div class="status-row">
<div>
<strong>Nairobi Tech Ltd</strong>
<div style="font-size:11px;color:var(--pm-danger)">14 days overdue · KES 85,000
                                        </div>
</div>
<div>
<span class="pm-badge pm-badge-info">Promise: 30 Jun</span>
<button (click)="openModal('p33_recordPaymentModal')" class="pm-btn pm-btn-sm ms-2" type="button">Resolve</button>
</div>
</div>
<div class="status-row">
<div>
<strong>Mwangi Hardware</strong>
<div style="font-size:11px;color:var(--pm-danger)">65 days overdue · KES 42,000
                                        </div>
</div>
<div>
<span class="pm-badge pm-badge-warning">Escalated: Legal</span>
<button (click)="openModal('p33_attentionModal')" class="pm-btn pm-btn-sm ms-2" type="button">View</button>
</div>
</div>
</div>
</div>
</div>
</div>
