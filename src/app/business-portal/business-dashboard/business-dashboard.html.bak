<div class="modal-content">
<div class="modal-header">
<h5 class="modal-title"><i class="bi bi-shield-exclamation text-danger me-2"></i>Dunning (Retry)
                        Rules</h5><button (click)="closeModal('p33_dunningSettingsModal')" class="btn-close" data-bs-dismiss="modal" type="button"></button>
</div>
<div class="modal-body">
<p style="font-size:13px;color:var(--pm-ink-soft)">What happens when a recurring subscription card
                        or token fails?</p>
<div class="p-3 border rounded mb-2"><strong style="font-size:13px">First Retry</strong>
<div class="d-flex align-items-center mt-1"><select class="pm-form-control pm-btn-sm w-50 me-2">
<option>1 Day later</option>
</select> <span style="font-size:11px;color:var(--pm-muted)">Send email</span></div>
</div>
<div class="p-3 border rounded mb-2"><strong style="font-size:13px">Second Retry</strong>
<div class="d-flex align-items-center mt-1"><select class="pm-form-control pm-btn-sm w-50 me-2">
<option>3 Days later</option>
</select> <span style="font-size:11px;color:var(--pm-muted)">Send email + SMS</span></div>
</div>
<div class="p-3 border rounded mb-3"><strong style="font-size:13px">Third Retry</strong>
<div class="d-flex align-items-center mt-1"><select class="pm-form-control pm-btn-sm w-50 me-2">
<option>7 Days later</option>
</select> <span style="font-size:11px;color:var(--pm-muted)">Final warning</span></div>
</div>
<div class="mb-3"><label class="pm-form-label">Action after final failure</label><select class="pm-form-control">
<option>Cancel subscription automatically</option>
<option>Pause subscription and notify admin</option>
<option>Leave active but mark unpaid</option>
</select></div>
</div>
<div class="modal-footer"><button (click)="closeModal('p33_dunningSettingsModal')" class="pm-btn" data-bs-dismiss="modal" type="button">Cancel</button><button (click)="processAction('p33_dunningSettingsModal', 'Dunning schedule updated.', '')" class="pm-btn pm-btn-primary" type="button">Save
                        Logic</button></div>
</div>
</div>
