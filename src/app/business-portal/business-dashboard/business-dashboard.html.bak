</div>
</div>
</div><div (click)="closeModal('p32_customerSegmentModal')" [attr.aria-hidden]="isModalOpen('p32_customerSegmentModal') ? null : 'true'" [attr.aria-modal]="isModalOpen('p32_customerSegmentModal') ? 'true' : null" [class.show]="isModalOpen('p32_customerSegmentModal')" [style.display]="isModalOpen('p32_customerSegmentModal') ? 'block' : 'none'" class="modal fade resettable" id="p32_customerSegmentModal" tabindex="-1">
