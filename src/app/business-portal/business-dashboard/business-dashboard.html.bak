<!-- ===== Angularized body content from source 3.3.html ===== -->
<div><section class="paymo-page-source" id="p33_page">
<!-- HEADER -->

<!-- PAGE BAR -->
<div class="pm-page-bar">
<div>
<div class="pm-breadcrumb"><a (click)="notify('Link action handled')" role="button" tabindex="0">Business Portal</a> / <a (click)="notify('Link action handled')" role="button" tabindex="0">Collections</a> /
                        <strong>Invoicing &amp; Billing</strong></div>
<h2 style="font-family:var(--pm-font-display);font-size:20px;font-weight:700;margin:8px 0 2px">PAGE
                        3.3 — Invoicing &amp; Billing</h2>
<p style="font-size:13px;color:var(--pm-ink-soft);margin:0">Create invoices, manage payment links,
                        automate DSOs, and track recurring subscriptions in real-time.</p>
</div>
<div class="d-flex flex-wrap" style="gap:8px">
<button (click)="openModal('p33_newPaymentLinkModal')" class="pm-btn" type="button"><i class="bi bi-link-45deg"></i>
                        Payment Link</button>
<button (click)="openModal('p33_newSubscriptionModal')" class="pm-btn" type="button"><i class="bi bi-arrow-repeat"></i> Subscription</button>
<button (click)="openModal('p33_newInvoiceModal')" class="pm-btn-primary pm-btn" type="button"><i class="bi bi-plus-lg"></i> New Invoice</button>
</div>
</div>
<div class="pm-content">
<!-- HERO STATS ROW -->
<div class="row g-3">
<!-- Card 1: Outstanding -->
<div class="col-lg-3 col-md-6">
<div class="pm-card pm-card-accent" style="min-height:160px">
<p style="margin:0;font-size:11px;color:rgba(255,255,255,.7);text-transform:uppercase;letter-spacing:0.05em;font-weight:600">
                                TOTAL OUTSTANDING</p>
<div class="pm-stat-value" style="margin:8px 0;color:#fff">KES 482,500</div>
<div class="invoice-status-bar mt-3 mb-2">
<div class="invoice-status-seg" style="width:45%;background:#10B981" title="Not Due">
</div>
<div class="invoice-status-seg" style="width:25%;background:#FBBF24" title="1-30 Days">
</div>
<div class="invoice-status-seg" style="width:20%;background:#F59E0B" title="31-60 Days">
</div>
<div class="invoice-status-seg" style="width:10%;background:#EF4444" title="60+ Days">
</div>
</div>
<div class="d-flex justify-content-between" style="font-size:11px;color:rgba(255,255,255,.8)">
<span><span style="color:#FCA5A5">●</span> Overdue: <strong>KES 168k</strong></span>
<a (click)="openModal('p33_agingReportModal')" role="button" style="color:#fff;text-decoration:underline" tabindex="0">Aging Report</a>
</div>
</div>
</div>
<!-- Card 2: Monthly Invoiced -->
<div class="col-lg-3 col-md-6">
<div class="pm-card" style="min-height:160px">
<p class="pm-stat-label" style="color:var(--pm-primary)">THIS MONTH INVOICED</p>
<div class="pm-stat-value" style="margin:6px 0">KES 1.2M</div>
<span class="pm-badge pm-badge-success"><i class="bi bi-arrow-up-right"></i> 14% vs last
                                mo</span>
<div class="mt-3">
<div class="d-flex justify-content-between mb-1" style="font-size:11px;color:var(--pm-muted)"><span>Collection
                                        Rate</span><span>82%</span></div>
<div class="pm-progress">
<div class="pm-progress-bar" style="width:82%;background:var(--pm-primary)"></div>
</div>
</div>
</div>
</div>
<!-- Card 3: MRR -->
<div class="col-lg-3 col-md-6">
<div class="pm-card" style="min-height:160px">
<p class="pm-stat-label" style="color:var(--pm-info)">MONTHLY RECURRING (MRR)</p>
<div class="pm-stat-value" style="margin:6px 0">KES 345,000</div>
<span class="pm-badge pm-badge-info"><i class="bi bi-arrow-repeat"></i> 124 Active
                                Subs</span>
<div class="pm-mini-bars mt-3">
<div class="pm-mini-bar" style="height:50%;background:var(--pm-info)"></div>
<div class="pm-mini-bar" style="height:60%;background:var(--pm-info)"></div>
<div class="pm-mini-bar" style="height:55%;background:var(--pm-info)"></div>
<div class="pm-mini-bar" style="height:70%;background:var(--pm-info)"></div>
<div class="pm-mini-bar" style="height:85%;background:var(--pm-info)"></div>
<div class="pm-mini-bar" style="height:100%;background:var(--pm-primary)"></div>
</div>
</div>
</div>
<!-- Card 4: DSO -->
<div class="col-lg-3 col-md-6">
<div class="pm-card" style="min-height:160px;border-left:3px solid var(--pm-warning)">
<p class="pm-stat-label" style="color:var(--pm-warning)">DAYS SALES OUTSTANDING</p>
<div class="pm-stat-value" style="margin:6px 0">28 Days</div>
<span class="pm-badge pm-badge-success"><i class="bi bi-check-circle"></i> Healthy</span>
<div class="mt-2" style="font-size:12px;color:var(--pm-ink-soft)">
<div>Link Conversions: <strong>68% paid</strong></div>
<div>Avg time to pay: <strong>1.2 days</strong> (via Link)</div>
</div>
</div>
</div>
</div>
<!-- ATTENTION / SUGGESTIONS / QUICK ACTIONS -->
<div class="row g-3">
<div class="col-lg-4">
<div class="pm-card" style="height:100%">
<div class="d-flex justify-content-between align-items-center mb-3">
<h3 class="pm-section-title">Attention Required</h3>
<button (click)="openModal('p33_attentionModal')" class="pm-btn pm-btn-sm" type="button">View all</button>
</div>
<div class="feed-item">
<div class="pm-icon-circle" style="background:var(--pm-danger-soft);color:var(--pm-danger);font-size:12px">INV
                                </div>
<div style="flex:1;min-width:0">
<div style="font-weight:600;font-size:13px">INV-2025-042 is 14 days overdue</div>
<div style="font-size:11px;color:var(--pm-muted)">Nairobi Tech Ltd · KES 85,000
                                    </div>
</div>
<button (click)="openModal('p33_bulkRemindersModal')" class="pm-btn pm-btn-sm pm-btn-danger" type="button">Remind</button>
</div>
<div class="feed-item">
<div class="pm-icon-circle" style="background:var(--pm-warning-soft);color:var(--pm-warning);font-size:12px">SUB
                                </div>
<div style="flex:1;min-width:0">
<div style="font-weight:600;font-size:13px">Subscription payment failed</div>
<div style="font-size:11px;color:var(--pm-muted)">Premium Plan · KES 5,000/mo (Retry
                                        2)</div>
</div>
<button (click)="openModal('p33_dunningSettingsModal')" class="pm-btn pm-btn-sm" type="button">Dunning</button>
</div>
<div class="feed-item">
<div class="pm-icon-circle" style="background:var(--pm-purple-soft);color:var(--pm-purple);font-size:12px">LNK
                                </div>
<div style="flex:1;min-width:0">
<div style="font-weight:600;font-size:13px">High value link abandoned</div>
<div style="font-size:11px;color:var(--pm-muted)">Link LNK-992 · KES 120,000 viewed
                                        3x</div>
</div>
<button (click)="openModal('p33_linkAnalyticsModal')" class="pm-btn pm-btn-sm" type="button">Track</button>
</div>
</div>
</div>
<div class="col-lg-4">
<div class="pm-card" style="height:100%">
<div class="d-flex justify-content-between align-items-center mb-3">
<h3 class="pm-section-title">Smart Suggestions</h3>
<span class="pm-badge pm-badge-purple"><i class="bi bi-stars"></i> AI</span>
</div>
<div class="feed-item">
<div class="pm-icon-circle" style="background:var(--pm-accent-soft);color:var(--pm-accent);font-size:12px">AR
                                </div>
<div style="flex:1;min-width:0">
<div style="font-weight:600;font-size:13px">Enable auto-reminders</div>
<div style="font-size:11px;color:var(--pm-muted)">Reduce DSO by approx 4 days</div>
</div>
<button (click)="openModal('p33_reminderSettingsModal')" class="pm-btn pm-btn-sm" type="button">Setup</button>
</div>
<div class="feed-item">
<div class="pm-icon-circle" style="background:var(--pm-info-soft);color:var(--pm-info);font-size:12px">UP</div>
<div style="flex:1;min-width:0">
<div style="font-weight:600;font-size:13px">Offer early payment discount</div>
<div style="font-size:11px;color:var(--pm-muted)">To 3 clients with 60+ days aging
                                    </div>
</div>
<button (click)="openModal('p33_suggestionsModal')" class="pm-btn pm-btn-sm" type="button">Review</button>
</div>
<div class="feed-item">
<div class="pm-icon-circle" style="background:var(--pm-warning-soft);color:var(--pm-warning);font-size:12px">TAX
                                </div>
<div style="flex:1;min-width:0">
<div style="font-weight:600;font-size:13px">Update Withholding Tax rates</div>
<div style="font-size:11px;color:var(--pm-muted)">New KRA brackets detected for
                                        services</div>
</div>
<button (click)="openModal('p33_taxSettingsModal')" class="pm-btn pm-btn-sm" type="button">Update</button>
</div>
</div>
</div>
<div class="col-lg-4">
<div class="pm-card" style="height:100%">
<div class="mb-3">
<h3 class="pm-section-title">Quick Actions</h3>
<p class="pm-section-sub">Common billing workflows</p>
</div>
<div class="quick-action-grid">
<button (click)="openModal('p33_newInvoiceModal')" class="quick-action-btn" type="button"><i class="bi bi-receipt text-primary me-1"></i> New Invoice</button>
<button (click)="openModal('p33_newPaymentLinkModal')" class="quick-action-btn" type="button"><i class="bi bi-link-45deg text-success me-1"></i> Payment Link</button>
<button (click)="openModal('p33_newSubscriptionModal')" class="quick-action-btn" type="button"><i class="bi bi-arrow-repeat text-info me-1"></i> Subscription</button>
<button (click)="openModal('p33_creditNoteModal')" class="quick-action-btn" type="button"><i class="bi bi-file-earmark-minus text-warning me-1"></i> Credit Note</button>
<button (click)="openModal('p33_recordPaymentModal')" class="quick-action-btn" type="button"><i class="bi bi-cash text-success me-1"></i> Record Pay</button>
<button (click)="openModal('p33_bulkRemindersModal')" class="quick-action-btn" type="button"><i class="bi bi-bell me-1" style="color:var(--pm-purple)"></i> Reminders</button>
<button (click)="openModal('p33_customerSelectModal')" class="quick-action-btn" type="button"><i class="bi bi-people text-secondary me-1"></i> Customers</button>
<button (click)="openModal('p33_invoiceTemplatesModal')" class="quick-action-btn" type="button"><i class="bi bi-palette text-danger me-1"></i> Templates</button>
</div>
</div>
</div>
</div>
