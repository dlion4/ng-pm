                        Customer</button></div>
</div>
</div>
</div><div (click)="closeModal('p32_feeCalculatorModal')" [attr.aria-hidden]="isModalOpen('p32_feeCalculatorModal') ? null : 'true'" [attr.aria-modal]="isModalOpen('p32_feeCalculatorModal') ? 'true' : null" [class.show]="isModalOpen('p32_feeCalculatorModal')" [style.display]="isModalOpen('p32_feeCalculatorModal') ? 'block' : 'none'" class="modal fade resettable" id="p32_feeCalculatorModal" tabindex="-1">
<div (click)="$event.stopPropagation()" class="modal-dialog modal-dialog-centered">
<div class="modal-content">
<div class="modal-header">
<h5 class="modal-title"><i class="bi bi-calculator me-2"></i>Transaction Fee Calculator</h5><button (click)="closeModal('p32_feeCalculatorModal')" class="btn-close" data-bs-dismiss="modal" type="button"></button>
</div>
<div class="modal-body">
<div class="mb-3"><label class="pm-form-label">Transaction Amount (KES)</label><input (input)="setCalcAmount($event)" class="pm-form-control" id="p32_calcAmt" type="number" value="10000"/></div>
<div class="table-responsive">
<table class="pm-table">
<thead>
<tr>
<th>Method</th>
<th>MDR Rate</th>
<th>Fee Deduction</th>
<th>Net Settlement</th>
</tr>
</thead>
<tbody>
<tr>
<td>PayBill</td>
<td>1.5%</td>
<td>KES <span class="calc-pb-fee">{{ fee['paybillFee'] }}</span></td>
<td><strong style="color:var(--pm-primary)">KES <span class="calc-pb-net">{{ fee['paybillNet'] }}</span></strong></td>
</tr>
<tr>
<td>Till</td>
<td>1.0%</td>
<td>KES <span class="calc-till-fee">{{ fee['tillFee'] }}</span></td>
<td><strong style="color:var(--pm-primary)">KES <span class="calc-till-net">{{ fee['tillNet'] }}</span></strong></td>
</tr>
<tr>
<td>Card (Visa/MC)</td>
<td>2.9%</td>
<td>KES <span class="calc-card-fee">{{ fee['cardFee'] }}</span></td>
<td><strong style="color:var(--pm-primary)">KES <span class="calc-card-net">{{ fee['cardNet'] }}</span></strong></td>
</tr>
<tr>
<td>PesaLink</td>
<td>Fixed</td>
<td>KES <span class="calc-pesa-fee">{{ fee['pesalinkFee'] }}</span></td>
<td><strong style="color:var(--pm-primary)">KES <span class="calc-pesa-net">{{ fee['pesalinkNet'] }}</span></strong></td>
</tr>
</tbody>
</table>
</div>
<div class="p-3 rounded mt-3" style="background:var(--pm-surface-2);font-size:12px">All fees are
                        deducted gross before settlement. No hidden charges.</div>
</div>
<div class="modal-footer"><button (click)="closeModal('p32_feeCalculatorModal')" class="pm-btn" data-bs-dismiss="modal" type="button">Close</button></div>
</div>
</div>
</div><div (click)="closeModal('p32_exportReportModal')" [attr.aria-hidden]="isModalOpen('p32_exportReportModal') ? null : 'true'" [attr.aria-modal]="isModalOpen('p32_exportReportModal') ? 'true' : null" [class.show]="isModalOpen('p32_exportReportModal')" [style.display]="isModalOpen('p32_exportReportModal') ? 'block' : 'none'" class="modal fade resettable" id="p32_exportReportModal" tabindex="-1">
