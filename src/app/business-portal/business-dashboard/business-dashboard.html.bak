</div><button (click)="processAction('p32_apiConfigModal', 'Keys rotated successfully. Update your application.', '')" class="pm-btn pm-btn-sm pm-btn-danger" type="button"><i class="bi bi-arrow-repeat"></i> Rotate Keys</button>
