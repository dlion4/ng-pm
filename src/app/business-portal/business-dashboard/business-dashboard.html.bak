</div>
</div>
</section><section class="paymo-page-modals" id="p33_modals"><div (click)="closeModal('p33_newInvoiceModal')" [attr.aria-hidden]="isModalOpen('p33_newInvoiceModal') ? null : 'true'" [attr.aria-modal]="isModalOpen('p33_newInvoiceModal') ? 'true' : null" [class.show]="isModalOpen('p33_newInvoiceModal')" [style.display]="isModalOpen('p33_newInvoiceModal') ? 'block' : 'none'" class="modal fade resettable" id="p33_newInvoiceModal" tabindex="-1">
<div (click)="$event.stopPropagation()" class="modal-dialog modal-xl modal-dialog-centered">
<div class="modal-content">
<div class="modal-header">
<h5 class="modal-title"><i class="bi bi-receipt me-2 text-primary"></i>Create New Invoice</h5>
<button (click)="closeModal('p33_newInvoiceModal')" class="btn-close" data-bs-dismiss="modal" type="button"></button>
</div>
<div class="modal-body" id="p33_invModalBody">
<div class="pm-stepper" id="p33_invStepper">
  @for (step of stepperItems('p33_inv'); track step.index) {
    <div class="pm-step" [class.completed]="step.index < currentStep('p33_inv')" [class.active]="step.index === currentStep('p33_inv')">
      <div class="pm-step-num">@if (step.index < currentStep('p33_inv')) { <i class="bi bi-check"></i> } @else { {{ step.index }} }</div>
}
      @if (step.label) { <div class="pm-step-label">{{ step.label }}</div> } {
    </div>
    @if (!step.last) { <div class="pm-step-line"></div> } {
  }
</div>
<div [class.active]="isStep('p33_inv', 1)" [style.display]="isStep('p33_inv', 1) ? 'block' : 'none'" class="fade-step active" id="p33_invStep1">
<h6 style="font-weight:700">Client Details</h6>
<div class="row g-3 mb-3">
<div class="col-md-8"><label class="pm-form-label">Select Client</label>
<div class="d-flex gap-2">
<select class="pm-form-control">
<option>Select existing...</option>
<option>Nairobi Tech Ltd</option>
<option>Amina Traders</option>
</select>
<button (click)="openModal('p33_customerSelectModal')" class="pm-btn pm-btn-primary" type="button"><i class="bi bi-person-plus"></i></button>
</div>
</div>
<div class="col-md-4"><label class="pm-form-label">Currency</label><select class="pm-form-control">
<option>KES - Kenyan Shilling</option>
<option>USD - US Dollar</option>
</select></div>
<div class="col-md-6"><label class="pm-form-label">Invoice Date</label><input class="pm-form-control" type="date" value="2025-06-27"/></div>
<div class="col-md-6"><label class="pm-form-label">Due Date</label><input class="pm-form-control" type="date" value="2025-07-11"/></div>
</div>
</div>
<div [class.active]="isStep('p33_inv', 2)" [style.display]="isStep('p33_inv', 2) ? 'block' : 'none'" class="fade-step" id="p33_invStep2">
<div class="d-flex justify-content-between align-items-center mb-2">
<h6 style="font-weight:700;margin:0">Line Items</h6><button (click)="openModal('p33_itemCatalogModal')" class="pm-btn pm-btn-sm" type="button"><i class="bi bi-list"></i> Catalog</button>
</div>
<div class="p-3 border rounded mb-3" style="background:var(--pm-surface-2)">
<div class="invoice-item-row fw-bold" style="font-size:12px;color:var(--pm-muted)">
<div style="flex:3">Description</div>
<div style="flex:1">Qty</div>
<div style="flex:1">Unit Price</div>
<div style="flex:1">Tax</div>
<div style="flex:1;text-align:right">Amount</div>
</div>
<div class="invoice-item-row">
<div class="invoice-item-col" style="flex:3"><input class="pm-form-control" value="Web Development Consulting"/></div>
<div class="invoice-item-col"><input class="pm-form-control" type="number" value="40"/>
</div>
<div class="invoice-item-col"><input class="pm-form-control" type="number" value="2500"/>
</div>
<div class="invoice-item-col"><select class="pm-form-control">
<option>VAT 16%</option>
<option>Exempt</option>
</select></div>
<div class="invoice-item-col" style="text-align:right;font-weight:700;padding-top:10px">
                                    100,000</div>
</div>
<button class="pm-btn pm-btn-sm mt-2" type="button"><i class="bi bi-plus"></i> Add Item</button>
</div>
<div class="row">
<div class="col-md-6 offset-md-6">
<div class="d-flex justify-content-between mb-2">
<span>Subtotal</span><strong>100,000</strong></div>
<div class="d-flex justify-content-between mb-2"><span>VAT
                                        (16%)</span><strong>16,000</strong></div>
<hr class="pm-divider"/>
<div class="d-flex justify-content-between"><span class="fw-bold">Total
                                        (KES)</span><strong style="color:var(--pm-primary);font-size:18px">116,000</strong></div>
</div>
</div>
</div>
<div [class.active]="isStep('p33_inv', 3)" [style.display]="isStep('p33_inv', 3) ? 'block' : 'none'" class="fade-step" id="p33_invStep3">
<h6 style="font-weight:700">Settings &amp; Attachments</h6>
<div class="mb-3"><label class="pm-form-label">Notes / Terms</label><textarea class="pm-form-control" rows="3">Payment due within 14 days. Late payments subject to 2% penalty.</textarea>
</div>
<div class="form-check mb-2"><input checked="" class="form-check-input" type="checkbox"/><label class="form-check-label">Attach PDF Payment Link via PayMo Checkout</label></div>
<div class="form-check mb-2"><input checked="" class="form-check-input" type="checkbox"/><label class="form-check-label">Enable automated email reminders</label></div>
<div class="mb-3 mt-3"><label class="pm-form-label">Attachments (PO, Timesheet)</label><input class="pm-form-control" type="file"/></div>
</div>
<div [class.active]="isStep('p33_inv', 4)" [style.display]="isStep('p33_inv', 4) ? 'block' : 'none'" class="fade-step" id="p33_invStep4">
<div class="pm-receipt">
<div class="receipt-icon"><i class="bi bi-check-lg"></i></div>
<h5 style="font-weight:700;color:var(--pm-accent)">Invoice Ready</h5>
<p style="font-size:13px;color:var(--pm-ink-soft)">INV-2025-048 for KES 116,000 has been
                                created.</p>
<div class="d-flex justify-content-center gap-2 mt-3">
<button (click)="openModal('p33_sendInvoiceModal')" class="pm-btn pm-btn-sm" type="button"><i class="bi bi-send"></i> Send Now</button>
<button (click)="openModal('p33_invoiceDetailModal')" class="pm-btn pm-btn-sm" type="button"><i class="bi bi-eye"></i> Preview</button>
</div>
</div>
</div>
</div>
<div class="modal-footer" id="p33_invFooter">
<button (click)="closeModal('p33_newInvoiceModal')" class="pm-btn" data-bs-dismiss="modal" type="button">Cancel</button>
<button (click)="nextStepFlow('p33_inv', 4, 'p33_newInvoiceModal', 'Invoice created and queued for sending.', '')" class="pm-btn pm-btn-primary" id="p33_invNextBtn" type="button">Next <i class="bi bi-arrow-right"></i></button>
</div>
</div>
</div>
</div><div (click)="closeModal('p33_newPaymentLinkModal')" [attr.aria-hidden]="isModalOpen('p33_newPaymentLinkModal') ? null : 'true'" [attr.aria-modal]="isModalOpen('p33_newPaymentLinkModal') ? 'true' : null" [class.show]="isModalOpen('p33_newPaymentLinkModal')" [style.display]="isModalOpen('p33_newPaymentLinkModal') ? 'block' : 'none'" class="modal fade resettable" id="p33_newPaymentLinkModal" tabindex="-1">
