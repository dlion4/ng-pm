</div><div (click)="closeModal('p32_analyticsModal')" [attr.aria-hidden]="isModalOpen('p32_analyticsModal') ? null : 'true'" [attr.aria-modal]="isModalOpen('p32_analyticsModal') ? 'true' : null" [class.show]="isModalOpen('p32_analyticsModal')" [style.display]="isModalOpen('p32_analyticsModal') ? 'block' : 'none'" class="modal fade resettable" id="p32_analyticsModal" tabindex="-1">
